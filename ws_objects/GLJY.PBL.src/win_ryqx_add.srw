public subroutine fun_tzsb (string temp)
end prototypes

public subroutine fun_tzsb (string temp);choose case temp
	case '1'
	case '2'
		if cbx_dt.checked = true and cbx_dtjymark.checked = true and + &
			cbx_dt1.checked = true and cbx_dt2.checked = true and cbx_dt5.checked = true and + &
			cbx_qzj.checked = true and cbx_qzjjymark.checked = true and + &
			cbx_qzj1.checked = true and cbx_qzj2.checked = true and cbx_qzj3.checked = true and + &
			cbx_cc.checked = true and cbx_ccjymark.checked = true and  cbx_cc1.checked = true and + &
			cbx_sd.checked = true and cbx_sdjymark.checked = true and + &
			cbx_sd1.checked = true and cbx_sd2.checked = true and + &
			cbx_yl.checked = true and cbx_yljymark.checked = true and + &
			cbx_yl1.checked = true and cbx_yl2.checked = true then
			cbx_jdl.checked = true
		end if
end choose
end subroutine

