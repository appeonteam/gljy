event clicked;call super::clicked;long i,ll_NowRow,ll_RowCount
boolean lb_Succ 
string ls_jymk,ls_jytype
string ls_TestDj[],ls_Testaj[],ls_Testjj[],ls_Testjk[],ls_Testqj[]
string ls_NowRydj,ls_NowRyaj,ls_NowRyjj,ls_NowRyjk,ls_NowRyqj
string ls_NowDjml,ls_NowDjlb,ls_NowAjml,ls_NowAjlb,ls_NowJjml,ls_NowJjlb,ls_NowJkml,ls_NowJklb,ls_NowQjml,ls_NowQjlb
string ls_NowRydjmark,ls_NowRyajmark,ls_NowRyjjmark,ls_NowRyjkmark,ls_NowRyqjmark
delete from a_jykey where ryid like :ls_NowRyid;
if ls_NowRyid = '' or IsNull(ls_NowRyid) then
	MessageBox("ÌáÊ¾","ÈËÔ±¼ìÑéÔ±ºÅÉèÖÃÓÐ´íÎó£¬ÇëÈ·ÈÏÈËÔ±ÒÑ¾­±£´æÁË¼ìÑéÔ±ºÅ!")
	return
end if
if cbx[13].checked = false and cbx[14].checked = false and cbx[15].checked = false and cbx_gn.checked = false then
	MessageBox("ÌáÊ¾","ÇëÑ¡ÔñÖÁÉÙÆð²Ý£¬ÉóºË£¬ÉóÅúÒ»ÖÖµÄÖ°ÄÜ!")
	return
end if
string mc[]

for i = 1 to 12
	if cbx[i].checked = false then continue 
	if cbx[i].checked = true and (mk[i] = '' or isnull(mk[i]))  then
		mc[i] = cbx[i].text
		MessageBox("ÌáÊ¾",mc[i] + "ÀàÄ£¿éÎª¿Õ£¬ÇëÑ¡ÔñÕýÈ·µÄÄ£¿é!")
		return
	end if
next
////////////////////////////////////////////////////////////////////
for i = 1 to 12
	if cbx[i].checked = true then
		dw[i].accepttext()
		ll_RowCount = dw[i].RowCount()
		for ll_NowRow = 1 to ll_RowCount
			ls_jymk = dw[i].GetItemString(ll_NowRow,'jymk')
			if pos(mk[i],ls_jymk) <= 0 then continue
			choose case ls_jymk
				case 'dj'
					ls_TestDj[ll_NowRow] = dw[i].GetItemString(ll_NowRow,'jytype')
					insert into a_jykey (ryid,jytype,ryqc,rysh,rysq,sqid,jymk,bsqid,rysp) values (:ls_NowRyid,:ls_TestDj[ll_NowRow],:ls_ryqc,:ls_rysh,'0','ÎÞ',:ls_jymk,'ÎÞ',:ls_rysp);
				case 'aj'
					ls_Testaj[ll_NowRow] = dw[i].GetItemString(ll_NowRow,'jytype')
					insert into a_jykey (ryid,jytype,ryqc,rysh,rysq,sqid,jymk,bsqid,rysp) values (:ls_NowRyid,:ls_Testaj[ll_NowRow],:ls_ryqc,:ls_rysh,'0','ÎÞ',:ls_jymk,'ÎÞ',:ls_rysp);
				case 'jj'
					ls_Testjj[ll_NowRow] = dw[i].GetItemString(ll_NowRow,'jytype')
					insert into a_jykey (ryid,jytype,ryqc,rysh,rysq,sqid,jymk,bsqid,rysp) values (:ls_NowRyid,:ls_Testjj[ll_NowRow],:ls_ryqc,:ls_rysh,'0','ÎÞ',:ls_jymk,'ÎÞ',:ls_rysp);
				case 'jk'
					ls_Testjk[ll_NowRow] = dw[i].GetItemString(ll_NowRow,'jytype')
					insert into a_jykey (ryid,jytype,ryqc,rysh,rysq,sqid,jymk,bsqid,rysp) values (:ls_NowRyid,:ls_Testjk[ll_NowRow],:ls_ryqc,:ls_rysh,'0','ÎÞ',:ls_jymk,'ÎÞ',:ls_rysp);
				case 'qj'
					ls_Testqj[ll_NowRow] = dw[i].GetItemString(ll_NowRow,'jytype')
					insert into a_jykey (ryid,jytype,ryqc,rysh,rysq,sqid,jymk,bsqid,rysp) values (:ls_NowRyid,:ls_Testqj[ll_NowRow],:ls_ryqc,:ls_rysh,'0','ÎÞ',:ls_jymk,'ÎÞ',:ls_rysp);
			end choose
		next
	end if
next
for i = 1 to 12
	if cbx[i].checked = false then continue 
	if ls_NowRydj='1' then
	else
		if pos(mk[i],'dj') > 0 then
			ls_NowRydj = '1' 
		else
			ls_NowRydj = '0' 
		end if
	end if
	if ls_NowRyaj='1' then
	else
		if pos(mk[i],'aj') > 0 then
			ls_NowRyaj = '1' 
		else
			ls_NowRyaj = '0' 
		end if
	end if
	if ls_NowRyjj='1' then
	else
		if pos(mk[i],'jj') > 0 then
			ls_NowRyjj = '1' 
		else
			ls_NowRyjj = '0' 
		end if
	end if
	if ls_NowRyjk='1' then
	else
		if pos(mk[i],'jk') > 0 then
			ls_NowRyjk = '1' 
		else
			ls_NowRyjk = '0' 
		end if	
	end if
	if ls_NowRyqj='1' then
	else
		if pos(mk[i],'qj') > 0 then
			ls_NowRyqj = '1' 
		else
			ls_NowRyqj = '0' 
		end if
	end if
next
if ls_NowRydj = '1' then   
   ls_NowDjml = fun_getmllb(ls_TestDj,'1')
	ls_NOwDjlb = fun_getmllb(ls_TestDj,'2')
	ls_NowRydjmark = ls_ryqc + ls_rysh + '0' + ls_ysxx + ls_rysp
else
	ls_NowRydjmark = '000' + ls_ysxx + '0'
end if
if ls_NowRyaj = '1' then   
   ls_NowAjml = fun_getmllb(ls_TestAj,'1')
	ls_NowAjlb = fun_getmllb(ls_TestAj,'2')
	ls_NowRyajmark = ls_ryqc + ls_rysh + ls_rysp
else
//	ls_NowRyajmark = ls_ryqc + ls_rysh + ls_rysp
end if
if ls_NowRyjj = '1' then   
   ls_NowJjml = fun_getmllb(ls_TestJj,'1')
	ls_NowJjlb = fun_getmllb(ls_TestJj,'2')
	ls_NowRyjjmark = ls_ryqc + ls_rysh + ls_rysp
else
//	ls_NowRyjjmark = ls_ryqc + ls_rysh + ls_rysp
end if
if ls_NowRyJk = '1' then   
   ls_NowJkml = fun_getmllb(ls_TestJk,'1')
	ls_NowJklb = fun_getmllb(ls_TestJk,'2')
	ls_NowRyjkmark = ls_ryqc + ls_rysh + ls_rysp
else
//	ls_NowRyjkmark = ls_ryqc + ls_rysh + ls_rysp
end if
if ls_NowRyqj = '1' then   
   ls_NowQjml = fun_getmllb(ls_TestQj,'1')
	ls_NowQjlb = fun_getmllb(ls_TestQj,'2')
	if cbx_gn.checked = true then
		ls_NowRyqjmark = ls_ryqc + ls_rysh + ls_rysp + '111'
	else
		for i = 16 to 18
			if cbx[i].checked = true then
				if ls_NowRyqjmark = '' or isnull(ls_NowRyqjmark) then
					ls_NowRyqjmark = '1'
				else
					ls_NowRyqjmark = ls_NowRyqjmark + '1'
				end if
			else
				if ls_NowRyqjmark = '' or isnull(ls_NowRyqjmark) then
					ls_NowRyqjmark = '0'
				else
					ls_NowRyqjmark = ls_NowRyqjmark + '0'
				end if
			end if
		next
		ls_NowRyqjmark = ls_ryqc + ls_rysh + ls_rysp + ls_NowRyqjmark
	end if
else
	if cbx_gn.checked = true then
		ls_NowRyqjmark = '000111'
	else
		for i = 16 to 18
			if cbx[i].checked = true then
				if ls_NowRyqjmark = '' or isnull(ls_NowRyqjmark) then
					ls_NowRyqjmark = '1'
				else
					ls_NowRyqjmark = ls_NowRyqjmark + '1'
				end if
			else
				if ls_NowRyqjmark = '' or isnull(ls_NowRyqjmark) then
					ls_NowRyqjmark = '0'
				else
					ls_NowRyqjmark = ls_NowRyqjmark + '0'
				end if
			end if
		next
		ls_NowRyqjmark = '000' + ls_NowRyqjmark
	end if
end if

update a_rycode set rydj = :ls_NowRydjmark,rydjml = :ls_NowDjml,rydjlb = :ls_NowDjlb,
                    ryaj = :ls_NowRyajmark,ryajml = :ls_NowAjml,ryajlb = :ls_NowAjlb,
						  ryjj = :ls_NowRyjjmark,ryjjml = :ls_NowJjml,ryjjlb = :ls_NowJjlb,
						  ryjk = :ls_NowRyjkmark,ryjkml = :ls_NowJkml,ryjklb = :ls_NowJklb,
						  ryqj = :ls_NowRyqjmark,ryqjml = :ls_NowQjml,ryqjlb = :ls_NowQjlb
where ryid = :gs_keyno;
lb_Succ = true
if sqlca.sqlcode <> 0 then
   lb_Succ = false
end if
if lb_Succ then   
   commit;
	MessageBox("ÌáÊ¾","±£´æ³É¹¦")
else
   rollback;
	MessageBox("ÌáÊ¾","±£´æÊ§°Ü")
end if
win_jykeyset.cb_3.TriggerEvent(Clicked!)
end event

