	mysql = "CREATE view djylrq.view_jybg_total_super (jydw,jyrq,jylb,jyjl,bgbh,xcjyrq,jyid,jyry,sydw,jytype,jyml,ryid) "+&
	"AS select  (select jydw from a_jydw),b_jy_total.jydate,b_jy_total.jylb,b_jy_total.jyjl,b_jy_total.bgid,b_jy_total.nextdate,b_jy_total.jyid,b_jy_total.rymc,b_jy_total.sydw,b_jy_total.jytype,b_jy_total.jyml,b_jy_total.ryid from "+& 
	" b_jy_total  where b_jy_total.shtui <> '-1' and b_jy_total.shsp <> '-1' "+&
	"union   select  (select jydw from a_jydw),b_aj_total.jydate,b_aj_total.jylb,b_aj_total.jyjl,b_aj_total.bgid,'',b_aj_total.jyid,b_aj_total.rymc,b_aj_total.sydw,b_aj_total.jytype,b_aj_total.jyml,b_aj_total.ryid from  "+&
	" b_aj_total  where b_aj_total.shtui <> '-1' and b_aj_total.shsp <> '-1' "+&
	"union  select  (select jydw from a_jydw),b_jj_total.jydate,b_jj_total.jylb,'',b_jj_total.bgid,'',b_jj_total.jyid,b_jj_total.rymc,b_jj_total.sydw,b_jj_total.jytype,b_jj_total.jyml,b_jj_total.ryid from  "+&
	" b_jj_total  where b_jj_total.shtui <> '-1' and b_jj_total.shsp <> '-1' "+&
	"union  select  (select jydw from a_jydw),b_qj_total.jydate,b_qj_total.jylb,'',b_qj_total.bgid,'',b_qj_total.jyid,b_qj_total.rymc,b_qj_total.sydw,b_qj_total.jytype,b_qj_total.jyml,b_qj_total.ryid from  "+&
	" b_qj_total  where b_qj_total.shtui <> '-1' and b_qj_total.shsp <> '-1' "
	execute immediate :mysql using sqlca;
