if mark = 'sqlserver' then
	mysql = "CREATE TABLE djylrq.b_aj_lld (jyid varchar(20) NOT NULL,bgbh varchar(20) NULL,sjdw varchar(60) NULL,"+&
              "sbmc varchar(40) NULL,xm varchar(20) NULL,year1 varchar(4) NULL,mm1 varchar(2) NULL,"+&
              "dd1 varchar(2) NULL,yj1 varchar(80) NULL,yj2 varchar(80) NULL,yj3 varchar(80) NULL,"+&
				  "yj4 varchar(80) NULL,yj5 varchar(80) NULL,yj6 varchar(80) NULL,yj7 varchar(80) NULL,"+&
				  "yj8 varchar(80) NULL,yj9 varchar(80) NULL,yj10 varchar(80) NULL,jjy varchar(10) NULL,"+&
				  "jjrq varchar(20) NULL,jsr varchar(10) NULL,jsrq varchar(20) NULL,cljg1 varchar(80) NULL,"+&
				  "cljg2 varchar(80) NULL,cljg3 varchar(80) NULL,cljg4 varchar(80) NULL,cljg5 varchar(80) NULL,"+&
				  "cljg6 varchar(80) NULL,cljg7 varchar(80) NULL,cljg8 varchar(80) NULL,cljg9 varchar(80) NULL,"+&
				  "cljg10 varchar(80) NULL,fzr varchar(10) NULL,fzrq varchar(20) NULL,year2 varchar(4) NULL,"+&
				  "mm2 varchar(2) NULL,dd2 varchar(2) NULL,sh varchar(10) NULL,shrq varchar(20) NULL,azdw varchar(60) null);"
	execute immediate :mysql using sqlca;
	myindex = "CREATE UNIQUE INDEX b_aj_lld_X ON DJYLRQ.b_aj_lld (jyid)"
	execute immediate :myindex using sqlca;
else
	mysql = "CREATE TABLE b_aj_lld (jyid varchar(20) NOT NULL,bgbh varchar(20) NULL,sjdw varchar(60) NULL,"+&
              "sbmc varchar(40) NULL,xm varchar(20) NULL,year1 varchar(4) NULL,mm1 varchar(2) NULL,"+&
              "dd1 varchar(2) NULL,yj1 varchar(80) NULL,yj2 varchar(80) NULL,yj3 varchar(80) NULL,"+&
				  "yj4 varchar(80) NULL,yj5 varchar(80) NULL,yj6 varchar(80) NULL,yj7 varchar(80) NULL,"+&
				  "yj8 varchar(80) NULL,yj9 varchar(80) NULL,yj10 varchar(80) NULL,jjy varchar(10) NULL,"+&
				  "jjrq varchar(20) NULL,jsr varchar(10) NULL,jsrq varchar(20) NULL,cljg1 varchar(80) NULL,"+&
				  "cljg2 varchar(80) NULL,cljg3 varchar(80) NULL,cljg4 varchar(80) NULL,cljg5 varchar(80) NULL,"+&
				  "cljg6 varchar(80) NULL,cljg7 varchar(80) NULL,cljg8 varchar(80) NULL,cljg9 varchar(80) NULL,"+&
				  "cljg10 varchar(80) NULL,fzr varchar(10) NULL,fzrq varchar(20) NULL,year2 varchar(4) NULL,"+&
				  "mm2 varchar(2) NULL,dd2 varchar(2) NULL,sh varchar(10) NULL,shrq varchar(20) NULL,azdw varchar(60) null,PRIMARY KEY (jyid));"
	execute immediate :mysql using sqlca;
end if
