IF mark = 'sqlserver' THEN
	delsql = "drop view djylrq.view_sb_jy"
	execute immediate :delsql using sqlca;
		mysql="CREATE VIEW djylrq.view_sb_jy(jylb,jyjl,zcid) AS select jylb,jyjl,zcid from "+&
				" sb_jy where xh = (select max(xh) from sb_jy where zcid = sb_jy.zcid) "+&
				"and xh1 in(SELECT MAX(xh1) AS xh1 FROM sb_jy GROUP BY zcid)"
		execute immediate :mysql using sqlca;
ELSE
	delsql = "drop view view_sb_jy"
	execute immediate :delsql using sqlca;
		mysql="CREATE view view_sb_jy(jylb,jyjl,zcid) AS select jylb,jyjl,zcid from "+&
				" sb_jy where xh = (select max(xh) from sb_jy where zcid = sb_jy.zcid) "+&
				"and xh1 in (SELECT MAX(xh1) AS xh1 FROM sb_jy GROUP BY zcid)"
		execute immediate :mysql using sqlca ;		
END IF
