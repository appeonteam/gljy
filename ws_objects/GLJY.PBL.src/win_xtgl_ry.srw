fn=FileOpen(ls_bmp,StreamMode!,Write!,LockReadWrite!,Replace!)
selectblob qm into :pic from a_rycode where ryid like :gs_keyno;
if fn = 1 then 
   if string(pic) = '0x' or isnull(pic) then 
	   setnull(pic) 
   else
	   for po = 1 TO int(len(pic)/32765) + 1
		    pic_temp = blobmid(pic,(po - 1) * 32765 + 1,32765)
		    filewrite(fn,pic_temp)
	   next
		dw_qm.setredraw(false)
		dw_qm.setredraw(true)
		setitem(dw_qm,1,'id',ls_bmp)
