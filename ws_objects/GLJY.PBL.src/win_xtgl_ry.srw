//	messagebox('ÏµÍ³ÌáÊ¾','ÇëÊäÈë¹¤×÷µÄÕ¾µã£¡')
//	return 
//end if	
int count_jyid
if gi_modimark = 1 then
	select count(*) into :count_jyid from a_rycode where jyid = :jyid and jyid <> '' and jyid is not null;
	if count_jyid >= 1  then
		messagebox("ÏµÍ³ÌáÊ¾", + "¼ìÑéÔ±ºÅÒÑ´æÔÚ£¡")
		return
	end if
end if

if gi_modimark = 2 then
	select count(*) into :count_jyid from a_rycode where jyid = :jyid and jyid <> '' and jyid is not null and ryid <> :gs_keyno;
	if count_jyid >= 1  then
		messagebox("ÏµÍ³ÌáÊ¾", + "¼ìÑéÔ±ºÅÒÑ´æÔÚ£¡")
		return
	end if
end if
