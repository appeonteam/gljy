global win_xtgl_ry win_xtgl_ry

type variables
string ls_OldSql
end variables

event open;st_xt.text = gs_jydw
st_date.text=string(date(fun_datetime('date')),'yyyyÄêmmÔÂddÈÕ')
st_title.text = "ÈËÔ±Î¬»¤"

//**FFF Modify **Ôö¼ÓÔ´¹¤ÖÖÈ¨ÏÞ**//
string ls_czzl,ls_czzldm
declare c_px cursor for
select czzl,czzldm from xmlb_dm order by xh;
open c_px;
fetch c_px into :ls_czzl,:ls_czzldm;
do while sqlca.sqlcode = 0 
	lv_source.AddItem(ls_czzl+" "+ls_Czzldm,1)
	fetch c_px into :ls_czzl,:ls_czzldm;
loop
close c_px;
//**end Modify FFF**//
settransobject(dw_1,sqlca)
retrieve(dw_1)
ls_OldSql = dw_1.GetSqlSelect()
dw_1.visible = true
dw_1.enabled = true
cb_ok.visible = false
cb_cancel.visible = false
//
string tempstr1,tempstr2
DECLARE temp_bm CURSOR FOR
SELECT bmid,bmmc
FROM a_bmcode ORDER BY bmid;
OPEN temp_bm;
//ddlb_1.additem(space(40))
//ddlb_bm.additem(space(40))
FETCH temp_bm INTO :tempstr1,:tempstr2;
DO WHILE SQLCA.SQLCODE = 0
	ddlb_1.additem(tempstr2)
//   ddlb_bm.additem(tempstr2)
	setnull(tempstr2)
   FETCH temp_bm INTO :tempstr1,:tempstr2;
LOOP
CLOSE temp_bm;
///////////////////// È¡ÉóºË¼¶±ð
DECLARE temp_jbcode CURSOR FOR
	SELECT jbid,jbmc
	FROM a_jbcode ORDER BY jbid;
OPEN temp_jbcode;
ddlb_jyjb.additem(space(40))
FETCH temp_jbcode INTO :tempstr1,:tempstr2;
DO WHILE SQLCA.SQLCODE = 0
   ddlb_jyjb.additem(tempstr2)
	setnull(tempstr2)
   FETCH temp_jbcode INTO :tempstr1,:tempstr2;
LOOP
CLOSE temp_jbcode;
//////////////////// END
DECLARE zh CURSOR FOR
	SELECT zh,zm
	FROM a_gzz 
	ORDER BY zh;
OPEN zh;
FETCH zh INTO :tempstr1,:tempstr2;
DO WHILE SQLCA.SQLCODE = 0
   ddlb_zhmark.additem(tempstr1 + '  ' + tempstr2)
	setnull(tempstr1)
	setnull(tempstr2)
   FETCH zh INTO :tempstr1,:tempstr2;
LOOP
CLOSE zh;
/////////////////¾­·ÑÉóÅú¼¶±ð
string jb1,mc1
DECLARE cur_sb CURSOR FOR  
SELECT jb,mc  
FROM jfsq_jb order by xh ;
open cur_sb;
fetch cur_sb into :jb1,:mc1;
ddlb_jf.additem(space(40))
do while sqlca.sqlcode = 0 
	ddlb_jf.additem(mc1 +space(40) + jb1)
   fetch cur_sb into :jb1,:mc1;	
loop
close cur_sb;

ddlb_jyjb.additem(space(40))
ddlb_bm.selectitem(0)
ddlb_jyjb.selectitem(0)
ddlb_zhmark.selectitem(1)
gi_modimark = 0 
gs_keyno = ''

dw_qm.settransobject(sqlca)
dw_qm.insertrow(0)
FileDelete('c:\jyoa\qm.bmp')
//////////////////////////////////////////////////////////
string supervisor
select supervisor into :supervisor from a_rycode where ryid like :gs_keyno;
if supervisor='' or isnull(supervisor) then
	cbx_1.checked=false
	sle_1.text=""
else
	cbx_1.checked=true
	sle_1.text=mid(supervisor,2)
end if
////////////////////////////////////////////
end event

