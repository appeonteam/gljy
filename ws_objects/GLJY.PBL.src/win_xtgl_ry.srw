	messagebox('ÏµÍ³ÌáÊ¾','ÇëÊäÈë´úÂë£¡')
	return 
end if	
if arypass = '' then
	messagebox('ÏµÍ³ÌáÊ¾','ÇëÊäÈë¿ÚÁî£¡')
	return 
end if	
//**Modify By FFF **//**TransPass**//
long ll_expass
string ls_NowPass
select count(*) into :ll_expass from a_rycode where mark like '%';
if sqlca.sqlcode = -1 then
   if arypass = '||++-+_|=*' then
		select rypass into :ls_NowPass from a_rycode where ryid like :gs_KeyNo;
	else
		ls_NowPass = arypass
	end if
else
	if arypass = '||++-+_|=*' then
		select rypass into :ls_NowPass from a_rycode where ryid like :gs_KeyNo;
	else
		ls_NowPass = arypass
	   ls_NowPass = Fun_TransPass(ls_NowPass)
	end if
end if
arypass = ls_NowPass
//**Modify End **//
