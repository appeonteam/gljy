type ddlb_bm from dropdownlistbox within win_xtgl_ry
event ue_init ( string addrid )
integer x = 1618
integer y = 244
integer width = 535
integer height = 544
integer taborder = 100
boolean bringtotop = true
integer textsize = -11
integer weight = 400
fontpitch fontpitch = variable!
string facename = "ËÎÌå"
long backcolor = 16777215
boolean sorted = false
boolean vscrollbar = true
borderstyle borderstyle = stylelowered!
end type

event ue_init(string addrid);//ÉèÖÃddlb_bm
ddlb_bm.text = ""
ddlb_bm.reset()
datastore lds_bm
lds_bm = create datastore
lds_bm.dataobject = 'dw_xtgl_bm'
lds_bm.settransobject(sqlca)

string ls_str_select,ls_str_where,ls_str_sql
ls_str_select = lds_bm.getsqlselect()
ls_str_where = " where addrid = '" + addrid + "'"
ls_str_sql = ls_str_select + ls_str_where
lds_bm.setsqlselect(ls_str_sql)

lds_bm.retrieve()
long ll_row_count
ll_row_count = lds_bm.rowcount()
if ll_row_count > 0 then
	lds_bm.setsort('bmid A')
	lds_bm.sort()
	
	int i
	string ls_id,ls_mc
	this.reset()
	for i = 1 to ll_row_count
		ls_id = lds_bm.getitemstring(i,'bmid')
		ls_mc = lds_bm.getitemstring(i,'bmmc')
		this.additem(ls_mc)
	next
end if

destroy lds_bm
end event

