//** px ±äÁ¿ Modify **//
string ls_rypx
int    li_PxCount,li_Pxi,li_PxNumber
string ls_pxCzzl
ListViewItem lvi_pxNow
//**px ±äÁ¿**//
if cbx_px.checked then
	arymk = '1'
	
	//**Modify by FFF**//
	ls_rypx = '00000000000000000000'
	if cbx_pxgl.Checked then
		ls_rypx = Replace(ls_rypx,1,1,'1')
	end if
	if cbx_pxsh.Checked then
		ls_rypx = Replace(ls_rypx,2,1,'1')
	end if
	li_PxCount = lv_Dest.TotalItems()
	if li_PxCount > 18 then
		MessageBox("ÌáÊ¾","¹¤ÖÖÊýÁ¿×î¶àÖ»ÄÜÊÇ18¸ö!!")
	end if
	for li_pxi = 1 to li_PxCount
		lv_Dest.GetItem(li_Pxi,lvi_pxNow)
		ls_pxCzzl = lvi_pxNow.label
		ls_PxCzzl = trim(right(ls_PxCzzl,2))
		select xh into :li_PxNumber from xmlb_dm where czzldm = :ls_PxCzzl;
