event dragdrop;ListView  lv_Now
ListViewItem lvi_Now
int   li_Index,li_TotalItem
li_Index = 0
li_TotalItem = 0
lv_Now = draggedObject()
if lv_Now <> lv_source then
	return
end if
lv_Now.GetItem(lv_Now.SelectedIndex(),lvi_Now)
li_Index = lv_dest.FindItem(0,lvi_Now.label,True,true)
if li_Index < 0 then
	lv_dest.AddItem(lvi_Now.label,1)
	//lv_Now.DeleteItem(lv_Now.SelectedIndex())
	lv_Now.Arrange()
	lv_Dest.Arrange()
else
	MessageBox("ÌáÊ¾",lvi_Now.label +" ÒÑ¾­ÊÚÓèÈ¨ÏÞ!")
end if
end event

