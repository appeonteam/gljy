event selectionchanged;string ls_bm,ls_NowSql,ls_FSql
ls_bm = trim(ddlb_1.text)
if ls_bm = '' or isnull(ls_bm) then
	ls_bm = '%'
end if
ls_Fsql = " and rybm like '"+ls_bm+"' "
dw_1.SetSqlSelect(ls_OldSql + ls_Fsql)
dw_1.retrieve()
end event

