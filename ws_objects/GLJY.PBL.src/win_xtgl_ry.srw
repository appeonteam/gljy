select jb into :jbmca from a_jbcode where jbmc like :aryjyjb;
aryjyjb = jbmca

if arymc = '' then
	messagebox('ÏµÍ³ÌáÊ¾','ÇëÊäÈëÐÕÃû£¡')
	return 
end if	
