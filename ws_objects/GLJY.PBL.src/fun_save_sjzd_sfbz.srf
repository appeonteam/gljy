	delsql = "drop view djylrq.view_sjzd_sfmc_nr_ts"
	execute immediate :delsql using sqlca;
	mysql = "CREATE VIEW djylrq.view_sjzd_sfmc_nr_ts as select bglb_id, bg_id, xh_id, xh, " + &
	"(nr + tj + tjnr + '¶Ö¡¤Ã×') as tjnr, sfbz, jymk FROM sjzd_sf_sfmc_nr WHERE (bglb_id = 4) AND (bg_id = 3) AND (xh_id = '1')" 
	execute immediate :mysql using sqlca;
else
	delsql = "drop view view_sjzd_sfmc_nr_ts"
	execute immediate :delsql using sqlca;
	mysql = "CREATE VIEW view_sjzd_sfmc_nr_ts as select bglb_id, bg_id, xh_id, xh, " + &
	"(nr + tj + tjnr + '¶Ö¡¤Ã×') as tjnr, sfbz, jymk FROM sjzd_sf_sfmc_nr WHERE (bglb_id = 4) AND (bg_id = 3) AND (xh_id = '1')" 
