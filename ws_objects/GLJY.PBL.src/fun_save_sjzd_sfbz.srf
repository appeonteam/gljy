	delsql = "drop view djylrq.view_sjzdn_bglb_sf"
	execute immediate :delsql using sqlca;
	mysql = "create View djylrq.view_sjzdn_bglb_sf as select a.id as id,a.mc as mc," + &
		     "b.lbid as lbid,b.sh as sh " + &
		     "from djylrq.sjzdn_bglb as a,djylrq.view_bgml_total as b where a.mc = b.typename and (mark = '' or mark is null)"
	execute immediate :mysql using sqlca;
else
	delsql = "drop view view_sjzdn_bglb_sf"
	execute immediate :delsql using sqlca;
	mysql = "create View view_sjzdn_bglb_sf as select a.id as id,a.mc as mc," + &
