DECLARE temp_zdsh CURSOR FOR
SELECT jytype
FROM a_zdsh_nr ORDER BY jytype; 
OPEN temp_zdsh;
FETCH temp_zdsh INTO :jytype_temp;
do while sqlca.sqlcode = 0
	if isnull(jytype_temp) then jytype_temp = ''
	choose case jytype_temp
		case '6c'
			update a_zdsh_nr set jytype = '6s' where jytype = :jytype_temp;
		case 'Ic'
			select count(*) into :ll_num from a_zdsh_nr where jytype = '6c';
			if ll_num = 0 then
				update a_zdsh_nr set jytype = '6s' where jytype = 'Ic';
			else
				delete a_zdsh_nr where jytype = 'Ic';
				update a_zdsh_nr set jytype = '6s' where jytype = '6c';	
			end if
		case 'Kc'
			update a_zdsh_nr set jytype = 'Ks' where jytype = :jytype_temp;
		case 'Jc'
			update a_zdsh_nr set jytype = 'Js' where jytype = :jytype_temp;
		case 'Id'
			update a_zdsh_nr set jytype = '6d' where jytype = :jytype_temp;
		case 'Ip'
			update a_zdsh_nr set jytype = '6p' where jytype = :jytype_temp;
		case 'Iu'
			delete a_zdsh_nr where jytype = 'Iu';
		case 'Iv'
			update a_zdsh_nr set jytype = '6v' where jytype = :jytype_temp;
		case 'Iw'
			update a_zdsh_nr set jytype = '6w' where jytype = :jytype_temp;
		case '+c'
			update a_zdsh_nr set jytype = '+s' where jytype = :jytype_temp;
		case '0c'
			update a_zdsh_nr set jytype = '6]' where jytype = :jytype_temp;
		case ')d'
			update a_zdsh_nr set jytype = 'D8' where jytype = :jytype_temp;
		case ']d'
			update a_zdsh_nr set jytype = 'D{' where jytype = :jytype_temp;
		case '.c'
			update a_zdsh_nr set jytype = 'D}' where jytype = :jytype_temp;
		case '&e'
			update a_zdsh_nr set jytype = '&d' where jytype = :jytype_temp;
		case '*w'
			update a_zdsh_nr set jytype = '=aw' where jytype = :jytype_temp;
	end choose
	///////////////////////////////////////////////////////////////////////////////////////
	if gs_jydw = '°°É½¸ÖÌú¼¯ÍÅ¹«Ë¾Éú²ú¼à²âÖÐÐÄ' then
		choose case jytype_temp
			case ')c'
				update a_zdsh_nr set jytype = 'Is' where jytype = :jytype_temp;
		end choose
	end if
	if gs_jydw = 'ÁÉÑôÊ¯»¯·Ö¹«Ë¾Éú²ú¼à²â²¿ÈÝÆ÷¼ìÑéËù' then
		choose case jytype_temp
			case ']8'
				update a_zdsh_nr set jytype = ']6' where jytype = :jytype_temp;
		end choose
	end if
	if gs_jydw = 'Î÷°²ÌØÖÖÉè±¸¼ìÑé¼ì²âÔº' then
		choose case jytype_temp
			case '+6'
				update a_zdsh_nr set jytype = ':a2' where jytype = :jytype_temp;
			case '*6'
				update a_zdsh_nr set jytype = 'Qc2' where jytype = :jytype_temp;
			case '<e'
				update a_zdsh_nr set jytype = '*d' where jytype = :jytype_temp;
			case '^e'
				update a_zdsh_nr set jytype = '$d' where jytype = :jytype_temp;
			case '#e'
				update a_zdsh_nr set jytype = '\d' where jytype = :jytype_temp;
			case '/e'
				update a_zdsh_nr set jytype = '/d' where jytype = :jytype_temp;
			case 'Z@'
				update a_zdsh_nr set jytype = 'Z$' where jytype = :jytype_temp;	
			case '0w'
				update a_zdsh_nr set jytype = ':w' where jytype = :jytype_temp;	
		end choose
	end if
FETCH temp_zdsh INTO :jytype_temp;
LOOP
CLOSE temp_zdsh;

DECLARE temp_zdshmc CURSOR FOR
SELECT jytype
FROM a_zdsh_zdmc ORDER BY jytype; 
OPEN temp_zdshmc;
FETCH temp_zdshmc INTO :jytype_temp;
do while sqlca.sqlcode = 0
	if isnull(jytype_temp) then jytype_temp = ''
	choose case jytype_temp	
		case '6c'
			update a_zdsh_zdmc set jytype = '6s' where jytype = '6c';
		case 'Ic'
			select count(*) into :ll_num from a_zdsh_zdmc where jytype = '6c';
			if ll_num = 0 then
				update a_zdsh_zdmc set jytype = '6s' where jytype = 'Ic';
			else
				delete a_zdsh_zdmc where jytype = 'Ic';
				update a_zdsh_zdmc set jytype = '6s' where jytype = '6c';	
			end if
		case 'Kc'
			update a_zdsh_zdmc set jytype = 'Ks' where jytype = :jytype_temp;
		case 'Jc'
			update a_zdsh_zdmc set jytype = 'Js' where jytype = :jytype_temp;
		case 'Id'
			update a_zdsh_zdmc set jytype = '6d' where jytype = :jytype_temp;
		case 'Ip'
			update a_zdsh_zdmc set jytype = '6p' where jytype = :jytype_temp;
		case 'Iu'
			delete a_zdsh_zdmc where jytype = 'Iu';
		case 'Iv'
			update a_zdsh_zdmc set jytype = '6v' where jytype = :jytype_temp;
		case 'Iw'
			update a_zdsh_zdmc set jytype = '6w' where jytype = :jytype_temp;
		case '+c'
			update a_zdsh_zdmc set jytype = '+s' where jytype = :jytype_temp;
		case '0c'
			update a_zdsh_zdmc set jytype = '6]' where jytype = :jytype_temp;
		case ')d'
			update a_zdsh_zdmc set jytype = 'D8' where jytype = :jytype_temp;
		case ']d'
			update a_zdsh_zdmc set jytype = 'D{' where jytype = :jytype_temp;
		case '.c'
			update a_zdsh_zdmc set jytype = 'D}' where jytype = :jytype_temp;
		case '&e'
			update a_zdsh_zdmc set jytype = '&d' where jytype = :jytype_temp;
		case '*w'
			update a_zdsh_zdmc set jytype = '=aw' where jytype = :jytype_temp;
	end choose
	///////////////////////////////////////////////////////////////////////////////////////
	if gs_jydw = '°°É½¸ÖÌú¼¯ÍÅ¹«Ë¾Éú²ú¼à²âÖÐÐÄ' then
		choose case jytype_temp
			case ')c'
				update a_zdsh_zdmc set jytype = 'Is' where jytype = :jytype_temp;
		end choose
	end if
	if gs_jydw = 'ÁÉÑôÊ¯»¯·Ö¹«Ë¾Éú²ú¼à²â²¿ÈÝÆ÷¼ìÑéËù' then
		choose case jytype_temp
			case ']8'
				update a_zdsh_zdmc set jytype = ']6' where jytype = :jytype_temp;
		end choose
	end if
	if gs_jydw = 'Î÷°²ÌØÖÖÉè±¸¼ìÑé¼ì²âÔº' then
		choose case jytype_temp
			case '+6'
				update a_zdsh_zdmc set jytype = ':a2' where jytype = :jytype_temp;
			case '*6'
				update a_zdsh_zdmc set jytype = 'Qc2' where jytype = :jytype_temp;
			case '<e'
				update a_zdsh_zdmc set jytype = '*d' where jytype = :jytype_temp;
			case '^e'
				update a_zdsh_zdmc set jytype = '$d' where jytype = :jytype_temp;
			case '#e'
				update a_zdsh_zdmc set jytype = '\d' where jytype = :jytype_temp;
			case '/e'
				update a_zdsh_zdmc set jytype = '/d' where jytype = :jytype_temp;
			case 'Z@'
				update a_zdsh_zdmc set jytype = 'Z$' where jytype = :jytype_temp;	
			case '0w'
				update a_zdsh_zdmc set jytype = ':w' where jytype = :jytype_temp;	
		end choose
	end if
FETCH temp_zdshmc INTO :jytype_temp;
LOOP
CLOSE temp_zdshmc;
IF sqlca.sqlcode <>0 THEN
	MessageBox ('','×Ô¶¯ÉóºË¸üÐÂÊ§°Ü')
	return
else
	messagebox('ÏµÍ³ÌáÊ¾','×Ô¶¯ÉóºËÍê±Ï£¡¸üÐÂ³ÌÐòÈÔÔÚ½øÐÐ£¬ÇëÄÍÐÄµÈ´ý£¡')
END IF
