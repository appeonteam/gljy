	if isnull(jyday) then jyday = ''
	jydate = mid(ls_jydate,1,4) + mid(ls_jydate,6,2) + mid(ls_jydate,9,2)
	insert into u_addr_bg (bg_id,bg_jytype,bg_qc_addrid,bg_rq,fl) values (:jyid,:jytype,:ls_addrid,:jydate,'qj');
FETCH temp_ryqj INTO :jyid,:jytype,:ls_jydate;
LOOP
CLOSE temp_ryqj;
IF sqlca.sqlcode <>0 THEN
	MessageBox ('','µØÇøÂëÆäËü¼ìÑé±í¸üÐÂÊ§°Ü')
