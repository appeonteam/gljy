/////////////////////////////////////////////////////////////////////////////////////////
string add1mark
select add1mark into :add1mark from a_jydw;  
if add1mark = '1' then
	update z_rw_sb set jymlid = '6',jylbid = 's' where jymlid = 'I' and jylbid = 'c';
	update z_rw_sb set jymlid = '6',jylbid = 's' where jymlid = '6' and jylbid = 'c';	
	update z_rw_sb set jymlid = 'K',jylbid = 's' where jymlid = 'K' and jylbid = 'c';
	update z_rw_sb set jymlid = 'J',jylbid = 's' where jymlid = 'J' and jylbid = 'c';
	update z_rw_sb set jymlid = '6',jylbid = 'd' where jymlid = 'I' and jylbid = 'd';
	update z_rw_sb set jymlid = '6',jylbid = 'p' where jymlid = 'I' and jylbid = 'p';
	update z_rw_sb set jymlid = '6',jylbid = 'u' where jymlid = 'I' and jylbid = 'u';
	update z_rw_sb set jymlid = '6',jylbid = 'v' where jymlid = 'I' and jylbid = 'v';
	update z_rw_sb set jymlid = '6',jylbid = 'w' where jymlid = 'I' and jylbid = 'w';
	update z_rw_sb set jymlid = '+',jylbid = 's' where jymlid = '+' and jylbid = 'c';
	update z_rw_sb set jymlid = '6',jylbid = ']' where jymlid = '0' and jylbid = 'c';
	update z_rw_sb set jymlid = 'D',jylbid = '8' where jymlid = ')' and jylbid = 'd';
	update z_rw_sb set jymlid = 'D',jylbid = '{' where jymlid = ']' and jylbid = 'd';
	update z_rw_sb set jymlid = 'D',jylbid = '}' where jymlid = '.' and jylbid = 'c';
	update z_rw_sb set jymlid = '&',jylbid = 'd' where jymlid = '&' and jylbid = 'd';
	update z_rw_sb set jymlid = '=a',jylbid = 'w' where jymlid = '*' and jylbid = 'w';
	////////////////////////////////////ÒÔÏÂÊÇÎ÷°²///////////////////////////////////////
	if gs_jydw = '°°É½¸ÖÌú¼¯ÍÅ¹«Ë¾Éú²ú¼à²âÖÐÐÄ' then
		choose case jytype_temp
			case ')c'
				update z_rw_sb set jymlid = 'I',jylbid = 's' where jymlid = ')' and jylbid = 'c';
		end choose
	end if
	if gs_jydw = 'ÁÉÑôÊ¯»¯·Ö¹«Ë¾Éú²ú¼à²â²¿ÈÝÆ÷¼ìÑéËù' then
		choose case jytype_temp
			case ']8'
				update z_rw_sb set jymlid = ']',jylbid = '6' where jymlid = ']' and jylbid = '8';
		end choose
	end if
	if gs_jydw = 'Î÷°²ÌØÖÖÉè±¸¼ìÑé¼ì²âÔº' then
				update z_rw_sb set jymlid = ':a',jylbid = '2' where jymlid = '+' and jylbid = '6';
				update z_rw_sb set jymlid = 'Qc',jylbid = '2' where jymlid = '*' and jylbid = '6';
				update z_rw_sb set jymlid = '*',jylbid = 'd' where jymlid = '<' and jylbid = 'e';
				update z_rw_sb set jymlid = '$',jylbid = 'd' where jymlid = '^' and jylbid = 'e';
				update z_rw_sb set jymlid = '\',jylbid = 'd' where jymlid = '#' and jylbid = 'e';
				update z_rw_sb set jymlid = '/',jylbid = 'd' where jymlid = '/' and jylbid = 'e';
				update z_rw_sb set jymlid = 'Z',jylbid = '$' where jymlid = 'Z' and jylbid = '@';	
				update z_rw_sb set jymlid = ':',jylbid = 'w' where jymlid = '0' and jylbid = 'w';	
	end if
	IF sqlca.sqlcode <>0 THEN
		MessageBox ('','µÇ¼ÇÈÎÎñtotal±í¸üÐÂÊ§°Ü')
		return
	else
		messagebox('ÏµÍ³ÌáÊ¾','µÇ¼ÇÈÎÎñtotal±íÉý¼¶Íê±Ï£¡¸üÐÂ³ÌÐòÈÔÔÚ½øÐÐ£¬ÇëÄÍÐÄµÈ´ý£¡')
	END IF
