////////////////////////////////////////////////////////////////////////////////////////////////
string l_jytype
DECLARE a_bgml CURSOR FOR
SELECT id,jytype,lbid
FROM a_bgml;   
OPEN a_bgml;
FETCH a_bgml INTO :id_bgml,:jytype_bgml,:lbid;
do while sqlca.sqlcode = 0
	select count(*) into :ll_num from a_jykey where jytype like :jytype_bgml;
	if ll_num = 0 then
		update a_bgml set mark = :lbid,lbid = '' where id like :id_bgml and jytype like :jytype_bgml;
	else
		if add1mark = '1' then
			if isnull(l_jytype) then l_jytype = ''
			l_jytype = l_jytype + ','
		end if
	end if
FETCH a_bgml INTO :id_bgml,:jytype_bgml,:lbid;
LOOP
CLOSE a_bgml;
update a_jydw set rw = :l_jytype;

end subroutine

