			case '0c'
				update a_cz_bgyy set jymlid = '6',jylbid = ']',jyml = 'Ñ¹Á¦ÈÝÆ÷',jylb = 'ÄÍÑ¹ÊÔÑé' where jymlid = '0' and jylbid = 'c';
			case ')d'
				update a_cz_bgyy set jymlid = 'D',jylbid = '8',jyml = '¹¤Òµ¹øÂ¯',jylb = 'Ë®´¦Àí¼ìÑé' where jymlid = ')' and jylbid = 'd';
			case ']d'
				update a_cz_bgyy set jymlid = 'D',jylbid = '{',jyml = '¹¤Òµ¹øÂ¯',jylb = 'ÔËÐÐË®´¦Àí¼ìÑé' where jymlid = ']' and jylbid = 'd';
			case '.c'
				update a_cz_bgyy set jymlid = 'D',jylbid = '}',jyml = '¹¤Òµ¹øÂ¯',jylb = 'Í£Â¯Ë®´¦Àí¼ìÑé' where jymlid = '.' and jylbid = 'c';
			case '&e'
				update a_cz_bgyy set jymlid = '&',jylbid = 'd',jylb = '°²×°¼à¼ì' where jymlid = '&' and jylbid = 'd';
			case '*w'
				update a_cz_bgyy set jymlid = '=a',jylbid = 'w' where jymlid = '*' and jylbid = 'w';
		end choose
		///////////////////////////////////////////////////////////////////////////////////////
		if gs_jydw = '°°É½¸ÖÌú¼¯ÍÅ¹«Ë¾Éú²ú¼à²âÖÐÐÄ' then
			choose case jytype_temp
				case ')c'
					update a_cz_bgyy set jymlid = 'I',jylbid = 's',jyml = 'Ñ¹Á¦ÈÝÆ÷(1)',jylb = 'È«Ãæ¼ìÑé' where jymlid = ')' and jylbid = 'c';
			end choose
		end if
		if gs_jydw = 'ÁÉÑôÊ¯»¯·Ö¹«Ë¾Éú²ú¼à²â²¿ÈÝÆ÷¼ìÑéËù' then
			choose case jytype_temp
