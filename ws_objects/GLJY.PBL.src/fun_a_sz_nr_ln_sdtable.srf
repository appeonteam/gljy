string jydate,jyyear,jymonth,jyday,ls_jydate
DECLARE temp_rydj CURSOR FOR
SELECT jyid,jytype,jyyear,jymonth,jyday
FROM b_jy_total ORDER BY jyid; 
OPEN temp_rydj;
FETCH temp_rydj INTO :jyid,:jytype,:jyyear,:jymonth,:jyday;
do while sqlca.sqlcode = 0
	if isnull(jydate) then jydate = ''
	if isnull(jyyear) then jyyear = ''
	if isnull(jymonth) then jymonth = ''
	if isnull(jyday) then jyday = ''
	jydate = jyyear + jymonth + jyday
	insert into u_addr_bg (bg_id,bg_jytype,bg_qc_addrid,bg_rq,fl) values (:jyid,:jytype,:ls_addrid,:jydate,'dj');
FETCH temp_rydj INTO :jyid,:jytype,:jyyear,:jymonth,:jyday;
LOOP
CLOSE temp_rydj;
IF sqlca.sqlcode <>0 THEN
	MessageBox ('','µØÇøÂë¶¨ÆÚ¼ìÑé±í¸üÐÂÊ§°Ü')
	return
else
	messagebox('ÏµÍ³ÌáÊ¾','µØÇøÂë¶¨ÆÚ¼ìÑé±íÉý¼¶Íê±Ï£¡¸üÐÂ³ÌÐòÈÔÔÚ½øÐÐ£¬ÇëÄÍÐÄµÈ´ý£¡')
END IF
DECLARE temp_ryaj CURSOR FOR
SELECT jyid,jytype,jyyear,jymonth,jyday
FROM b_aj_total ORDER BY jyid; 
OPEN temp_ryaj;
FETCH temp_ryaj INTO :jyid,:jytype,:jyyear,:jymonth,:jyday;
do while sqlca.sqlcode = 0
	if isnull(jydate) then jydate = ''
	if isnull(jyyear) then jyyear = ''
	if isnull(jymonth) then jymonth = ''
	if isnull(jyday) then jyday = ''
	jydate = jyyear + jymonth + jyday
	insert into u_addr_bg (bg_id,bg_jytype,bg_qc_addrid,bg_rq,fl) values (:jyid,:jytype,:ls_addrid,:jydate,'aj');
FETCH temp_ryaj INTO :jyid,:jytype,:jyyear,:jymonth,:jyday;
LOOP
CLOSE temp_ryaj;
IF sqlca.sqlcode <>0 THEN
	MessageBox ('','µØÇøÂë°²×°¼ìÑé±í¸üÐÂÊ§°Ü')
	return
else
	messagebox('ÏµÍ³ÌáÊ¾','µØÇøÂë°²×°¼ìÑé±íÉý¼¶Íê±Ï£¡¸üÐÂ³ÌÐòÈÔÔÚ½øÐÐ£¬ÇëÄÍÐÄµÈ´ý£¡')
END IF
DECLARE temp_ryjj CURSOR FOR
SELECT jyid,jytype,jydate
FROM b_jj_total ORDER BY jyid; 
OPEN temp_ryjj;
FETCH temp_ryjj INTO :jyid,:jytype,:ls_jydate;
do while sqlca.sqlcode = 0
	if isnull(jydate) then jydate = ''
	if isnull(ls_jydate) then ls_jydate = ''
	jydate = mid(ls_jydate,1,4) + mid(ls_jydate,6,2) + mid(ls_jydate,9,2)
	insert into u_addr_bg (bg_id,bg_jytype,bg_qc_addrid,bg_rq,fl) values (:jyid,:jytype,:ls_addrid,:jydate,'jj');
FETCH temp_ryjj INTO :jyid,:jytype,:ls_jydate;
LOOP
CLOSE temp_ryjj;
IF sqlca.sqlcode <>0 THEN
	MessageBox ('','µØÇøÂëÖÆÔì¼à¼ì±í¸üÐÂÊ§°Ü')
	return
else
	messagebox('ÏµÍ³ÌáÊ¾','µØÇøÂëÖÆÔì¼à¼ì±íÉý¼¶Íê±Ï£¡¸üÐÂ³ÌÐòÈÔÔÚ½øÐÐ£¬ÇëÄÍÐÄµÈ´ý£¡')
END IF
