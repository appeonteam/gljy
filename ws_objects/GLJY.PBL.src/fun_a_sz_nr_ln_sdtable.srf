DECLARE temp_jykey CURSOR FOR
SELECT jytype,ryid
FROM a_jykey where jytype = 'Iu' or jytype = 'Ic';
OPEN temp_jykey;
FETCH temp_jykey INTO :jytype,:ryid;
do while sqlca.sqlcode = 0
	choose case jytype
		case 'Iu'
			select count(*) into :ll_num from a_jykey where ryid like :ryid and jytype = '6u';
			if ll_num = 0 then
				update a_jykey set jytype = '6u' where jytype = 'Iu' and ryid like :ryid;
			else
				delete a_jykey where ryid like :ryid and jytype = 'Iu' and ryid like :ryid;
			end if
		case 'Ic'
			select count(*) into :ll_num from a_jykey where ryid like :ryid and jytype = '6c';
			if ll_num = 0 then
				update a_jykey set jytype = '6s' where jytype = 'Ic' and ryid like :ryid;
			else
				update a_jykey set jytype = '6s' where jytype = '6c' and ryid like :ryid;
				delete a_jykey where ryid like :ryid and jytype = 'Ic' and ryid like :ryid;
			end if
	end choose
FETCH temp_jykey INTO :jytype,:ryid;
LOOP
CLOSE temp_jykey;
update a_jykey set jytype = '6s' where jytype = '6c';
update a_jykey set jytype = 'Ks' where jytype = 'Kc';
update a_jykey set jytype = 'Js' where jytype = 'Jc';
update a_jykey set jytype = '+s' where jytype = '+c';
update a_jykey set jytype = '6]' where jytype = '0c';
update a_jykey set jytype = '6d' where jytype = 'Id';
update a_jykey set jytype = '6p' where jytype = 'Ip';
update a_jykey set jytype = '6v' where jytype = 'Iv';
update a_jykey set jytype = '6w' where jytype = 'Iw';
update a_jykey set jytype = 'D8' where jytype = ')d';
update a_jykey set jytype = 'D{' where jytype = ']d';
update a_jykey set jytype = 'D}' where jytype = '.c';
update a_jykey set jytype = '&d' where jytype = '&e';
update a_jykey set jytype = '=aw' where jytype = '*w';	
///////////////////////////////////////////////////////////////////////////////////////
if gs_jydw = '°°É½¸ÖÌú¼¯ÍÅ¹«Ë¾Éú²ú¼à²âÖÐÐÄ' then
	update a_jykey set jytype = 'Is' where jytype = ')c';
end if
if gs_jydw = 'ÁÉÑôÊ¯»¯·Ö¹«Ë¾Éú²ú¼à²â²¿ÈÝÆ÷¼ìÑéËù' then
	update a_jykey set jytype = ']6' where jytype = ']8';
end if
if gs_jydw = 'Î÷°²ÌØÖÖÉè±¸¼ìÑé¼ì²âÔº' then
	update a_jykey set jytype = ':a2' where jytype = '+6';
	update a_jykey set jytype = 'Qc2' where jytype = '*6';
	update a_jykey set jytype = '*d' where jytype = '<e';
	update a_jykey set jytype = '$d' where jytype = '^e';
	update a_jykey set jytype = '\d' where jytype = '#e';
	update a_jykey set jytype = '/d' where jytype = '/e';
	update a_jykey set jytype = 'Z$' where jytype = 'Z@';	
	update a_jykey set jytype = ':w' where jytype = '0w';	
end if

IF sqlca.sqlcode <>0 THEN
	MessageBox ('','a_jykey¸üÐÂÊ§°Ü')
	return
else
	messagebox('ÏµÍ³ÌáÊ¾','a_jykeyÉý¼¶Íê±Ï£¡¸üÐÂ³ÌÐòÈÔÔÚ½øÐÐ£¬ÇëÄÍÐÄµÈ´ý£¡')
END IF
/////////////////////////////////////¸üÐÂÈËÔ±////////////////////////////////////////			
long ll_NowRow = 0
string ls_TestDj[],ls_NullStr[],ls_TestAj[],ls_TestJj[],ls_TestJk[],ls_TestQj[],jymk,temp_ryid
string ls_NowDjml,ls_NowDjlb,ls_NowAjml,ls_NowAjlb,ls_NowJjml,ls_NowJjlb,ls_NowJkml,ls_NowJklb,ls_NowQjml,ls_NowQjlb
DECLARE temp_rycode CURSOR FOR
SELECT ryid,jytype,jymk
FROM a_jykey order by ryid;
OPEN temp_rycode;
FETCH temp_rycode INTO :ryid,:jytype,:jymk;
do while sqlca.sqlcode = 0
	if isnull(temp_ryid) then temp_ryid = ''
	if temp_ryid <> ryid then
		if temp_ryid = '' then
		else
			ls_NowDjml = fun_getmllb(ls_TestDj,'1')
			ls_NOwDjlb = fun_getmllb(ls_TestDj,'2')
			ls_NowAjml = fun_getmllb(ls_TestAj,'1')
			ls_NowAjlb = fun_getmllb(ls_TestAj,'2')
			ls_NowJjml = fun_getmllb(ls_TestJj,'1')
			ls_NowJjlb = fun_getmllb(ls_TestJj,'2')
			ls_NowJkml = fun_getmllb(ls_TestJk,'1')
			ls_NowJklb = fun_getmllb(ls_TestJk,'2')
			ls_NowQjml = fun_getmllb(ls_TestQj,'1')
			ls_NowQjlb = fun_getmllb(ls_TestQj,'2')
			update a_rycode set rydjml = :ls_NowDjml,rydjlb = :ls_NowDjlb,
									  ryajml = :ls_NowAjml,ryajlb = :ls_NowAjlb,
									  ryjjml = :ls_NowJjml,ryjjlb = :ls_NowJjlb,
									  ryjkml = :ls_NowJkml,ryjklb = :ls_NowJklb,
									  ryqjml = :ls_NowQjml,ryqjlb = :ls_NowQjlb
			where jyid = :temp_ryid;
			setnull(ls_NowDjml)
			setnull(ls_NowDjlb)
			setnull(ls_NowAjml)
			setnull(ls_NowAjlb)
			setnull(ls_NowJjml)
			setnull(ls_NowJjlb)
			setnull(ls_NowJkml)
			setnull(ls_NowJklb)
			setnull(ls_NowQjml)
			setnull(ls_NowQjlb)
			ll_NowRow = 0
		end if
		temp_ryid = ryid
	end if
	ll_NowRow = ll_NowRow + 1
	choose case jymk
		case 'dj'
			ls_TestDj[ll_NowRow] = jytype
		case 'aj'
			ls_TestAj[ll_NowRow] = jytype
		case 'jj'
			ls_TestJj[ll_NowRow] = jytype
		case 'jk'
			ls_TestJk[ll_NowRow] = jytype
		case 'qj'
			ls_TestQj[ll_NowRow] = jytype		
	end choose
FETCH temp_rycode INTO :ryid,:jytype,:jymk;
LOOP
CLOSE temp_rycode;	
IF sqlca.sqlcode <>0 THEN
	MessageBox ('','a_rycode¸üÐÂÊ§°Ü')
	return
else
	messagebox('ÏµÍ³ÌáÊ¾','a_rycodeÉý¼¶Íê±Ï£¡¸üÐÂ³ÌÐòÈÔÔÚ½øÐÐ£¬ÇëÄÍÐÄµÈ´ý£¡')
END IF
///////////////////////////////////////////////////////////////////////////////////////////////////
////ÒÔÏÂÊÇµØÇøÂë±íÌî³ä
///////////////////////////////////////////¸üÐÂ²¿ÃÅ///////////////////////////////////
string sbsfdm,sbdsdm,ls_addrid
string ls_sheng,ls_shi,ls_quxian
string bmid_max,bmid_min
long bmid_minid,bmid_maxid,i

select sbsfdm,sbdsdm into :sbsfdm,:sbdsdm from a_jydw;
ls_sheng = left(sbsfdm,2)
ls_shi = mid(sbdsdm,3,2)
ls_quxian = '01'
ls_addrid = ls_sheng + ls_shi + ls_quxian

select max(bmid),min(bmid) into :bmid_max,:bmid_min from a_bmcode;
bmid_minid = long(bmid_min)
bmid_maxid = long(bmid_max)
for i = bmid_minid to bmid_maxid
	 update a_bmcode set addrid = :ls_addrid,addrbg = '0';
next
