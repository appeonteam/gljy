			end choose
		end if
		if gs_jydw = 'Î÷°²ÌØÖÖÉè±¸¼ìÑé¼ì²âÔº' then
			choose case jytype_temp
				case '+6'
					update a_cz_bgyy set jymlid = ':a',jylbid = '2',jylb = '¼ìÑé±¨¸æ' where jymlid = '+' and jylbid = '6';
				case '*6'
					update a_cz_bgyy set jymlid = 'Qc',jylbid = '2',jylb = '¼ìÑé±¨¸æ' where jymlid = '*' and jylbid = '6';
				case '<e'
