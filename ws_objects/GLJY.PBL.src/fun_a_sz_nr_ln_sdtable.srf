update sjzdn_bglb set mc = 'ÇÅ(ÃÅ)Ê½ÆðÖØ»úÑéÊÕ¼ìÑé' where mc = 'ÇÅÆðÖØ»úÑéÊÕ¼ìÑé';
update sjzdn_bglb set mc = 'ÃÅ×ùÊ½ÆðÖØ»ú¶¨ÆÚ¼ìÑé' where mc = 'ÃÅÆðÖØ»ú¶¨ÆÚ¼ìÑé';
