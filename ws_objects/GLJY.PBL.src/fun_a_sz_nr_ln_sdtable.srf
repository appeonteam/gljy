				case '/e'
					update a_cz_bgyy set jymlid = '/',jylbid = 'd',jylb = '°²×°¼à¼ì' where jymlid = '/' and jylbid = 'e';
				case 'Z@'
					update a_cz_bgyy set jymlid = 'Z',jylbid = '$' where jymlid = 'Z' and jylbid = '@';	
				case '0w'
					update a_cz_bgyy set jymlid = ':',jylbid = 'w' where jymlid = '0' and jylbid = 'w';	
