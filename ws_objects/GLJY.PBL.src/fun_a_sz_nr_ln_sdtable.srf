/////////////////////////////////u_addr_staff,a_dqm_init///////////////////////////////////
string ls_addrname
string sbsf,sbds
string ryjyjb
select sbsf,sbds into :sbsf,:sbds from a_jydw;
ls_addrname = sbsf + sbds + 'ÊÐÏ½Çø'
DECLARE u_addr_staff CURSOR FOR
SELECT ryid,ryjyjb
FROM a_rycode where ryid <> '1111' ORDER BY ryid; 
OPEN u_addr_staff;
FETCH u_addr_staff INTO :ryid,:ryjyjb;
do while sqlca.sqlcode = 0
	insert into u_addr_staff values (:ryid,:ls_addrid,:ls_addrname);
	if ryjyjb > '2' then
		insert into a_dqm_init values (:ryid,:ls_addrid,:ls_addrname,'3');
	end if
	FETCH u_addr_staff INTO :ryid,:ryjyjb;
LOOP
CLOSE u_addr_staff;
IF sqlca.sqlcode <>0 THEN
	MessageBox ('','µØÇøÂëÈËÔ±u_addr_staff¼°a_dqm_init¸üÐÂÊ§°Ü')
	return
else
	messagebox('ÏµÍ³ÌáÊ¾','µØÇøÂëÈËÔ±u_addr_staff¼°a_dqm_initÉý¼¶Íê±Ï£¡¸üÐÂ³ÌÐòÈÔÔÚ½øÐÐ£¬ÇëÄÍÐÄµÈ´ý£¡')
END IF
////////////////////////////////////////////////////////////////////////////////////////////

DECLARE a_ry_dqm CURSOR FOR
SELECT ryid,jytype
FROM a_jykey order by ryid;
OPEN a_ry_dqm;
FETCH a_ry_dqm INTO :ryid,:jytype;
do while sqlca.sqlcode = 0
select ryid into :ryid_str from a_rycode where jyid like :ryid and ryjyjb > '2';
if isnull(ryid_str) or ryid_str = '' then
else
	select max(id) into :l_id from a_ry_dqm;
	if isnull(l_id) or l_id = '' then
		l_id = '1000000001'
	else
		l_id = string(dec(l_id) + 1)
	end if
	select typename into :typename from a_bgml where jytype like :jytype;
	insert into a_ry_dqm values (:l_id,:ryid_str,:jytype,:typename,:ryid,:ls_addrid,:ls_addrname,'3');
end if
FETCH a_ry_dqm INTO :ryid,:jytype;
LOOP
CLOSE a_ry_dqm;		
IF sqlca.sqlcode <>0 THEN
	MessageBox ('','µØÇøÂëÉóºË±¨¸æÀà±ða_ry_dqm¸üÐÂÊ§°Ü')
	return
else
	messagebox('ÏµÍ³ÌáÊ¾','µØÇøÂëÉóºË±¨¸æÀà±ða_ry_dqmÉý¼¶Íê±Ï£¡¸üÐÂ³ÌÐòÈÔÔÚ½øÐÐ£¬ÇëÄÍÐÄµÈ´ý£¡')
END IF
