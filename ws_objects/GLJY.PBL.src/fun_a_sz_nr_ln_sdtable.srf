global subroutine fun_a_sz_nr_ln_sdtable ();long ls_count = 0
string mysql,delsql,myindex,modsql
// Ê×ÏÈÅÐ¶ÏÏµÍ³Îªsqlserver°æ»¹ÊÇsybase°æ
string mark = 'sybase'
if sqlca.dbms="MSS (Msoft) SQL Server 6.0" then mark = 'sqlserver'
string typename,lbid,sh
string ll_jymlid,ll_jylbid,jytype_temp
///////////////////////////////////////////¸üÐÂ±¨¸æ±àºÅ///////////////////////////////////////////
messagebox('','¿ªÊ¼ÇåÀíÊý¾Ý£¬ÇëÄÍÐÄµÈ´ý')
long ll_num
string jytype,ryid
string id_bgml,jytype_bgml
string ryid_str,l_id

DECLARE temp_bgbh CURSOR FOR
SELECT jymlid,jylbid
FROM a_bgbh ORDER BY jymlid; 
OPEN temp_bgbh;
FETCH temp_bgbh INTO :ll_jymlid,:ll_jylbid;
do while sqlca.sqlcode = 0
	if isnull(ll_jymlid) then ll_jymlid = ''
	if isnull(ll_jylbid) then ll_jylbid = ''
	jytype_temp = ll_jymlid + ll_jylbid
	select typename,lbid,sh into :typename,:lbid,:sh from view_bgml_total where jytype like :jytype_temp;
	update a_bgbh set typename = :typename,lbid = :lbid,sh = :sh where jymlid = :ll_jymlid and jylbid = :ll_jylbid;
	choose case jytype_temp
		case '6c'
			update a_bgbh set jymlid = '6',jylbid = 's' where jymlid = '6' and jylbid = 'c';
		case 'Ic'
			select count(*) into :ll_num from a_bgbh where jymlid = '6' and jylbid = 'c';
			if ll_num = 0 then
				update a_bgbh set jymlid = '6',jylbid = 's' where jymlid = 'I' and jylbid = 'c';
			else
				update a_bgbh set jymlid = '6',jylbid = 's' where jymlid = '6' and jylbid = 'c';
				delete a_bgbh where jymlid = 'I' and jylbid = 'c';
			end if
		case 'Kc'
			update a_bgbh set jymlid = 'K',jylbid = 's' where jymlid = 'K' and jylbid = 'c';
		case 'Jc'
			update a_bgbh set jymlid = 'J',jylbid = 's' where jymlid = 'J' and jylbid = 'c';
		case 'Id'
			update a_bgbh set jymlid = '6',jylbid = 'd' where jymlid = 'I' and jylbid = 'd';
		case 'Ip'
			update a_bgbh set jymlid = '6',jylbid = 'p' where jymlid = 'I' and jylbid = 'p';
		case 'Iu'
			select count(*) into :ll_num from a_bgbh where jymlid = '6' and jylbid = 'u';
			if ll_num = 0 then
				update a_bgbh set jymlid = '6',jylbid = 'u' where jymlid = 'I' and jylbid = 'u';
			else
				delete a_bgbh where jymlid = 'I' and jylbid = 'u';
			end if
		case 'Iv'
			update a_bgbh set jymlid = '6',jylbid = 'v' where jymlid = 'I' and jylbid = 'v';
		case 'Iw'
			update a_bgbh set jymlid = '6',jylbid = 'w' where jymlid = 'I' and jylbid = 'w';
		case '+c'
			update a_bgbh set jymlid = '+',jylbid = 's' where jymlid = '+' and jylbid = 'c';
		case '0c'
			update a_bgbh set jymlid = '6',jylbid = ']' where jymlid = '0' and jylbid = 'c';
		case ')d'
			update a_bgbh set jymlid = 'D',jylbid = '8' where jymlid = ')' and jylbid = 'd';
		case ']d'
			update a_bgbh set jymlid = 'D',jylbid = '{' where jymlid = ']' and jylbid = 'd';
		case '.c'
			update a_bgbh set jymlid = 'D',jylbid = '}' where jymlid = '.' and jylbid = 'c';
		case '&e'
			update a_bgbh set jymlid = '&',jylbid = 'd' where jymlid = '&' and jylbid = 'd';
		case '*w'
			update a_bgbh set jymlid = '=a',jylbid = 'w' where jymlid = '*' and jylbid = 'w';
	end choose
	///////////////////////////////////////////////////////////////////////////////////////
	if gs_jydw = '°°É½¸ÖÌú¼¯ÍÅ¹«Ë¾Éú²ú¼à²âÖÐÐÄ' then
		choose case jytype_temp
			case ')c'
				update a_bgbh set jymlid = 'I',jylbid = 's' where jymlid = ')' and jylbid = 'c';
		end choose
	end if
	if gs_jydw = 'ÁÉÑôÊ¯»¯·Ö¹«Ë¾Éú²ú¼à²â²¿ÈÝÆ÷¼ìÑéËù' then
		choose case jytype_temp
			case ']8'
				update a_bgbh set jymlid = ']',jylbid = '6' where jymlid = ']' and jylbid = '8';
		end choose
	end if
	if gs_jydw = 'Î÷°²ÌØÖÖÉè±¸¼ìÑé¼ì²âÔº' then
		choose case jytype_temp
			case '+6'
				update a_bgbh set jymlid = ':a',jylbid = '2' where jymlid = '+' and jylbid = '6';
			case '*6'
				update a_bgbh set jymlid = 'Qc',jylbid = '2' where jymlid = '*' and jylbid = '6';
			case '<e'
				update a_bgbh set jymlid = '*',jylbid = 'd' where jymlid = '<' and jylbid = 'e';
			case '^e'
				update a_bgbh set jymlid = '$',jylbid = 'd' where jymlid = '^' and jylbid = 'e';
			case '#e'
				update a_bgbh set jymlid = '\',jylbid = 'd' where jymlid = '#' and jylbid = 'e';
			case '/e'
				update a_bgbh set jymlid = '/',jylbid = 'd' where jymlid = '/' and jylbid = 'e';
			case 'Z@'
				update a_bgbh set jymlid = 'Z',jylbid = '$' where jymlid = 'Z' and jylbid = '@';	
			case '0w'
				update a_bgbh set jymlid = ':',jylbid = 'w' where jymlid = '0' and jylbid = 'w';	
		end choose
	end if
FETCH temp_bgbh INTO :ll_jymlid,:ll_jylbid;
LOOP
CLOSE temp_bgbh;
IF sqlca.sqlcode <>0 THEN
	MessageBox ('','±¨¸æ±àºÅ¸üÐÂÊ§°Ü')
	return
else
	messagebox('ÏµÍ³ÌáÊ¾','±¨¸æ±àºÅÉý¼¶Íê±Ï£¡¸üÐÂ³ÌÐòÈÔÔÚ½øÐÐ£¬ÇëÄÍÐÄµÈ´ý£¡')
END IF
