		myindex = "CREATE UNIQUE INDEX b_sbxx_yc_delete_x ON djylrq.b_sbxx_yc_delete (zcbh);"
		execute immediate :delsql using sqlca;
else
	mysql = "CREATE TABLE b_sbxx_yc_delete (zcbh char (20) NOT NULL ,sbmc char (20) NULL ,cqdw char (60) NULL ,sydw char (60) NULL ,"+&
	"ssqx char (48) NULL ,sydd char (60) NULL ,lxr char (14) NULL ,lxfs char (26) NULL ,jylb char (12) NULL ,sbdate char (20) NULL ,"+&
	"yjdate char (20) NULL ,sjdate char (20) NULL ,jyy_1 char (14) NULL ,jyy_2 char (14) NULL ,"+&
	"ycqk char (20) NULL ,sb char (1) NULL ,sc char (1) NULL ,xz char (2) NULL,mark varchar(5) NULL,PRIMARY KEY (zcbh));"
		execute immediate :mysql using sqlca;
end if

