	modsql = "alter table djylrq.z_cw_sjd add fph varchar(30) NULL;"
	execute immediate :modsql using sqlca;
	modsql = "alter table djylrq.z_cw_sjd add sydw varchar(60) NULL;"
	execute immediate :modsql using sqlca;
else
	modsql = "alter table z_rw_sb_temp add je varchar(10) NULL;"
	execute immediate :modsql using sqlca;
	modsql = "alter table z_rw_sb add mx varchar(200) NULL;"
	execute immediate :modsql using sqlca;
	modsql = "alter table z_cw_sjd add zfsj varchar(10) NULL;"
	execute immediate :modsql using sqlca;
	modsql = "alter table z_cw_sjd add fph varchar(30) NULL;"
	execute immediate :modsql using sqlca;
	modsql = "alter table z_cw_sjd add sydw varchar(60) NULL;"
	execute immediate :modsql using sqlca;
end if


//Éè±¸Ô¤¾¯
if mark = 'sqlserver' then 
   delsql = "drop view djylrq.view_sb_yjsb_total"
	execute immediate :delsql using sqlca;
	mysql = "CREATE view djylrq.view_sb_yjsb_total (cpid,sydw,djid,sbmc,zcid,jyid,jytype,jydate,nextdate,lbid ) AS SELECT "+&
	        "glc_tzsb.cpid,glc_tzsb.sydw, glc_tzsb.djid,glc_tzsb.sbmc,glc_tzsb.zcid,b_jy_total.jyid,b_jy_total.jytype,"+& 
	        "b_jy_total.jydate,nextyear + '-' + nextmonth + '-' + nextday,a_bgml.lbid FROM b_jy_total,glc_tzsb,a_bgml "+& 
			  "WHERE ( b_jy_total.cpid = glc_tzsb.cpid and b_jy_total.jytype = a_bgml.jytype and "+&
			  "( a_bgml.lbid like 'dt%' or a_bgml.lbid like 'qzj%' or a_bgml.lbid like 'cc%' or a_bgml.lbid like 'sd%' or a_bgml.lbid like 'yl%')) union SELECT glc_ylrq.cpid,"+&
			  "glc_ylrq.sydw,glc_ylrq.djid,glc_ylrq.rqmc,glc_ylrq.zcid,b_jy_total.jyid,b_jy_total.jytype,"+&
			  "b_jy_total.jydate,nextyear + '-' + nextmonth + '-' + nextday,a_bgml.lbid FROM b_jy_total,glc_ylrq,a_bgml "+& 
			  "WHERE ( b_jy_total.cpid = glc_ylrq.cpid and b_jy_total.jytype = a_bgml.jytype and a_bgml.lbid like 'rq%' ) union SELECT glc_gg.cpid,"+&
			   "glc_gg.sydw,glc_gg.djid,glc_gg.sbflmc,glc_gg.zcid,b_jy_total.jyid,b_jy_total.jytype,"+&
			  "b_jy_total.jydate,nextyear + '-' + nextmonth + '-' + nextday,a_bgml.lbid FROM b_jy_total,glc_gg,a_bgml "+& 
			  "WHERE ( b_jy_total.cpid = glc_gg.cpid and b_jy_total.jytype = a_bgml.jytype and (b_jy_total.jytype like 'D%' or b_jy_total.jytype like 'F%') ) union SELECT glc_dzgl.cpid,"+&
			   "glc_dzgl.sydw,glc_dzgl.djid,glc_dzgl.sbflmc,glc_dzgl.zcid,b_jy_total.jyid,b_jy_total.jytype,"+&
			  "b_jy_total.jydate,nextyear + '-' + nextmonth + '-' + nextday,a_bgml.lbid FROM b_jy_total,glc_dzgl,a_bgml "+& 
			  "WHERE ( b_jy_total.cpid = glc_dzgl.cpid and b_jy_total.jytype = a_bgml.jytype and b_jy_total.jytype like 'A%' ) union SELECT glc_gygd.cpid,"+&
			   "glc_gygd.sydw,glc_gygd.djid,glc_gygd.gdmc,glc_gygd.zcid,b_jy_total.jyid,b_jy_total.jytype,"+&
			  "b_jy_total.jydate,nextyear + '-' + nextmonth + '-' + nextday,a_bgml.lbid FROM b_jy_total,glc_gygd,a_bgml "+& 
			  "WHERE ( b_jy_total.cpid = glc_gygd.cpid and b_jy_total.jytype = a_bgml.jytype and a_bgml.lbid like 'gd%' ) "
	execute immediate :mysql using sqlca;
else 
	delsql = "drop view view_sb_yjsb_total"
	execute immediate :delsql using sqlca;
	mysql = "create view view_sb_yjsb_total (cpid,sydw,djid,sbmc,zcid,jyid,jytype,jydate,nextdate ) AS SELECT "+&
	        "glc_tzsb.cpid,glc_tzsb.sydw, glc_tzsb.djid,glc_tzsb.sbmc,glc_tzsb.zcid,b_jy_total.jyid,b_jy_total.jytype,"+& 
	        "b_jy_total.jydate,nextyear + '-' + nextmonth + '-' + nextday FROM b_jy_total,glc_tzsb WHERE ( b_jy_total.cpid = glc_tzsb.cpid ) "
	execute immediate :mysql using sqlca;
end if


   
           
             




   
           
             


end subroutine

