//CREATE VIEW djylrq.view_jcgl_ylgd ( zcid, sjdw, azdw, tyrq, gdmc, gdlb, gdjb, gdbh, gdzd, dgcd, gdcl, sjyl, sjwd, ssjz, zggzyl, zggzwd, fffs, gczzmc, sbsydw, sbsf, sbds, sbqx, sydwdz, aqglbm, aqglry, zgbmlxdh, sydwyb, sbzcdm, sbmc, sblb, sbzl, sbjb, sbpz, sbxh, ccbh, qydm, sbdm,sbflmc,aqglrydh, GDQD,GD_ZDGCZJ, GD_ZDBH,GDPSFS) as SELECT djylrq.DJB_YLGD.ZCID, djylrq.DJB_YLGD.SJDW, djylrq.DJB_YLGD.AZDW, djylrq.DJB_YLGD.TYRQ, djylrq.DJB_YLGD.GDMC, djylrq.DJB_YLGD.GDLB, djylrq.DJB_YLGD.GDJB, djylrq.DJB_YLGD.GDBH, djylrq.DJB_YLGD.GDZD, djylrq.DJB_YLGD.DGCD, djylrq.DJB_YLGD.GDCL, djylrq.DJB_YLGD.SJYL, djylrq.DJB_YLGD.SJWD, djylrq.DJB_YLGD.SSJZ, djylrq.DJB_YLGD.ZGGZYL, djylrq.DJB_YLGD.ZGGZWD, djylrq.DJB_YLGD.FFFS,djylrq.DJB_YLGD_HZB.GCZZMC, djylrq.DJB_YLGD_HZB.SBSYDW, djylrq.DJB_YLGD_HZB.SBSF, djylrq.DJB_YLGD_HZB.SBDS, djylrq.DJB_YLGD_HZB.SBQX, djylrq.DJB_YLGD_HZB.SYDWDZ, djylrq.DJB_YLGD_HZB.AQGLBM, djylrq.DJB_YLGD_HZB.AQGLRY, djylrq.DJB_YLGD_HZB.ZGBMLXDH, djylrq.DJB_YLGD_HZB.SYDWYB, djylrq.SB_TOTAL.SBZCDM, djylrq.SB_TOTAL.SBMC, djylrq.SB_TOTAL.SBLB, djylrq.SB_TOTAL.SBZL, djylrq.SB_TOTAL.SBJB, djylrq.SB_TOTAL.SBPZ, djylrq.SB_TOTAL.SBXH, djylrq.SB_TOTAL.CCBH, djylrq.SB_TOTAL.QYDM, djylrq.SB_TOTAL.SBDM, djylrq.view_jcgl_sbfl.sbflmc, djylrq.DJB_YLGD_HZB.AQGLRYDH, djylrq.DJB_YLGD.GD_ZDGCZJ, djylrq.DJB_YLGD.GD_ZDBH,djb_ylgd.GDPSFS FROM djylrq.DJB_YLGD INNER JOIN djylrq.DJB_YLGD_HZB ON djylrq.DJB_YLGD.ZCID = djylrq.DJB_YLGD_HZB.ZCID INNER JOIN djylrq.SB_TOTAL ON djylrq.DJB_YLGD_HZB.ZCID = djylrq.SB_TOTAL.ZCID INNER JOIN djylrq.view_jcgl_sbfl ON djylrq.SB_TOTAL.SBPZ = djylrq.view_jcgl_sbfl.sbpz WHERE (djylrq.SB_TOTAL.SBSYZT <> '20');
