if mark = 'sqlserver' then 
   delsql = "drop view djylrq.view_jcgl_dzgl"
	execute immediate :delsql using sqlca;
	mysql = "CREATE view djylrq.view_jcgl_dzgl ( zcid, sbzcdb, zdlxzfl, gtgzyl, grqckyl, gswd, grqckwd, sxhfs, bgsclfs, dwnbbh, glxh, gllb, zzdw, zzrq, anzdw, anzjgrq, tyrq, syzh, sbzcdm, sbmc, sblb, sbzl, sydw, sbpz, sbxh, zzdw_a, qydm, sbdm, sbsf, sbds, sbqx, frdb1, sydwdz, dwyzbm, aqglbm ,sydwlxdh,sbflmc,zgfzr,fzrdh,rrfs,rrzl,ccbg) AS SELECT djb_gl_dzgl.zcid, djb_gl_dzgl.sbzcdb, djb_gl_dzgl.zdlxzfl, djb_gl_dzgl.gtgzyl, djb_gl_dzgl.grqckyl, djb_gl_dzgl.gswd, djb_gl_dzgl.grqckwd, djb_gl_dzgl.sxhfs, djb_gl_dzgl.bgsclfs, djb_gl.dwnbbh, djb_gl.glxh, djb_gl.gllb, djb_gl.zzdw, djb_gl.zzrq, djb_gl.anzdw, djb_gl.anzjgrq, djb_gl.tyrq, sb_syz.syzh, sb_total.lssbzcdm, sb_total.sbmc, sb_total.sblb, sb_total.sbzl, sb_total.sydw, sb_total.sbpz, sb_total.sbxh, sb_total.zzdw, sb_total.qydm, sb_total.sbdm, sb_sydw.sbsf, sb_sydw.sbds, sb_sydw.sbqx, sb_sydw.frdb1, sb_sydw.sydwdz, sb_sydw.dwyzbm, sb_sydw.aqglbm, sb_sydw.sydwlxdh,view_jcgl_sbfl.sbflmc, SB_SYDW.ZGFZR, SB_SYDW.FZRDH,DJB_GL.RRFS, DJB_GL.RRZL,DJB_GL.CCBG FROM {oj sb_total LEFT OUTER JOIN sb_syz ON sb_total.zcid = sb_syz.zcid},djb_gl,djb_gl_dzgl,sb_sydw,view_jcgl_sbfl  WHERE ( sb_total.zcid = djb_gl.zcid ) and ( sb_total.zcid = djb_gl_dzgl.zcid ) and ( sb_total.zcid = sb_sydw.zcid ) and (sb_total.sbpz = view_jcgl_sbfl.sbpz) "// and (sb_total.sbsyzt <> '20')
