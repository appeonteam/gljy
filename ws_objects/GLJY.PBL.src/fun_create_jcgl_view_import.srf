if mark = 'sqlserver' then
	delsql = "drop view djylrq.view_map_sbsl"
	execute immediate :delsql using sqlca;
	mysql = "create view djylrq.view_map_sbsl(xzid,xzmc,gl,ylrq,dt,qzj,cc,ylss,ylgd,kysd,bs,jd,wd) as "+&
			"	select xzid,xzmc,  (case bs when 0 then (select count(*) from view_map_total where substring(qydm,1,2) = '"+ left(qydm,2) + "' and sblb = '1000') when "+&
			"		1 then (select count(*) from view_map_total where substring(qydm,1,4) = substring(xzid,1,4) and sblb = '1000') when "+&
			"		2 then (select  count(*) from view_map_total where qydm = xzid and sblb = '1000') else "+&
			"		(select count(*) from view_map_total where dwid = xzid and sblb = '1000') end),"+&
			"	(case bs when 0 then 	"+&
			"		(select count(*) from view_map_total where substring(qydm,1,2) = '"+ left(qydm,2) + "' and substring(sbzl,1,2) <> '23' and sblb = '2000')  "+&
			"	when 1 then (select count(*) from view_map_total where substring(qydm,1,4) = substring(xzid,1,4) and substring(sbzl,1,2) <> '23' and sblb = '2000') "+&
			"	when 2 then (select  count(*) from view_map_total where qydm = xzid and substring(sbzl,1,2) <> '23' and sblb = '2000') "+&
			"	else (select count(*) from view_map_total where dwid = xzid and substring(sbzl,1,2) <> '23' and sblb = '2000') end),"+&
			"	(case bs when 0 then (select count(*) from view_map_total where substring(qydm,1,2) = '"+ left(qydm,2) + "' and sblb = '3000') when "+&
			"		1 then (select count(*) from view_map_total where substring(qydm,1,4) = substring(xzid,1,4) and sblb = '3000') when "+&
			"		2 then (select  count(*) from view_map_total where qydm = xzid and sblb = '3000') else "+&
			"		(select count(*) from view_map_total where dwid = xzid and sblb = '3000') end),"+&
			"	(case bs when 0 then (select count(*) from view_map_total where substring(qydm,1,2) = '"+ left(qydm,2) + "' and sblb = '4000') when "+&
			"		1 then (select count(*) from view_map_total where substring(qydm,1,4) = substring(xzid,1,4) and sblb = '4000') when "+&
			"		2 then (select  count(*) from view_map_total where qydm = xzid and sblb = '4000') else "+&
			"		(select count(*) from view_map_total where dwid = xzid and sblb = '4000') end),"+&
			"	(case bs when 0 then (select count(*) from view_map_total where substring(qydm,1,2) = '"+ left(qydm,2) + "' and sblb = '5000') when "+&
			"		1 then (select count(*) from view_map_total where substring(qydm,1,4) = substring(xzid,1,4) and sblb = '5000') when "+&
			"		2 then (select  count(*) from view_map_total where qydm = xzid and sblb = '5000') else "+&
			"		(select count(*) from view_map_total where dwid = xzid and sblb = '5000') end),"+&
			"	(case bs when 0 then (select count(*) from view_map_total where substring(qydm,1,2) = '"+ left(qydm,2) + "' and sblb = '6000') when "+&
			"		1 then (select count(*) from view_map_total where substring(qydm,1,4) = substring(xzid,1,4) and sblb = '6000') when "+&
			"		2 then (select  count(*) from view_map_total where qydm = xzid and sblb = '6000') else "+&
			"		(select count(*) from view_map_total where dwid = xzid and sblb = '6000') end),	"+&
			"	(case bs when 0 then (select sum(convert(decimal,dgcd)) from view_map_total where substring(qydm,1,2) = '"+ left(qydm,2) + "' and sblb = '8000') when "+&
			"		1 then (select sum(convert(decimal,dgcd)) from view_map_total where substring(qydm,1,4) = substring(xzid,1,4) and sblb = '8000') when "+&
			"		2 then (select  sum(convert(decimal,dgcd)) from view_map_total where qydm = xzid and sblb = '8000') else "+&
			"		(select sum(convert(decimal,dgcd)) from view_map_total where dwid = xzid and sblb = '8000') end),"+&
			"	(case bs when 0 then (select count(*) from view_map_total where substring(qydm,1,2) = '"+ left(qydm,2) + "' and sblb = '9000') when "+&
			"		1 then (select count(*) from view_map_total where substring(qydm,1,4) = substring(xzid,1,4) and sblb = '9000') when "+&
			"		2 then (select  count(*) from view_map_total where qydm = xzid and sblb = '9000') else "+&
			"		(select count(*) from view_map_total where dwid = xzid and sblb = '9000') end)	"+&
			"	,bs,jd,wd    from view_map_temp"
	execute immediate :mysql using sqlca;
else 
	delsql = "drop view view_map_sbsl"
