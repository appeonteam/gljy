//½«z_sbfl²¢³ÉÒ»ÁÐ
if mark = 'sqlserver' then 
   delsql = "drop view djylrq.view_jcgl_sbfl"
	execute immediate :delsql using sqlca;
	mysql = "CREATE view djylrq.view_jcgl_sbfl ( sbpz,sbflmc,qcml ) AS SELECT sbpz,lb,qcml from z_sbfl where substring(sbpz,2,3) = '000' union select sbpz,zl,qcml from z_sbfl where substring(sbpz,3,2) = '00' and substring(sbpz,2,3) <> '000' union select sbpz,zl,qcml from z_sbfl where substring(sbpz,1,1) = '5' and substring(sbpz,3,2) <> '00' and substring(sbpz,2,3) <> '000' union select sbpz,pz,qcml from z_sbfl where substring(sbpz,1,1) <> '5' and substring(sbpz,3,2) <> '00' and substring(sbpz,2,3) <> '000' "
	execute immediate :mysql using sqlca;
else 
	delsql = "drop view view_jcgl_sbfl"
	execute immediate :delsql using sqlca;
	mysql = "create view view_jcgl_sbfl ( sbpz,sbflmc,qcml ) AS SELECT sbpz,lb,qcml from z_sbfl where substring(sbpz,2,3) = '000' union select sbpz,zl,qcml from z_sbfl where substring(sbpz,3,2) = '00' and substring(sbpz,2,3) <> '000' union select sbpz,zl,qcml from z_sbfl where substring(sbpz,1,1) = '5' and substring(sbpz,3,2) <> '00' and substring(sbpz,2,3) <> '000' union select sbpz,pz,qcml from z_sbfl where substring(sbpz,1,1) <> '5' and substring(sbpz,3,2) <> '00' and substring(sbpz,2,3) <> '000' "
	execute immediate :mysql using sqlca;
end if

//µ¼¹øÂ¯Êý¾ÝÊÓÍ¼
if mark = 'sqlserver' then 
   delsql = "drop view djylrq.view_jcgl_gl"
	execute immediate :delsql using sqlca;
	mysql = "CREATE view djylrq.view_jcgl_gl ( dwnbbh, glszdd, ddlxdh, glxh, gllb, zzdw, zzrq, ccbg, tyrq, sjgzyl, xksyyl, edcl, rrzl, glyt, jzckwd, sclfs, zcid, sbzcdm, sbmc, sblb, sbzl, sbpz, sydw, sbxh, ccbh, qydm, sbdm, sydwdz, dwyzbm, sbsf, sbds, sbqx, frdb1, sydwlxdh, zgfzr, fzrdh, aqglbm, aqglry, aqglbmdh, syzh ,sbflmc) AS SELECT djb_gl.dwnbbh, djb_gl.glszdd, djb_gl.ddlxdh, djb_gl.glxh, djb_gl.gllb, djb_gl.zzdw, djb_gl.zzrq, djb_gl.ccbg, djb_gl.tyrq, djb_gl.sjgzyl, djb_gl.xksyyl, djb_gl.edcl, djb_gl.rrzl, djb_gl.glyt, djb_gl.jzckwd, djb_gl.sclfs, djb_gl.zcid, sb_total.lssbzcdm, sb_total.sbmc, sb_total.sblb, sb_total.sbzl, sb_total.sbpz, sb_total.sydw, sb_total.sbxh, sb_total.ccbh, sb_total.qydm, sb_total.sbdm, sb_sydw.sydwdz, sb_sydw.dwyzbm, sb_sydw.sbsf, sb_sydw.sbds, sb_sydw.sbqx, sb_sydw.frdb1, sb_sydw.sydwlxdh, sb_sydw.zgfzr, sb_sydw.fzrdh, sb_sydw.aqglbm, sb_sydw.aqglry, sb_sydw.aqglbmdh, sb_syz.syzh,view_jcgl_sbfl.sbflmc FROM {oj sb_total LEFT OUTER JOIN sb_syz ON sb_total.zcid = sb_syz.zcid},djb_gl,sb_sydw,view_jcgl_sbfl WHERE ( sb_total.zcid = sb_sydw.zcid ) and ( sb_total.zcid = djb_gl.zcid ) and (sb_total.sbpz = view_jcgl_sbfl.sbpz) "//  and (sb_total.sbsyzt <> '20')sbzcdm¸Ä³Élssbzcdm
   execute immediate :mysql using sqlca;
else 
	delsql = "drop view view_jcgl_gl"
	execute immediate :delsql using sqlca;
	mysql = "create view view_jcgl_gl ( dwnbbh, glszdd, ddlxdh, glxh, gllb, zzdw, zzrq, ccbg, tyrq, sjgzyl, xksyyl, edcl, rrzl, glyt, jzckwd, sclfs, zcid, sbzcdm, sbmc, sblb, sbzl, sbpz, sydw, sbxh, ccbh, qydm, sbdm, sydwdz, dwyzbm, sbsf, sbds, sbqx, frdb1, sydwlxdh, zgfzr, fzrdh, aqglbm, aqglry, aqglbmdh, syzh ,sbflmc) AS SELECT djb_gl.dwnbbh, djb_gl.glszdd, djb_gl.ddlxdh, djb_gl.glxh, djb_gl.gllb, djb_gl.zzdw, djb_gl.zzrq, djb_gl.ccbg, djb_gl.tyrq, djb_gl.sjgzyl, djb_gl.xksyyl, djb_gl.edcl, djb_gl.rrzl, djb_gl.glyt, djb_gl.jzckwd, djb_gl.sclfs, djb_gl.zcid, sb_total.lssbzcdm, sb_total.sbmc, sb_total.sblb, sb_total.sbzl, sb_total.sbpz, sb_total.sydw, sb_total.sbxh, sb_total.ccbh, sb_total.qydm, sb_total.sbdm, sb_sydw.sydwdz, sb_sydw.dwyzbm, sb_sydw.sbsf, sb_sydw.sbds, sb_sydw.sbqx, sb_sydw.frdb1, sb_sydw.sydwlxdh, sb_sydw.zgfzr, sb_sydw.fzrdh, sb_sydw.aqglbm, sb_sydw.aqglry, sb_sydw.aqglbmdh, sb_syz.syzh,view_jcgl_sbfl.sbflmc FROM {oj sb_total LEFT OUTER JOIN sb_syz ON sb_total.zcid = sb_syz.zcid},djb_gl,sb_sydw,view_jcgl_sbfl WHERE ( sb_total.zcid = sb_sydw.zcid ) and ( sb_total.zcid = djb_gl.zcid ) and (sb_total.sbpz = view_jcgl_sbfl.sbpz) "// and (sb_total.sbsyzt <> '20')
   execute immediate :mysql using sqlca;
end if
