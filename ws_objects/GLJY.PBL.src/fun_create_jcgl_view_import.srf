if mark = 'sqlserver' then 
   delsql = "drop view djylrq.view_jcgl_ylgd"
	execute immediate :delsql using sqlca;
	mysql = "CREATE view djylrq.view_jcgl_ylgd ( zcid, sjdw, azdw, tyrq, gdmc, gdlb, gdjb, gdbh, gdzd, dgcd, gdcl, sjyl, sjwd, ssjz, zggzyl, zggzwd, fffs, gczzmc, sbsydw, sbsf, sbds, sbqx, sydwdz, aqglbm, aqglry, zgbmlxdh, sydwyb, sbzcdm, sbmc, sblb, sbzl, sbjb, sbpz, sbxh, ccbh, qydm, sbdm,sbflmc,aqglrydh, GDQD,GD_ZDGCZJ, GD_ZDBH,GDPSFS) AS SELECT djylrq.djb_ylgd.zcid,djylrq.djb_ylgd.sjdw,djylrq.djb_ylgd.azdw,djylrq.djb_ylgd.tyrq,djylrq.djb_ylgd.gdmc,djylrq.djb_ylgd.gdlb,djylrq.djb_ylgd.gdjb,djylrq.djb_ylgd.gdbh,djylrq.djb_ylgd.gdzd,djylrq.djb_ylgd.dgcd,djylrq.djb_ylgd.gdcl,djylrq.djb_ylgd.sjyl,djylrq.djb_ylgd.sjwd,djylrq.djb_ylgd.ssjz,djylrq.djb_ylgd.zggzyl,djylrq.djb_ylgd.zggzwd,djylrq.djb_ylgd.fffs,djylrq.djb_ylgd_hzb.gczzmc,djylrq.djb_ylgd_hzb.sbsydw,djylrq.djb_ylgd_hzb.sbsf,djylrq.djb_ylgd_hzb.sbds,djylrq.djb_ylgd_hzb.sbqx,djylrq.djb_ylgd_hzb.sydwdz,djylrq.djb_ylgd_hzb.aqglbm,djylrq.djb_ylgd_hzb.aqglry,djylrq.djb_ylgd_hzb.zgbmlxdh,djylrq.djb_ylgd_hzb.sydwyb, djylrq.sb_total.lssbzcdm,djylrq.sb_total.sbmc,djylrq.sb_total.sblb,djylrq.sb_total.sbzl,djylrq.sb_total.sbjb,djylrq.sb_total.sbpz,djylrq.sb_total.sbxh,djylrq.sb_total.ccbh,djylrq.sb_total.qydm,djylrq.sb_total.sbdm,djylrq.view_jcgl_sbfl.sbflmc,djylrq.djb_ylgd_hzb.aqglrydh, djylrq.DJB_YLGD.GDQD,djylrq.DJB_YLGD.GD_ZDGCZJ, djylrq.DJB_YLGD.GD_ZDBH,djylrq.DJB_YLGD.GDPSFS FROM djylrq.djb_ylgd,djylrq.djb_ylgd_hzb,djylrq.sb_total,djylrq.view_jcgl_sbfl WHERE (djylrq.djb_ylgd.zcid =djylrq.djb_ylgd_hzb.zcid ) and (djylrq.djb_ylgd_hzb.zcid =djylrq.sb_total.zcid ) and (djylrq.sb_total.sbpz = djylrq.view_jcgl_sbfl.sbpz) "//and (djylrq.sb_total.sbsyzt <> '20') 
	execute immediate :mysql using sqlca;
else 
	delsql = "drop view view_jcgl_ylgd"
	execute immediate :delsql using sqlca;
	mysql = "CREATE view djylrq.view_jcgl_ylgd ( zcid, sjdw, azdw, tyrq, gdmc, gdlb, gdjb, gdbh, gdzd, dgcd, gdcl, sjyl, sjwd, ssjz, zggzyl, zggzwd, fffs, gczzmc, sbsydw, sbsf, sbds, sbqx, sydwdz, aqglbm, aqglry, zgbmlxdh, sydwyb, sbzcdm, sbmc, sblb, sbzl, sbjb, sbpz, sbxh, ccbh, qydm, sbdm,sbflmc,aqglrydh, GDQD,GD_ZDGCZJ, GD_ZDBH,GDPSFS) AS SELECT djylrq.djb_ylgd.zcid,djylrq.djb_ylgd.sjdw,djylrq.djb_ylgd.azdw,djylrq.djb_ylgd.tyrq,djylrq.djb_ylgd.gdmc,djylrq.djb_ylgd.gdlb,djylrq.djb_ylgd.gdjb,djylrq.djb_ylgd.gdbh,djylrq.djb_ylgd.gdzd,djylrq.djb_ylgd.dgcd,djylrq.djb_ylgd.gdcl,djylrq.djb_ylgd.sjyl,djylrq.djb_ylgd.sjwd,djylrq.djb_ylgd.ssjz,djylrq.djb_ylgd.zggzyl,djylrq.djb_ylgd.zggzwd,djylrq.djb_ylgd.fffs,djylrq.djb_ylgd_hzb.gczzmc,djylrq.djb_ylgd_hzb.sbsydw,djylrq.djb_ylgd_hzb.sbsf,djylrq.djb_ylgd_hzb.sbds,djylrq.djb_ylgd_hzb.sbqx,djylrq.djb_ylgd_hzb.sydwdz,djylrq.djb_ylgd_hzb.aqglbm,djylrq.djb_ylgd_hzb.aqglry,djylrq.djb_ylgd_hzb.zgbmlxdh,djylrq.djb_ylgd_hzb.sydwyb, djylrq.sb_total.lssbzcdm,djylrq.sb_total.sbmc,djylrq.sb_total.sblb,djylrq.sb_total.sbzl,djylrq.sb_total.sbjb,djylrq.sb_total.sbpz,djylrq.sb_total.sbxh,djylrq.sb_total.ccbh,djylrq.sb_total.qydm,djylrq.sb_total.sbdm,djylrq.view_jcgl_sbfl.sbflmc,djylrq.djb_ylgd_hzb.aqglrydh, djylrq.DJB_YLGD.GDQD,djylrq.DJB_YLGD.GD_ZDGCZJ, djylrq.DJB_YLGD.GD_ZDBH,djylrq.DJB_YLGD.GDPSFS FROM djylrq.djb_ylgd,djylrq.djb_ylgd_hzb,djylrq.sb_total,djylrq.view_jcgl_sbfl WHERE (djylrq.djb_ylgd.zcid =djylrq.djb_ylgd_hzb.zcid ) and (djylrq.djb_ylgd_hzb.zcid =djylrq.sb_total.zcid ) and (djylrq.sb_total.sbpz = djylrq.view_jcgl_sbfl.sbpz) "//and (djylrq.sb_total.sbsyzt <> '20')
