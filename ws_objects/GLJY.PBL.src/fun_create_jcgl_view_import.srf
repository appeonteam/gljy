if mark = 'sqlserver' then 
   delsql = "drop view djylrq.view_map_total"
	execute immediate :delsql using sqlca;
	mysql = "CREATE view djylrq.view_map_total(zcid,sblb,sbzl,sydw,dwid,sbsyzt,sbpz,qydm,dgcd,sbzcdm ) AS SELECT sb_total.zcid,sb_total.sblb,sb_total.sbzl,sb_total.sydw,sb_total.dwid,sb_total.sbsyzt,sb_total.sbpz,sb_total.qydm,djb_ylgd.dgcd,sb_total.sbzcdm FROM {oj sb_total LEFT OUTER JOIN djb_ylgd ON sb_total.zcid = djb_ylgd.zcid} union SELECT sb_total_bf.zcid,sb_total_bf.sblb,sb_total_bf.sbzl,sb_total_bf.sydw,sb_total_bf.dwid,'99',sb_total_bf.sbpz,sb_total_bf.qydm,djb_ylgd.dgcd,sb_total_bf.sbzcdm  FROM {oj sb_total_bf LEFT OUTER JOIN djb_ylgd ON sb_total_bf.zcid = djb_ylgd.zcid}"
	execute immediate :mysql using sqlca;
else 
	delsql = "drop view view_map_total"
	execute immediate :delsql using sqlca;
	mysql = "CREATE VIEW view_map_total(zcid,sblb,sbzl,sydw,dwid,sbsyzt,sbpz,qydm,dgcd,sbzcdm ) AS SELECT sb_total.zcid,sb_total.sblb,sb_total.sbzl,sb_total.sydw,sb_total.dwid,sb_total.sbsyzt,sb_total.sbpz,sb_total.qydm,djb_ylgd.dgcd,sb_total.sbzcdm FROM {oj sb_total LEFT OUTER JOIN djb_ylgd ON sb_total.zcid = djb_ylgd.zcid} union SELECT sb_total_bf.zcid,sb_total_bf.sblb,sb_total_bf.sbzl,sb_total_bf.sydw,sb_total_bf.dwid,'99',sb_total_bf.sbpz,sb_total_bf.qydm,djb_ylgd.dgcd,sb_total_bf.sbzcdm  FROM {oj sb_total_bf LEFT OUTER JOIN djb_ylgd ON sb_total_bf.zcid = djb_ylgd.zcid}"
	execute immediate :mysql using sqlca;
end if
string qydm,sbdsdm
select sbdsdm into :sbdsdm from a_jydw;
qydm = left(sbdsdm,4)
if mark = 'sqlserver' then 
   delsql = "drop view djylrq.view_map_temp"
	execute immediate :delsql using sqlca;
	mysql = "CREATE view djylrq.view_map_temp(xzid,xzmc,bs,jd,wd) AS select distinct(view_map_total.qydm),z_xzdm.xzmc,2,z_xzdm.jd,z_xzdm.wd from view_map_total,z_xzdm where substring(view_map_total.qydm,1,4) = '" + qydm + "' and substring(view_map_total.qydm,5,2) <> '00'  and view_map_total.qydm = z_xzdm.xzid union  select distinct(substring(view_map_total.qydm,1,4))+ '00',z_xzdm.xzmc,1,z_xzdm.jd,z_xzdm.wd from view_map_total,z_xzdm   where substring(view_map_total.qydm,1,4) = '" + qydm + "' and  substring(view_map_total.qydm,1,4)+ '00' = z_xzdm.xzid   union select distinct(convert(varchar,view_map_total.dwid)),dw_total_sydw.dwmc,3,dw_total_sydw.jd,dw_total_sydw.wd from view_map_total,dw_total_sydw  where substring(view_map_total.qydm,1,4) = '" + qydm + "'  and  view_map_total.dwid = dw_total_sydw.dwid"
   execute immediate :mysql using sqlca;
else 
	delsql = "drop view view_map_temp"
	execute immediate :delsql using sqlca;
	mysql = "CREATE VIEW view_map_temp(xzid,xzmc,bs,jd,wd) AS select distinct(view_map_total.qydm),z_xzdm.xzmc,2,z_xzdm.jd,z_xzdm.wd from view_map_total,z_xzdm where substring(view_map_total.qydm,1,4) = '" + qydm + "'  and substring(view_map_total.qydm,5,2) <> '00'  and view_map_total.qydm = z_xzdm.xzid union  select distinct(substring(view_map_total.qydm,1,4))+ '00',z_xzdm.xzmc,1,z_xzdm.jd,z_xzdm.wd from view_map_total,z_xzdm   where substring(view_map_total.qydm,1,4) = '" + qydm + "' and  substring(view_map_total.qydm,1,4)+ '00' = z_xzdm.xzid   union select distinct(convert(varchar,view_map_total.dwid)),dw_total_sydw.dwmc,3,dw_total_sydw.jd,dw_total_sydw.wd from view_map_total,dw_total_sydw  where substring(view_map_total.qydm,1,4) = '" + qydm + "'  and  view_map_total.dwid = dw_total_sydw.dwid"
   execute immediate :mysql using sqlca;
end if

