global subroutine fun_create_jcgl_view_import (string zt);long ls_count = 0
string mysql,delsql,myindex,modsql
// Ê×ÏÈÅÐ¶ÏÏµÍ³Îªsqlserver°æ»¹ÊÇsybase°æ
