event clicked;string ls_NowBsqid,ls_NowSqid
if row < 1 then
	return
end if

ls_NowBsqid = this.GetItemString(row,'bsqid')
ls_NowSqid = this.GetItemString(row,'sqid')
if ls_NowBsqid <> 'ÎÞ' or ls_NowSqid <> 'ÎÞ' then
	this.SetTabOrder('jytype',0)
	this.SetTabOrder('rysh',0)
	this.SetTabOrder('rysq',0)
	this.SetTabOrder('rysp',0)
else
	this.SetTabOrder('jytype',10)
	this.SetTabOrder('rysh',30)
	this.SetTabOrder('rysq',40)
	this.SetTabOrder('rysp',50)
end if
string jytype
jytype = this.getitemstring(row,'jytype')
if dwo.name = 'b_1' then
	if dw_dj.getitemstring(row,'rysh') = '1' or dw_dj.getitemstring(row,'rysp') = '1' then
		openwithparm(win_jykeyset_dqm,jytype)
	else
		messagebox("ÏµÍ³ÌáÊ¾","ÇëÈ·ÈÏÉóºËÈ¨ÏÞ£¡")
	end if
end if 
end event

