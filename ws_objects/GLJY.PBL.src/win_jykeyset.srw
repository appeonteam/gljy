event clicked;string ls_NowRyid,ls_NowRydj,ls_NowRyaj,ls_NowRyjj,ls_NowRyjk,ls_NowRyqj,ls_NowRygl,ls_NowRytj
//fun_windows_position(this)
select jyid,rydj,ryaj,ryjj,ryjk,ryqj,rygl,rytj into 
       :ls_NowRyid,:ls_NowRydj,:ls_NowRyaj,:ls_NowRyjj,:ls_NowRyjk,:ls_NowRyqj,:ls_NowRygl,:ls_NowRytj 
from a_rycode where ryid = :gs_keyno;
if ls_NowRydj <> 'NULL' then
	if mid(ls_NowRydj,1,1) = '1' then
		tab_1.tabpage_1.cbx_dj1.Checked = true
	else
		tab_1.tabpage_1.cbx_dj1.Checked = false
	end if
	if mid(ls_NowRydj,2,1) = '1' then
		tab_1.tabpage_1.cbx_dj2.Checked = true
	else
		tab_1.tabpage_1.cbx_dj2.Checked = false
	end if
	if mid(ls_NowRydj,3,1) = '1' then
		tab_1.tabpage_1.cbx_dj3.Checked = true
	else
		tab_1.tabpage_1.cbx_dj3.Checked = false
	end if
	if mid(ls_NowRydj,4,1) = '1' then
		tab_1.tabpage_1.cbx_dj4.Checked = true
	else
		tab_1.tabpage_1.cbx_dj4.Checked = false
	end if
	if mid(ls_NowRydj,5,1) = '1' then
		tab_1.tabpage_1.cbx_dj5.Checked = true
	else
		tab_1.tabpage_1.cbx_dj5.Checked = false
	end if
end if
if ls_NowRyaj <> 'NULL' then
	if mid(ls_NowRyaj,1,1) = '1' then
		tab_1.tabpage_2.cbx_aj1.Checked = true
	else
		tab_1.tabpage_2.cbx_aj1.Checked = false
	end if
	if mid(ls_NowRyaj,2,1) = '1' then
		tab_1.tabpage_2.cbx_aj2.Checked = true
	else
		tab_1.tabpage_2.cbx_aj2.Checked = false
	end if
	if mid(ls_NowRyaj,3,1) = '1' then
		tab_1.tabpage_2.cbx_aj3.Checked = true
	else
		tab_1.tabpage_2.cbx_aj3.Checked = false
	end if
end if
if ls_NowRyjj <> 'NULL' then
	if mid(ls_NowRyjj,1,1) = '1' then
		tab_1.tabpage_3.cbx_jj1.Checked = true
	else
		tab_1.tabpage_3.cbx_jj1.Checked = false
	end if
	if mid(ls_NowRyjj,2,1) = '1' then
		tab_1.tabpage_3.cbx_jj2.Checked = true
	else
		tab_1.tabpage_3.cbx_jj2.Checked = false
	end if
	if mid(ls_NowRyjj,3,1) = '1' then
		tab_1.tabpage_3.cbx_jj3.Checked = true
	else
		tab_1.tabpage_3.cbx_jj3.Checked = false
	end if
end if
if ls_NowRyjk <> 'NULL' then
	if mid(ls_NowRyjk,1,1) = '1' then
		tab_1.tabpage_4.cbx_jk1.Checked = true
	else
		tab_1.tabpage_4.cbx_jk1.Checked = false
	end if
	if mid(ls_NowRyjk,2,1) = '1' then
		tab_1.tabpage_4.cbx_jk2.Checked = true
	else
		tab_1.tabpage_4.cbx_jk2.Checked = false
	end if
	if mid(ls_NowRyjk,3,1) = '1' then
		tab_1.tabpage_4.cbx_jk3.Checked = true
	else
		tab_1.tabpage_4.cbx_jk3.Checked = false
	end if
end if
if ls_NowRyqj <> 'NULL' then
	if mid(ls_NowRyqj,1,1) = '1' then
		tab_1.tabpage_5.cbx_qj1.Checked = true
	else
		tab_1.tabpage_5.cbx_qj1.Checked = false
	end if
	if mid(ls_NowRyqj,2,1) = '1' then
		tab_1.tabpage_5.cbx_qj2.Checked = true
	else
		tab_1.tabpage_5.cbx_qj2.Checked = false
	end if
	if mid(ls_NowRyqj,3,1) = '1' then
		tab_1.tabpage_5.cbx_qj3.Checked = true
	else
		tab_1.tabpage_5.cbx_qj3.Checked = false
	end if
	if mid(ls_NowRyqj,4,1) = '1' then
		tab_1.tabpage_5.cbx_qj4.Checked = true
	else
		tab_1.tabpage_5.cbx_qj4.Checked = false
	end if
	if mid(ls_NowRyqj,5,1) = '1' then
		tab_1.tabpage_5.cbx_qj5.Checked = true
	else
		tab_1.tabpage_5.cbx_qj5.Checked = false
	end if
	if mid(ls_NowRyqj,6,1) = '1' then
		tab_1.tabpage_5.cbx_qj6.Checked = true
	else
		tab_1.tabpage_5.cbx_qj6.Checked = false
	end if
end if

tab_1.tabpage_1.dw_dj.Retrieve(ls_NowRyid)
tab_1.tabpage_2.dw_aj.Retrieve(ls_NowRyid)
tab_1.tabpage_3.dw_jj.Retrieve(ls_NowRyid)
tab_1.tabpage_4.dw_jk.Retrieve(ls_NowRyid)
tab_1.tabpage_5.dw_qj.Retrieve(ls_NowRyid)

///////////////////////////////song////////////////////////////
if tab_1.tabpage_1.cbx_dj2.checked = true or tab_1.tabpage_1.cbx_dj5.checked = true then 
	tab_1.tabpage_1.dw_dj.object.b_1.visible = true
else
	tab_1.tabpage_1.dw_dj.object.b_1.visible = false
end if
if tab_1.tabpage_2.cbx_aj2.checked = true or tab_1.tabpage_2.cbx_aj3.checked = true  then 
	tab_1.tabpage_2.dw_aj.object.b_1.visible = true
else
	tab_1.tabpage_2.dw_aj.object.b_1.visible = false
end if

if tab_1.tabpage_3.cbx_jj2.checked = true or tab_1.tabpage_3.cbx_jj3.checked = true then 
	tab_1.tabpage_3.dw_jj.object.b_1.visible = true
else
	tab_1.tabpage_3.dw_jj.object.b_1.visible = false
end if
if tab_1.tabpage_4.cbx_jk2.checked = true or tab_1.tabpage_4.cbx_jk3.checked = true then 
	tab_1.tabpage_4.dw_jk.object.b_1.visible = true
else
	tab_1.tabpage_4.dw_jk.object.b_1.visible = false
end if
if tab_1.tabpage_5.cbx_qj2.checked = true or tab_1.tabpage_5.cbx_qj3.checked = true then 
	tab_1.tabpage_5.dw_qj.object.b_1.visible = true
else
	tab_1.tabpage_5.dw_qj.object.b_1.visible = false
end if
if tab_1.tabpage_1.cbx_dj2.checked = false and tab_1.tabpage_1.cbx_dj5.checked = false and tab_1.tabpage_2.cbx_aj2.checked = false and tab_1.tabpage_2.cbx_aj3.checked = false and +&
	tab_1.tabpage_3.cbx_jj2.checked = false and tab_1.tabpage_3.cbx_jj3.checked = false and tab_1.tabpage_4.cbx_jk2.checked = false and tab_1.tabpage_4.cbx_jk3.checked = false and tab_1.tabpage_5.cbx_qj2.checked = false and tab_1.tabpage_5.cbx_qj3.checked = false then
	cb_1.visible = false
else
	cb_1.visible = true
end if
end event

