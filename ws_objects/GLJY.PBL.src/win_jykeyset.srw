destroy(this.tabpage_7)
end on

event selectionchanged;Ii_UseIndex = newindex
choose case Ii_UseIndex
	case 1,2,3,4,5
		cb_add.Enabled = true
		cb_delete.Enabled = true
	case 6
		if gs_jydw='ÖÐ¹úÊ¯ÓÍÁÉºÓÓÍÌïÌØÖÖÉè±¸¼ìÑéÖÐÐÄ' then
			tab_1.tabpage_6.cbx_gl33.enabled=true
		elseif (gs_jydw='ºùÂ«µºÊÐÌØÖÖÉè±¸¼à¶½¼ìÑéËù') and gs_connect='true' then 
			tab_1.tabpage_6.cbx_gl37.enabled=true
			tab_1.tabpage_6.cbx_gl38.enabled=true
			tab_1.tabpage_6.cbx_gl39.enabled=true
			tab_1.tabpage_6.cbx_gl40.enabled=true
			tab_1.tabpage_6.cbx_gl42.enabled=true
			tab_1.tabpage_6.cbx_gl43.enabled=true
		elseif gs_connect='true'  then
			tab_1.tabpage_6.cbx_gl41.enabled=true
			tab_1.tabpage_6.cbx_gl32.enabled=true
			tab_1.tabpage_6.cbx_gl34.enabled=true
			tab_1.tabpage_6.cbx_gl36.enabled=true
		elseif gs_jydw='ÉòÑôÊÐÌØÖÖÉè±¸¼ì²âÑÐ¾¿Ôº' then
			tab_1.tabpage_6.cbx_gl44.visible=true
			tab_1.tabpage_6.cbx_gl44.enabled=true
			tab_1.tabpage_6.cbx_gl45.visible=true
			tab_1.tabpage_6.cbx_gl45.enabled=true
			tab_1.tabpage_6.cbx_gl46.visible=true
			tab_1.tabpage_6.cbx_gl46.enabled=true
		else	
			string supervisor
			select supervisor into :supervisor from a_rycode where ryid = :gs_keyno;
			if supervisor = '' or isnull(supervisor) then
				tab_1.tabpage_6.cbx_gl21.visible=false
			else
				tab_1.tabpage_6.cbx_gl21.visible=true
			end if
			tab_1.tabpage_6.cbx_gl33.enabled=false
			tab_1.tabpage_6.cbx_gl37.enabled=false
			tab_1.tabpage_6.cbx_gl38.enabled=false
			tab_1.tabpage_6.cbx_gl39.enabled=false
			tab_1.tabpage_6.cbx_gl40.enabled=false
			tab_1.tabpage_6.cbx_gl44.visible=false
			tab_1.tabpage_6.cbx_gl44.enabled=false
			tab_1.tabpage_6.cbx_gl45.visible=false
			tab_1.tabpage_6.cbx_gl45.enabled=false
			tab_1.tabpage_6.cbx_gl46.visible=false
			tab_1.tabpage_6.cbx_gl46.enabled=false
		end if
	case 7
//		tab_1.tabpage_7.cbx_tj14.visible=false
//		tab_1.tabpage_7.cbx_tj15.visible=false
//		tab_1.tabpage_7.cbx_tj17.visible=false
//		tab_1.tabpage_7.cbx_tj18.visible=false
	case else
		cb_add.Enabled = false
		cb_delete.Enabled = false
end choose


end event

