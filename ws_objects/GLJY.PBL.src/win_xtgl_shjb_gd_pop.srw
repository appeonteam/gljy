type cb_1 from commandbutton within win_xtgl_shjb_gd_pop
event clicked pbm_bnclicked
int X=956
int Y=1289
int Width=366
int Height=125
int TabOrder=200
string Text="È·ÈÏ"
int TextSize=-12
int Weight=700
string FaceName="ËÎÌå"
