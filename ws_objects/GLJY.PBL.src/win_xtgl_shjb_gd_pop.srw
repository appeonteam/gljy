end type

event clicked;string str_ddlb1,str_ddlb2,str_ddlb3,str_ddlb4,str_ddlb5,str_sle1,str_sle2,str_sle3,str_sle4,hulue = "N"
string jyjlid = 'N'

if rb_2.checked = true then jyjlid =  'Y'
str_ddlb1 = trim(ddlb_1.text)
str_ddlb2 = trim(ddlb_2.text)
str_ddlb3 = trim(ddlb_3.text)
str_ddlb4 = trim(ddlb_4.text)
str_ddlb5 = trim(ddlb_5.text)
str_sle1 = trim(sle_1.text)
str_sle2 = trim(sle_2.text)
str_sle3 = trim(sle_3.text)
str_sle4 = trim(sle_4.text)

string shjbstr,jy1,jy2,jy3,jy4,jy5,jy6,jy7,jy8,jy9

setnull(shjbstr)
if cbx_1.checked = true then
	jy1 = '1'
	shjbstr = '1'
else
	jy1 = '1'
	shjbstr = '1'
end if
if cbx_2.checked = true then
	jy2 = '1'
	shjbstr = shjbstr + '1'
else
	jy2 = '0'
	shjbstr = shjbstr + '0'
end if
if cbx_3.checked = true then
	jy3 = '1'
	shjbstr = shjbstr + '1'
else
	jy3 = '0'
	shjbstr = shjbstr + '0'
end if
if cbx_4.checked = true then
	jy4 = '1'
	shjbstr = shjbstr + '1'
else
	jy4 = '0'
	shjbstr = shjbstr + '0'
end if
if cbx_5.checked = true then
	jy5 = '1'
	shjbstr = shjbstr + '1'
else
	jy5 = '0'
	shjbstr = shjbstr + '0'
end if
if cbx_6.checked = true then
	jy6 = '1'
	shjbstr = shjbstr + '1'
else
	jy6 = '0'
	shjbstr = shjbstr + '0'
end if
if cbx_7.checked = true then
	jy7 = '1'
	shjbstr = shjbstr + '1'
else
	jy7 = '0'
	shjbstr = shjbstr + '0'
end if
if cbx_8.checked = true then
	jy8 = '1'
	shjbstr = shjbstr + '1'
else
	jy8 = '0'
	shjbstr = shjbstr + '0'
end if
if cbx_9.checked = true then
	jy9 = '1'
	shjbstr = shjbstr + '1'
else
	jy9 = '0'
	shjbstr = shjbstr + '0'
end if

if shjbstr = "100000000"  then
	messagebox("ÏµÍ³ÌáÊ¾","±¨¸æÉóºËÈË±ØÐèÑ¡Ôñ£¡")
	return
end if
if cbx_sdcs.checked = false and gi_modimark <> 3 then
	if messagebox("ÏµÍ³ÌáÊ¾",gi_jyml + "  " + gi_jylb + "½«ºöÂÔÉè¶¨Ìõ¼þ£¬¶ø°´" + &
	   shjbstr + "ÉóºË¹ý³Ì£¬ÊÇÂð£¿",Exclamation!,YesNo!,1)=1 then
	else
	   return
   end if
	hulue = "Y"
end if

integer currnum,okmark

okmark = 0
choose case gi_modimark
	case 3
           delete from a_shjb_gg 
			  where jymlid like :gi_jymlid and jylbid = :gi_jylbid and shjbid = :gs_keyno ;
   case 2 
		      UPDATE a_shjb_gg  
     SET shjb = :shjbstr,   
         jy1 = :jy1,   
         jy2 = :jy2,   
         jy3 = :jy3,   
         jy4 = :jy4,   
         jy5 = :jy5,   
         jy6 = :jy6,   
         jy7 = :jy7,   
         jy8 = :jy8,   
         jy9 = :jy9,
			jyjl = :str_ddlb1,
			edcl1 = :str_ddlb2,   
         edcl2 = :str_ddlb3,   
         edyl1 = :str_ddlb4,   
         edyl2 = :str_ddlb5,
			syyl1 = :str_sle1,
			syyl2 = :str_sle2,
			ckwd1 = :str_sle3,
			ckwd2 = :str_sle4,
			mark = :hulue,
			jyjlid = :jyjlid
		WHERE jymlid like :gi_jymlid and jylbid like :gi_jylbid and shjbid = :gs_keyno ;

   case 1 
		string lastno
		select max(shjbid) into :lastno from a_shjb_gg ;//where jymlid like :gi_jymlid and &
		                                                 //    jylbid like :gi_jylbid  ;
         if sqlca.sqlcode = 0  then
             if isnull(lastno) then
       	       lastno = '1001'
             else
       	       lastno = string(long(lastno)+1)
             end if
         else
            lastno = '1001'
        end if
		  INSERT INTO a_shjb_gg  
         ( jymlid, 
			  jylbid,
			  jyml,
           jylb,   
           shjbid,   
           shjb,   
           jy1,   
           jy2,   
           jy3,   
           jy4,   
           jy5,   
           jy6,   
           jy7,   
           jy8,   
           jy9,
			  jyjl,
			  edcl1,
			  edcl2,
			  edyl1,
			  edyl2,
			  syyl1,
			  syyl2,
			  ckwd1,
			  ckwd2,
			  mark,
			  jyjlid)  
  VALUES ( :gi_jymlid,
           :gi_jylbid,
			  :gi_jyml,
			  :gi_jylb,   
           :lastno,   
           :shjbstr,   
           :jy1,   
           :jy2,   
           :jy3,   
           :jy4,   
           :jy5,   
           :jy6,   
           :jy7,   
           :jy8,   
           :jy9,
			  :str_ddlb1,
			  :str_ddlb2,
			  :str_ddlb3,
			  :str_ddlb4,
			  :str_ddlb5,
			  :str_sle1,
			  :str_sle2,
			  :str_sle3,
			  :str_sle4,
			  :hulue,
			  :jyjlid)  ;

end choose		  
if okmark = 0 then
   commit;
else
	rollback;
	messagebox('ÏµÍ³ÌáÊ¾','¶Ô²»Æð£¡´Ë´ÎÐÞ¸ÄµÄÊý¾ÝÎ´ÄÜ¸üÐÂ£¡')
end if

win_xtgl_shjb.dw_d.retrieve()

close(parent)
end event

