event open;st_title.text = gi_jyml  + gi_jylb

ddlb_1.additem(space(100))
ddlb_2.additem(space(100))
ddlb_3.additem(space(100))
ddlb_4.additem(space(100))
ddlb_5.additem(space(100))
if gi_modimark = 2 or gi_modimark = 3 then
	                      // edcl1 rqbh  , edcl2 aqdj , edyl1 ytdh , edyl2 yldj 
	string jy1,jy2,jy3,jy4,jy5,jy6,jy7,jy8,jy9
	string edcl1,edcl2,edyl1,edyl2,syyl1,syyl2,mark,jyjlid
	select jy1,jy2,jy3,jy4,jy5,jy6,jy7,jy8,jy9,jyjl,edcl1,edcl2,edyl1,edyl2,syyl1,syyl2,ckwd1,ckwd2,mark,jyjlid &
	into :jy1,:jy2,:jy3,:jy4,:jy5,:jy6,:jy7,:jy8,:jy9,  &
	     :ddlb_1.text,:ddlb_2.text,:ddlb_3.text,:ddlb_4.text,:ddlb_5.text,:sle_1.text,:sle_2.text,:sle_3.text,:sle_4.text,:mark,:jyjlid &
	from a_shjb_gg
	where jymlid like :gi_jymlid and jylbid like :gi_jylbid and shjbid like :gs_keyno ;
	
	if jy1 = '1' then
	    cbx_1.checked = true
   else
	    cbx_1.checked = false
   end if
	if jy2 = '1' then
	    cbx_2.checked = true
   else
	    cbx_2.checked = false
   end if
	if jy3 = '1' then
	    cbx_3.checked = true
   else
	    cbx_3.checked = false
   end if
	if jy4 = '1' then
	    cbx_4.checked = true
   else
	    cbx_4.checked = false
   end if
	if jy5 = '1' then
	    cbx_5.checked = true
   else
	    cbx_5.checked = false
   end if
	if jy6 = '1' then
	    cbx_6.checked = true
   else
	    cbx_6.checked = false
   end if
	if jy7 = '1' then
	    cbx_7.checked = true
   else
	    cbx_7.checked = false
   end if
	if jy8 = '1' then
	    cbx_8.checked = true
   else
	    cbx_8.checked = false
   end if
	if jy9 = '1' then
	    cbx_9.checked = true
   else
	    cbx_9.checked = false
   end if
	
	if mark = "Y" then 
		cbx_sdcs.checked = false		
	else
		cbx_sdcs.checked = true
		ddlb_1.enabled=true
		ddlb_2.enabled=true
		ddlb_3.enabled=true
		ddlb_4.enabled=true
	   ddlb_5.enabled=true
		sle_1.enabled=true
		sle_2.enabled=true
		sle_3.enabled=true
		sle_4.enabled=true
	end if
   if jyjlid = "Y" then
		rb_2.checked = true
		cbx_1.enabled=true
		cbx_2.enabled=true
		cbx_3.enabled=true
		cbx_4.enabled=true
		cbx_5.enabled=true
		cbx_6.enabled=true
		cbx_7.enabled=true
		cbx_8.enabled=true
		cbx_9.enabled=true
	else
		rb_1.checked = true
	end if
end if

end event

