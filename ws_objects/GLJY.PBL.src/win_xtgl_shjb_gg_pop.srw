   end if
	if jy7 = '1' then
	    cbx_7.checked = true
   else
	    cbx_7.checked = false
   end if
	if jy8 = '1' then
	    cbx_8.checked = true
   else
	    cbx_8.checked = false
   end if
	if jy9 = '1' then
	    cbx_9.checked = true
   else
	    cbx_9.checked = false
   end if
	
	if hulue = "Y" then 
		cbx_sdcs.checked = false
	else
		cbx_sdcs.checked = true
		em_edcl1.enabled=true
		em_edcl2.enabled=true
		em_edyl1.enabled=true
