		ddlb_ckwdfh2.enabled=true
		ddlb_jyjl.enabled=true
		ddlb_glzl.enabled=true
	end if
	if jyjlid = 'Y' then
		rb_2.checked = true
		cbx_sdcs.enabled=true
		cbx_1.enabled = true
		cbx_2.enabled = true
		cbx_3.enabled = true
