string temp2
DECLARE temp_jyjl CURSOR FOR
	SELECT  jyjl
	FROM a_jyjl 
	WHERE jymlid like :gi_jymlid and jylbid like :gi_jylbid;
OPEN temp_jyjl;
FETCH temp_jyjl INTO :temp2;
DO WHILE SQLCA.SQLCODE = 0
   ddlb_jyjl.additem(trim(temp2))
   FETCH temp_jyjl INTO :temp2;
LOOP
CLOSE temp_jyjl;


if gi_modimark <> 1 then
	string jy1,jy2,jy3,jy4,jy5,jy6,jy7,jy8,jy9
	string edcl1,edcl2,edyl1,edyl2,syyl1,syyl2,ckwd1,ckwd2,hulue,jyjlid
	select jy1,jy2,jy3,jy4,jy5,jy6,jy7,jy8,jy9,jyjl,glzl,glyt,rlzl, &
	       edclfh1,edcl1,edclfh2,edcl2,edylfh1,edyl1,edylfh2,edyl2, &
			 syylfh1,syyl1,syylfh2,syyl2,ckwdfh1,ckwd1,ckwdfh2,ckwd2,mark,jyjlid &
	into :jy1,:jy2,:jy3,:jy4,:jy5,:jy6,:jy7,:jy8,:jy9,  &
	     :ddlb_jyjl.text,:ddlb_glzl.text,:ddlb_glyt.text,:ddlb_rlzl.text, &
	     :ddlb_edclfh1.text,:edcl1,:ddlb_edclfh2.text,:edcl2, &
		  :ddlb_edylfh1.text,:edyl1,:ddlb_edylfh2.text,:edyl2, &
		  :ddlb_syylfh1.text,:syyl1,:ddlb_syylfh2.text,:syyl2, &
		  :ddlb_ckwdfh1.text,:ckwd1,:ddlb_ckwdfh2.text,:ckwd2,:hulue,:jyjlid &
	from a_shjb_gg
	where jymlid like :gi_jymlid and jylbid like :gi_jylbid and shjbid like :gs_keyno ;
	
	if jy1 = '1' then
	    cbx_1.checked = true
   else
	    cbx_1.checked = false
   end if
	if jy2 = '1' then
	    cbx_2.checked = true
   else
