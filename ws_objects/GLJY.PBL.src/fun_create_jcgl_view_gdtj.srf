	mysql = "create view view_nm_wjl_ylgd (zcid,sbpz,dwid,jydwid,jylb,qydm,xcjyrq,dgcd,xh,jydw,zzjgdm,jyrq,jylb_a,zywt,jyjl,bgbh,xcjyrq_a,jyid,yqid,zgqx) AS SELECT ZYSB_NC_WJL_YLGD.ZCID, ZYSB_NC_WJL_YLGD.SBPZ, ZYSB_NC_WJL_YLGD.DWID, ZYSB_NC_WJL_YLGD.JYDWID, ZYSB_NC_WJL_YLGD.JYLB, ZYSB_NC_WJL_YLGD.QYDM, ZYSB_NC_WJL_YLGD.XCJYRQ, ZYSB_NC_WJL_YLGD.DGCD, T.XH, T.JYDW, T.ZZJGDM, T.JYRQ, T.JYLB, T.ZYWT, T.JYJL, T.BGBH, T.XCJYRQ, T.JYID, T.YQID, T.ZGQX FROM ZYSB_NC_WJL_YLGD, SB_JY T WHERE ( ZYSB_NC_WJL_YLGD.ZCID = T.ZCID )  and (ZYSB_NC_WJL_YLGD.XCJYRQ <> T.XCJYRQ) and ( ( XH = (select max(xh) from sb_jy where zcid = t.zcid) ) )"
	execute immediate :mysql using sqlca;
end if
if mark = 'sqlserver' then 
   delsql = "drop view djylrq.view_dc_tj"
	execute immediate :delsql using sqlca;
	mysql = "CREATE view djylrq.view_dc_tj (zcid,sbzcdm,sbmc,sblb,sbzl,sbjb,sydw,dwid,sbsyzt,yh,dc,jk,jd,wd,mapnumber,vxjb,sbpz,jydw,jydwid,sbxh,ccbh,zzdw,dwnbbh,sbgzzt,qydm,yy1,yy2,yy3,yy4,scrq,cmry,cmdw,cmdwid,spry) AS SELECT SB_TOTAL.ZCID, SB_TOTAL.SBZCDM, SB_TOTAL.SBMC, SB_TOTAL.SBLB, SB_TOTAL.SBZL, SB_TOTAL.SBJB, SB_TOTAL.SYDW, SB_TOTAL.DWID, SB_TOTAL.SBSYZT, SB_TOTAL.YH, SB_TOTAL.DC, SB_TOTAL.JK, SB_TOTAL.JD, SB_TOTAL.WD, SB_TOTAL.MAPNUMBER, SB_TOTAL.VXJB, SB_TOTAL.SBPZ, SB_TOTAL.JYDW, SB_TOTAL.JYDWID, SB_TOTAL.SBXH, SB_TOTAL.CCBH, SB_TOTAL.ZZDW, SB_TOTAL.DWNBBH, SB_TOTAL.SBGZZT, SB_TOTAL.QYDM, SB_DCXX.YY1, SB_DCXX.YY2, SB_DCXX.YY3, SB_DCXX.YY4, SB_DCXX.SCRQ, SB_DCXX.CMRY, SB_DCXX.CMDW, SB_DCXX.CMDWID, SB_DCXX.SPRY FROM SB_TOTAL, SB_DCXX WHERE ( SB_TOTAL.ZCID = SB_DCXX.ZCID ) "
	execute immediate :mysql using sqlca;
else 
	delsql = "drop view view_dc_tj"
	execute immediate :delsql using sqlca;
	mysql = "create view view_dc_tj (zcid,sbzcdm,sbmc,sblb,sbzl,sbjb,sydw,dwid,sbsyzt,yh,dc,jk,jd,wd,mapnumber,vxjb,sbpz,jydw,jydwid,sbxh,ccbh,zzdw,dwnbbh,sbgzzt,qydm,yy1,yy2,yy3,yy4,scrq,cmry,cmdw,cmdwid,spry) AS SELECT SB_TOTAL.ZCID, SB_TOTAL.SBZCDM, SB_TOTAL.SBMC, SB_TOTAL.SBLB, SB_TOTAL.SBZL, SB_TOTAL.SBJB, SB_TOTAL.SYDW, SB_TOTAL.DWID, SB_TOTAL.SBSYZT, SB_TOTAL.YH, SB_TOTAL.DC, SB_TOTAL.JK, SB_TOTAL.JD, SB_TOTAL.WD, SB_TOTAL.MAPNUMBER, SB_TOTAL.VXJB, SB_TOTAL.SBPZ, SB_TOTAL.JYDW, SB_TOTAL.JYDWID, SB_TOTAL.SBXH, SB_TOTAL.CCBH, SB_TOTAL.ZZDW, SB_TOTAL.DWNBBH, SB_TOTAL.SBGZZT, SB_TOTAL.QYDM, SB_DCXX.YY1, SB_DCXX.YY2, SB_DCXX.YY3, SB_DCXX.YY4, SB_DCXX.SCRQ, SB_DCXX.CMRY, SB_DCXX.CMDW, SB_DCXX.CMDWID, SB_DCXX.SPRY FROM SB_TOTAL, SB_DCXX WHERE ( SB_TOTAL.ZCID = SB_DCXX.ZCID ) "
	execute immediate :mysql using sqlca;
end if


end subroutine

