global subroutine fun_alter_qjtable1 (string cs1);if cs1 <> 'OK' then return
long ls_count = 0
string delsql,mysql,myindex,modsql
// Ê×ÏÈÅÐ¶ÏÏµÍ³Îªsqlserver°æ»¹ÊÇsybase°æ
string mark = 'sybase'
if sqlca.dbms="MSS (Msoft) SQL Server 6.0" then mark = 'sqlserver'
//select count(*) into :ls_count from djylrq.a_rycode;
//if ls_count > 0 and sqlca.sqlcode = 0 then mark = 'sqlserver'
// END
ls_Count = 0
///ÐÞ¸Äa_sz_nrÔö¼Ó±í×Ö¶ÎÄÚÈÝ
if mark = 'sqlserver' then
	select count(*) into : ls_count from a_sz_nr where jytype like '%';
	if sqlca.sqlcode = 0 then
		modsql = "update djylrq.a_sz_nr set dw='qj_aqf_jy' where jytype = 'Zf' and xh = '01'; "
		execute immediate :modsql using sqlca ;
	end if
else
	select count(*) into : ls_count from a_sz_nr where jytype like '%';
	if sqlca.sqlcode = 0 then
		modsql = "update a_sz_nr set dw='qj_aqf_jy' where jytype = 'Zf' and xh = '01';  "
