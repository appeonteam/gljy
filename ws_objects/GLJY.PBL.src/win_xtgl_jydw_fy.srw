type dw_1 from datawindow within tabpage_1
integer x = 73
integer y = 72
integer width = 2853
integer height = 972
integer taborder = 1
string dataobject = "dw_xtgl_bgbh"
boolean hscrollbar = true
boolean vscrollbar = true
boolean hsplitscroll = true
boolean livescroll = true
borderstyle borderstyle = stylelowered!
end type

event clicked;this.accepttext()
if row < 1 then
	return
else
	ii_rowno = row
end if

end event

event itemchanged;string typename,jymlid,jylbid,lbid,sh
long ll_RowCount,ll_RowNow
this.accepttext()
ll_RowCount = tab_1.tabpage_1.dw_1.RowCount()
if ll_RowCount > 1 then
	if isnull(data) or data = '' then 
	else
		if ll_RowCount = row then
			for ll_RowNow = 1 to ll_RowCount - 1 
				typename = tab_1.tabpage_1.dw_1.getitemstring(ll_RowNow,'typename')
				if data = typename then
					MessageBox("ÌáÊ¾",typename+" ÖØ¸´·ÖÅä")
					return
				end if
			next
		elseif row < ll_RowCount then
			if row = 1 then
				for ll_RowNow = 2 to ll_RowCount 
					typename = tab_1.tabpage_1.dw_1.getitemstring(ll_RowNow,'typename')
					if data = typename then
						MessageBox("ÌáÊ¾",typename+" ÖØ¸´·ÖÅä")
						return
					end if
				next
			else
				for ll_RowNow = 1 to row - 1 
					typename = tab_1.tabpage_1.dw_1.getitemstring(ll_RowNow,'typename')
					if data = typename then
						MessageBox("ÌáÊ¾",typename+" ÖØ¸´·ÖÅä")
						return
					end if
				next
				for ll_RowNow = row + 1 to ll_RowCount
					typename = tab_1.tabpage_1.dw_1.getitemstring(ll_RowNow,'typename')
					if data = typename then
						MessageBox("ÌáÊ¾",typename+" ÖØ¸´·ÖÅä")
						return
					end if
				next
			end if
		end if
	end if
end if
choose case dwo.name
	case 'typename'
		typename = tab_1.tabpage_1.dw_1.getitemstring(row,'typename')
		if isnull(typename) then typename = ''
		select jymlid,jylbid,lbid,sh into :jymlid,:jylbid,:lbid,:sh from view_bgml_total where typename like :typename;
		setitem(this,row,'jymlid',jymlid)
		setitem(this,row,'jylbid',jylbid)
		setitem(this,row,'lbid',lbid)
		setitem(this,row,'sh',sh)
end choose
end event

