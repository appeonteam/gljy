public subroutine uf_ddlb (string str, dropdownlistbox ddlb);string ls_sheng,ls_shi,ls_quxian
choose case str
	case 'sheng'
		ls_sheng = '__0000'
		ls_shi = '000000'
		ls_quxian = '000000'
	case 'shi'
		ls_sheng = '____00'
		ls_shi = '__0000'
		ls_quxian = '000000'
	case 'quxian'
		ls_sheng = '______'
		ls_shi = '____00'
		ls_quxian = '__0000'
end choose

datastore lds_1
lds_1 = create datastore
lds_1.dataobject = 'dat_xzdm'
lds_1.settransobject(sqlca)
lds_1.retrieve(ls_sheng,ls_shi,ls_quxian)

long ll_row_count
ll_row_count = lds_1.rowcount()

if ll_row_count > 0 then
	string ls_mc,ls_id
	int i
	ddlb.reset()
	for i = 1 to ll_row_count
		ls_mc = lds_1.getitemstring(i,'xzmc')
		ls_id = lds_1.getitemstring(i,'xzid')
		ddlb.additem(ls_mc + '(' + ls_id + ')')
	next
end if

destroy lds_1

end subroutine

public subroutine fun_a_bgml_tz (integer li_i);choose case li_i
	case 0
		temp_lbid = ''
		string ls_id,ls_jytype,ls_mark,ls_sh
		DECLARE temp1 CURSOR FOR
		SELECT id,jytype,mark,sh
		FROM a_bgml where id > '2111' ORDER BY id; 
		OPEN temp1;
		FETCH temp1 INTO :ls_id,:ls_jytype,:ls_mark,:ls_sh;
		do while sqlca.sqlcode = 0
			if isnull(ls_mark) or ls_mark = '' then
			else	
				temp_lbid = temp_lbid + ls_jytype + '/' + ls_mark + '/' + + ls_sh + ','
			end if
			DELETE FROM a_bgml WHERE id = :ls_id;
		FETCH temp1 INTO :ls_id,:ls_jytype,:ls_mark,:ls_sh;
		LOOP
		CLOSE temp1;	
	case 1
		long i,j,li_temp,lj_temp
		string temp_id
		string record[],temp_record[]
		for i = 1 to len(temp_lbid)
			 li_temp = pos(temp_lbid,',')
			 record[i] = left(temp_lbid,li_temp - 1)
			 temp_lbid = right(temp_lbid,len(temp_lbid) - li_temp)
			 temp_id = record[i]
			 for j = 1 to len(temp_id)
				  lj_temp = pos(temp_id,'/')
				  temp_record[j] = left(temp_id,lj_temp - 1)
				  temp_id = right(temp_id,len(temp_id) - lj_temp)
			  next
			  update a_bgml set mark = :temp_record[2],sh = :temp_record[3] where jytype like :temp_record[1];
		next
end choose
end subroutine

public subroutine fun_jhsh ();///×ßÈÎÎñµÄ¸³ÖµÈ»ºó¼Æ»®µÇ¼ÇÊ±ºòÖ»¿´¼ûÕâÐ©¸³ÖµµÄ
long i,li_temp,li_num
string record[]
string rw_setup
string temp_setup
select rw into :rw_setup from a_jydw;
if rw_setup = '' or isnull(rw_setup) then
else
//	select count(*) into :li_num from a_bgml where jhsh = '1';
//	if li_num = 0 then
		temp_setup = rw_setup
		for i = 1 to len(rw_setup)
			li_temp = pos(temp_setup,',')
			if li_temp > 0 then
				record[i] = left(temp_setup,li_temp - 1)
				temp_setup = right(temp_setup,len(temp_setup) - li_temp)
				update a_bgml set jhsh = '1' where jytype like :record[i];
			end if
		next
//	end if
end if
long ll_count = 0
string delsql,mysql,myindex,modsql
// Ê×ÏÈÅÐ¶ÏÏµÍ³Îªsqlserver°æ»¹ÊÇsybase°æ
string mark = 'sybase'
if sqlca.dbms="MSS (Msoft) SQL Server 6.0" then mark = 'sqlserver'
if mark = 'sqlserver' then
	delsql = "drop view djylrq.view_bgml_total"
	execute immediate :delsql using sqlca;
	mysql = "CREATE VIEW djylrq.view_bgml_total as select id, jymk, jytype, typename, lbid, mark, " + &
	"(CASE WHEN (Len(jytype) = 2) THEN LEFT(jytype,1) else LEFT(jytype,2) END) as jymlid,  " + &
	"RIGHT(jytype,1) as jylbid,(CASE WHEN (LEFT(lbid, 2) = 'rq') THEN '10' WHEN (LEFT(lbid, 2) = 'gl')  " + &
		"THEN '11' WHEN (LEFT(lbid, 2) = 'gd') THEN '12' WHEN (LEFT(lbid, 2) = 'qp')  " + &
		"THEN '13' WHEN (LEFT(lbid, 2) = 'sz') THEN '14' WHEN (LEFT(lbid, 2) = 'aq')  " + &
		"THEN '15' WHEN (LEFT(lbid, 2) = 'ws') THEN '16' WHEN (LEFT(lbid, 2) = 'dt')  " + &
		"THEN '17' WHEN (LEFT(lbid, 2) = 'qz') THEN '18' WHEN (LEFT(lbid, 2) = 'cc')  " + &
		"THEN '19' WHEN (LEFT(lbid, 2) = 'sd') THEN '20' WHEN (LEFT(lbid, 2) = 'yl')  " + &
		"THEN '21' WHEN (LEFT(lbid, 2) = 'qt') THEN '22' ELSE '' END) as sh,jhsh as jhsh FROM a_bgml" 
	execute immediate :mysql using sqlca;
else
	delsql = "drop view view_bgml_total"
	execute immediate :delsql using sqlca;
	mysql = "CREATE VIEW view_bgml_total as select id, jymk, jytype, typename, lbid, mark, " + &
	        "jymlid, jylbid, sx as sh,jhsh as jhsh FROM a_bgml" 
	execute immediate :mysql using sqlca;
end if	
end subroutine

public subroutine fun_glc ();//½õÖÝµØÇøÂëÖ®ºó·¢ÏÖÓÐµÄ¼Ò²»ÊÇµØÇøÂë×îºóÒ»Î»ÊÇ¡°1¡±
string ls_sbdsdm,ry_addrid
long li_num
string cpid
select sbdsdm into :ls_sbdsdm from a_jydw;
ls_sbdsdm = Replace(ls_sbdsdm,6,1,'1')
SELECT COUNT(DISTINCT ry_addrid) into :li_num FROM u_addr_staff;
if li_num = 1 then
	SELECT DISTINCT ry_addrid into :ry_addrid FROM u_addr_staff;
	if ls_sbdsdm = ry_addrid then
	else
		DECLARE temp1 CURSOR FOR
		SELECT cpid
		FROM glc_gg where sbdqm = '' or sbdqm is null ORDER BY cpid; 
		OPEN temp1;
		FETCH temp1 INTO :cpid;
		do while sqlca.sqlcode = 0
			if isnull(cpid) or cpid = '' then
			else	
				update glc_gg set sbdqm = :ry_addrid where cpid like :cpid;
			end if
		FETCH temp1 INTO :cpid;
		LOOP
		CLOSE temp1;
		//////////////////////////////////////////////////////////
		DECLARE temp2 CURSOR FOR
		SELECT cpid
		FROM glc_ylrq where sbdqm = '' or sbdqm is null ORDER BY cpid; 
		OPEN temp2;
		FETCH temp2 INTO :cpid;
		do while sqlca.sqlcode = 0
			if isnull(cpid) or cpid = '' then
			else	
				update glc_ylrq set sbdqm = :ry_addrid where cpid like :cpid;
			end if
		FETCH temp2 INTO :cpid;
		LOOP
		CLOSE temp2;	
		//////////////////////////////////////////////////////////
		DECLARE temp3 CURSOR FOR
		SELECT cpid
		FROM glc_dzgl where sbdqm = '' or sbdqm is null ORDER BY cpid; 
		OPEN temp3;
		FETCH temp3 INTO :cpid;
		do while sqlca.sqlcode = 0
			if isnull(cpid) or cpid = '' then
			else	
				update glc_dzgl set sbdqm = :ry_addrid where cpid like :cpid;
			end if
		FETCH temp3 INTO :cpid;
		LOOP
		CLOSE temp3;	
	end if
end if

end subroutine

public subroutine fun_bb ();string qzjmark,tempstr
long li_num
select qzjmark into :qzjmark from a_jydw;
string ls_sbdsdm,ls_yh,ls_xh
select count(jyid) into :li_num from a_ft where jyid like :ls_sbdsdm;
if li_num = 0 then
	select sbdsdm into :ls_sbdsdm from a_jydw;
	ls_yh = mid(ls_sbdsdm,3,2)
	ls_xh = mid(ls_sbdsdm,5,2)
	insert into a_ft (jyid,yh,xh) values (:ls_sbdsdm,:ls_yh,:ls_xh);	
	choose case gs_jydw
		case 'Î÷°²ÊÐÌØÖÖÉè±¸¼ìÑé¼ì²âÔº'
			tempstr = 'Dj(A),Dk(A),'
		case 'Äµµ¤½­ÊÐÌØÖÖÉè±¸¼ìÑéÑÐ¾¿Ëù'
		   tempstr = 'Dj(B),Dk(B),'
		case '¹óÖÝÊ¡¹øÂ¯Ñ¹Á¦ÈÝÆ÷¼ìÑéÖÐÐÄ'
			tempstr = ':w(A),`aw,\aw,=aw,'
		case '°²Ë³ÊÐ¹øÂ¯Ñ¹Á¦ÈÝÆ÷¼ìÑéËù'
			tempstr = ':w(B),'
	end choose
	qzjmark = qzjmark + tempstr
	update a_jydw set qzjmark = :qzjmark;
end if
end subroutine

