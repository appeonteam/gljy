event selectionchanged;ii_rowno = 0
ls_name = ''
ls_flid = ''
ls_mkid = ''
string lds_strl,condstr
string sqdw,gzfw,pzzh,ls_jydwdz,ls_yzbm,ls_lxdh,ls_fax,ls_http,ls_mail
string flagmark1,flagmark2,sjshmark,qzjmark,add3,add4,add5,qzjorder 
blob pic,pic_temp
int fn,po
string ls_bmp
/////////////////////////////////////////////////////////////////////////				
if gs_zhmark = '8' or gs_zhmark = '3' then tab_1.tabpage_5.enabled = true
/////////////////////////////////////////////////////////////////////////
choose case newindex
	case 2
		if ib_pzdw = false then
			select sqdw,gzfw,pzzh,jydwdz,yzbm,lxdh,fax,http,mail
			into  :sqdw,:gzfw,:pzzh,:ls_jydwdz,:ls_yzbm,:ls_lxdh,:ls_fax,:ls_http,:ls_mail
			from  a_jydw ;
			tab_1.tabpage_2.sle_sqdw.text = sqdw
			tab_1.tabpage_2.mle_gzfw.text = gzfw
			tab_1.tabpage_2.sle_pzzh.text = pzzh
			tab_1.tabpage_2.sle_jydwdz.text = ls_jydwdz
			tab_1.tabpage_2.sle_yzbm.text = ls_yzbm
			tab_1.tabpage_2.sle_lxdh.text = ls_lxdh
			tab_1.tabpage_2.sle_fax.text = ls_fax
			tab_1.tabpage_2.sle_http.text = ls_http
			tab_1.tabpage_2.sle_mail.text = ls_mail
			ib_pzdw = true
			ll_num = ll_num + 1
		end if
	case 3
		//////////////////////////////////////////
		string ls_qm
		ls_qm = 'c:\jyoa\qm.bmp'
		if FileExists(ls_qm) then FileDelete(ls_qm)
		//////////////////////////////////////////
		if ib_qtzl = false then
			select flagmark1,flagmark2,sjshmark,qzjmark,add3,add4,add5,qzjorder
			into  :flagmark1,:flagmark2,:sjshmark,:qzjmark,:add3,:add4,:add5,:qzjorder 
			from  a_jydw ;
			tab_1.tabpage_6.ddlb_ylrq_1.text = f_ddlb('ylrq','1',mid(add3,1,1))
			tab_1.tabpage_6.ddlb_ylrq_2.text = f_ddlb('ylrq','2',mid(add3,2,1))
			tab_1.tabpage_6.ddlb_ylrq_3.text = f_ddlb('ylrq','3',mid(add3,3,1))
			
			tab_1.tabpage_6.ddlb_qcgc_1.text = f_ddlb('qcgc','1',mid(add4,1,1))
			tab_1.tabpage_6.ddlb_qcgc_2.text = f_ddlb('qcgc','2',mid(add4,2,1))
			tab_1.tabpage_6.ddlb_qcgc_3.text = f_ddlb('qcgc','3',mid(add4,3,1))
	      
		   /////////ÆðÖØ»ú±¨¸æÄ£Ê½
			if qzjorder = 'xmb' then
				tab_1.Tabpage_6.rb_new.Checked = true
				tab_1.Tabpage_6.rb_old.Checked = false
			else
				tab_1.Tabpage_6.rb_new.Checked = false
				tab_1.Tabpage_6.rb_old.Checked = true
			end if
			//°²È«·§±¨¸æÀàÐÍ 0¡ª¡ªÒ»ÆªÒ»·§1¡ª¡ªÒ»ÆªÎå·§
			if add5 = '1' then
				tab_1.tabpage_6.rb_aqf_no.checked=false
				tab_1.tabpage_6.rb_aqf_yes.checked=true
			else
				tab_1.tabpage_6.rb_aqf_no.checked=true
				tab_1.tabpage_6.rb_aqf_yes.checked=false
			end if
			//±¨¸æËù±êÖ¾ 1 ¡ª¡ªÓÐ£¬0¡ª¡ªÃ»ÓÐ
			if flagmark1 = '1' then 
				tab_1.tabpage_6.rb_flagmark1_yes.checked = true
				tab_1.tabpage_6.rb_flagmark1_no.checked = false
			else
				tab_1.tabpage_6.rb_flagmark1_yes.checked = false
				tab_1.tabpage_6.rb_flagmark1_no.checked = true
			end if
