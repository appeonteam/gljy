	case 'ÆäËü¼ìÑé'
		ls_mkid = 'qj'
end choose
		
DataWindowChild child
int code
code = tab_1.tabpage_8.dw_3.getchild('typename',child)
string id
id = ls_flid + '%'
if ls_mk = 'È«²¿' then
	condstr = " select typename,id,jytype from view_bgml_total where lbid like  '"+ id + "' order by lbid"
else
	condstr = " select typename,id,jytype from view_bgml_total where lbid like  '"+ id + "' and jymk like '"+ ls_mkid + "' order by lbid"
end if
child.settransobject(sqlca)
child.setsqlselect(condstr)
child.retrieve()
end event

