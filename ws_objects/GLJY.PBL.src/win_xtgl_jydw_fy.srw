			DECLARE a_jykey CURSOR FOR
			SELECT ryid
			FROM a_jykey
			WHERE rysp = '1' ORDER BY ryid;
			OPEN a_jykey;
			FETCH a_jykey INTO :ryid;
			do while sqlca.sqlcode = 0
