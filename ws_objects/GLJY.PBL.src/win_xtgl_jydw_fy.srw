		 l1 = trim(getitemstring(tab_1.tabpage_8.dw_3,i,'l1'))
		 s2 = trim(getitemstring(tab_1.tabpage_8.dw_3,i,'s2'))
		 l2 = trim(getitemstring(tab_1.tabpage_8.dw_3,i,'l2'))
		 s3 = trim(getitemstring(tab_1.tabpage_8.dw_3,i,'s3'))
		 l3 = trim(getitemstring(tab_1.tabpage_8.dw_3,i,'l3'))
		 s4 = trim(getitemstring(tab_1.tabpage_8.dw_3,i,'s4'))
		 lfrom = trim(getitemstring(tab_1.tabpage_8.dw_3,i,'lfrom'))
		 llen = getitemnumber(tab_1.tabpage_8.dw_3,i,'llen')
		 
		 if isnull(s1) or s1 = "" then s1 = ""
		 if isnull(l1) or l1 = "" or l1 = 'w' then l1 = ""
		 if isnull(s2) or s2 = "" then s2 = ""
		 if isnull(l2) or l2 = "" or l2 = 'w' then l2 = ""
		 if isnull(s3) or s3 = "" then s3 = ""
		 if isnull(l3) or l3 = "" or l3 = 'w' then l3 = ""
		 if isnull(s4) or s4 = "" then s4 = ""
		 if isnull(llen) then llen = 0
		 
		 if jymlid = "" or isnull(jymlid) then
			 messagebox("ÏµÍ³ÌáÊ¾","µÚ" + string(i) + "ÐÐÇë¼ì²é£¬¼ìÑé°¸Àý±àºÅ¹æÔò£¬Éè±¸Àà±ð±ØÐèÑ¡Ôñ£¡") 
			 return
		 end if
		 if jylbid = "" or isnull(jylbid) then
			 messagebox("ÏµÍ³ÌáÊ¾","µÚ" + string(i) + "ÐÐÇë¼ì²é£¬¼ìÑé°¸Àý±àºÅ¹æÔò£¬¼ìÑéÀà±ð±ØÐèÑ¡Ôñ£¡") 
			 return
		 end if
			 
		 if l1 = 'l' or l2 = 'l' or l3 = 'l' then
			 if lfrom = "" or isnull(lfrom) or llen <= 0 then
				  messagebox("ÏµÍ³ÌáÊ¾","µÚ" + string(i) + "¼ìÑé°¸Àý±àºÅ¹æÔò£¬ÐÐÁ÷Ë®ºÅ³õÊ¼»¯Öµ»òÎ»ÊýÐèÌîÐ´£¡")
				  return
			 else
				  if len(lfrom) = len(string(long(lfrom))) then
					  for j = len(lfrom) to llen - 1
							lfrom = ' ' + lfrom
					  next
					  tab_1.tabpage_8.dw_3.setitem(i,'lfrom',lfrom)
					  tab_1.tabpage_8.dw_3.accepttext()
				  else
					  if llen <> len(lfrom) then
						  messagebox("ÏµÍ³ÌáÊ¾","µÚ" + string(i) + "¼ìÑé°¸Àý¹æÔò£¬ÐÐÇë¼ì²é£¬Á÷Ë®ºÅÎ»Êý£¡")
						  return
					  end if
				  end if
			 end if
		 end if	 
		 if l1 = 'l' then ll1 = llen
		 if l2 = 'l' then ll2 = llen
		 if l3 = 'l' then ll3 = llen
		 if l1 = 'n' then ll1 = 4*len(l1)
		 if l2 = 'n' then ll2 = 4*len(l2)
		 if l3 = 'n' then ll3 = 4*len(l3)
		 if l1 = 'j' then ll1 = 3*len(l1)
		 if l2 = 'j' then ll2 = 3*len(l2)
		 if l3 = 'j' then ll3 = 3*len(l3)	 
	//	 if len(s1+l1+s2+l2+s3+l3+s4) + llen > 21 then 
		if len(s1) + ll1 + len(s2) + ll2 + len(s3) + ll3 + len(s4)  > 20 then	
			messagebox("ÏµÍ³ÌáÊ¾","µÚ" + string(i) + "ÐÐÇë¼ì²é£¬¼ìÑé°¸Àý¶¨ÒåÒÑ³¬³ö20Î»£¡") 
			return
		 end if
	next
	if tab_1.tabpage_8.dw_3.update() = 1 then
		ii_temp = ii_temp + 1
		commit;
	else
		rollback;
	end if
end if
