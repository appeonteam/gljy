////////µ½ÆÚÉè±¸
if mark = 'sqlserver' then 
   delsql = "drop view djylrq.view_sbdq_total"
	execute immediate :delsql using sqlca;
	mysql = "CREATE view view_sbdq_total(jyid,cpid,jyml,jylb,jytype,sydw,djid,sb_zcdm,nextyear,"+&
	        "nextmonth,nextday,bgid,jyyear,jymonth,jyday,jyjl,rymc,zcid,jydate,bs) AS select b_jy_total.jyid,b_jy_total.cpid,"+&
			  "b_jy_total.jyml,b_jy_total.jylb,b_jy_total.jytype,b_jy_total.sydw,b_jy_total.djid,b_jy_total.sb_zcdm,"+&
			  "b_jy_total.nextyear,b_jy_total.nextmonth,b_jy_total.nextday,b_jy_total.bgid,b_jy_total.jyyear,b_jy_total.jymonth,b_jy_total.jyday,"+&
			  "b_jy_total.jyjl,b_jy_total.rymc,b_jy_total.zcid,b_jy_total.jydate,(case when datediff(day,(select convert(varchar(10),getdate(),120) from a_jydw),b_jy_total.nextyear + '-' + b_jy_total.nextmonth + '-' + b_jy_total.nextday) <= (select yjday from a_zqsd where mcsd = 'µ½ÆÚÉè±¸Ê±¼äÉè¶¨') then 1 when datediff(day,(select convert(varchar(10),getdate(),120) from a_jydw),b_jy_total.nextyear + '-' + b_jy_total.nextmonth + '-' + b_jy_total.nextday) <0 then 2 else 0 end) "+&
			  "from b_jy_total where b_jy_total.nextyear<>'' and nextyear is not null and b_jy_total.nextmonth<>'' and nextmonth is not null and b_jy_total.nextday<>'' and nextday is not null and len(nextyear) = 4 and len(nextmonth)=2 and len(nextday)=2 and isdate(nextyear + '-' +nextmonth + '-' + nextday)=1 "+&
			  "union select b_aj_total.jyid,b_aj_total.cpid,"+&
			  "b_aj_total.jyml,b_aj_total.jylb,b_aj_total.jytype,b_aj_total.sydw,b_aj_total.djid,b_aj_total.sb_zcdm,"+&
			  "b_aj_total.nextyear,b_aj_total.nextmonth,b_aj_total.nextday,b_aj_total.bgid,b_aj_total.jyyear,b_aj_total.jymonth,b_aj_total.jyday,"+&
			  "b_aj_total.jyjl,b_aj_total.rymc,b_aj_total.zcid,b_aj_total.jydate,(case when datediff(day,(select convert(varchar(10),getdate(),120) from a_jydw),b_aj_total.nextyear + '-' + b_aj_total.nextmonth + '-' + b_aj_total.nextday) <= (select yjday from a_zqsd where mcsd = 'µ½ÆÚÉè±¸Ê±¼äÉè¶¨') then 1 when datediff(day,(select convert(varchar(10),getdate(),120) from a_jydw),b_aj_total.nextyear + '-' + b_aj_total.nextmonth + '-' + b_aj_total.nextday) <0 then 2 else 0 end) "+&
			  "from b_aj_total where b_aj_total.nextyear<>'' and nextyear is not null and b_aj_total.nextmonth<>'' and nextmonth is not null and b_aj_total.nextday<>'' and nextday is not null and len(nextyear) = 4 and len(nextmonth)=2 and len(nextday)=2 and isdate(nextyear + '-' +nextmonth + '-' + nextday)=1 "
	execute immediate :mysql using sqlca;//and  datediff(day,(select convert(varchar(10),getdate(),120) from a_jydw),b_jy_total.nextyear + '-' + b_jy_total.nextmonth + '-' + b_jy_total.nextday) >=0
end if
