		"from djylrq.b_jy_total as a,djylrq.t_tzsb_wg_dq1 as b where a.jyid = b.jyid"
	execute immediate :mysql using sqlca;
else
	delsql = "drop view View_wg_new_nrcx"
	execute immediate :delsql using sqlca;
	mysql = "create View View_wg_new_nrcx as select a.jyid as jyid,a.djid as djid,a.sb_zcdm as sb_zcdm,a.nh as nh,a.bgid as bgid," + &
      "a.jyml as jyml,a.jylb as jylb,a.cpmc as cpmc,a.sydw as sydw,a.spmc as spmc,a.ryid as ryid," + &
		"a.rymc as rymc,a.rybm as rybm,a.jydate as jydate,a.nextdate as nextdate," + &
		"a.shib as shib,a.shmark as shmark,a.shtui as shtui,a.shzb as shzb,a.shsp as shsp,a.sjid as sjid," + &
		"a.shwang as shwang,a.nextyear as nextyear,a.nextmonth as nextmonth,a.nextday as nextday," + &
		"b.sbsydw as sbsydw,b.sydwdz as sydwdz,b.zzjgdm as zzjgdm,b.sbsydd as sbsydd,b.aqglry as aqglrq,b.lxdh as rydh,b.dwnbh as dwnbh," + &
		"b.sblb as sblb,b.sbpz as sbpz,b.sydjzbh as sydjh,b.zzdw as zzdw,b.zzckzbh as zzxkzbh,b.zzrq as zzrq,b.ccbh as ccbh,b.sbxh as sbxh," + &
		"b.gzjb as gzjb,b.zdqzl as zdqzl,b.edqzl as qzjxzh,b.zdqzlj as zdqzlj,b.qsgd as qsgd,b.qssd as qssd,b.dcyxsd as dcyxsd,b.xcyxsd as xcyxsd," + &
		"b.sh as sh,b.shday as shrq,b.pz as pz,b.pzday as pzrq,b.jyjl as jyjl,b.bbxx as bbxx " + &
		"from b_jy_total as a,t_tzsb_wg_dq1 as b where a.jyid = b.jyid"
	execute immediate :mysql using sqlca;
end if
end subroutine

