if mark = 'sqlserver' then 
   delsql = "drop view djylrq.view_gzltj_total"
	execute immediate :delsql using sqlca;
	mysql = "CREATE VIEW djylrq.view_gzltj_total(jyid,bgbh,"+&
		"jyml,jylb,jytype,jydate,shmark,jyry,weekend,bs,sbmc,shtui,shsp,shwang,sydw,nh) AS SELECT "+&
		"jyid,bgid,jyml,jylb,jytype,jydate,shmark,rymc,"+&
		"(select count(*) from a_weekend where weekend between jydate and pzdate),"+&
		"(case when datediff(day,jydate,pzdate) > ((select zqday from a_zqsd where mcsd = '³ö¾ß±¨¸æÊ±¼äÉè¶¨') + (select count(*) from a_weekend where weekend between jydate and pzdate)) then 1 "+&
		"else 0 end),sbmc,shtui,shsp,shwang,sydw,nh FROM b_jy_total where pzdate <> '0000-00-00' and jydate <> '0000-00-00' "+&
		"union select jyid,bgid,"+&
		"jyml,jylb,jytype,jydate,shmark,rymc,"+&
		"(select count(*) from a_weekend where weekend between jydate and (case when (jydate <> '0000-00-00' and pzdate = '0000-00-00') then (select convert(varchar(10),getdate(),120) from a_jydw) end)),"+&
		"(case when datediff(day,jydate,(case when (jydate <> '0000-00-00' and pzdate = '0000-00-00') then (select convert(varchar(10),getdate(),120) from a_jydw) end)) > ((select zqday from a_zqsd where mcsd = '³ö¾ß±¨¸æÊ±¼äÉè¶¨') + (select count(*) from a_weekend where weekend between jydate and (case when (jydate <> '0000-00-00' and pzdate = '0000-00-00') then (select convert(varchar(10),getdate(),120) from a_jydw) end))) then 1 "+&
		"else 0 end),sbmc,shtui,shsp,shwang,sydw,nh FROM b_jy_total where pzdate = '0000-00-00' and jydate <> '0000-00-00'"+&
		"union select "+&
