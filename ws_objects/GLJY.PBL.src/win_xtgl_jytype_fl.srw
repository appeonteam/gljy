DECLARE sddj_bgml CURSOR FOR
SELECT id,jytype
FROM a_bgml WHERE jymk = 'dj' and (lbid = '' or lbid is null) and (mark = '' or mark is null) and (jytype like 'Nn' &
						or jytype like 'Xn' &
						or jytype LIKE 'Yn' &
						or jytype LIKE '@c' ) ;   
OPEN sddj_bgml;
FETCH sddj_bgml INTO :id,:jytype;
do while sqlca.sqlcode = 0
	if isnull(jytype) or jytype = '' then
	else
		choose case jytype
			case 'Nn'
				update a_bgml set lbid = 'sd101' where id like :id and jytype = 'Nn';
			case 'Xn'
				update a_bgml set lbid = 'sd102' where id like :id and jytype = 'Xn';
			case 'Yn'
				update a_bgml set lbid = 'sd103' where id like :id and jytype = 'Yn';
			case '@c'
				update a_bgml set lbid = 'sd104' where id like :id and jytype = '@c';
		end choose
	end if
FETCH sddj_bgml INTO :id,:jytype;
LOOP
CLOSE sddj_bgml;
/////////////////////////////////////////////////////////////////
DECLARE sdaj_bgml CURSOR FOR
SELECT id,jytype
FROM a_bgml WHERE jymk = 'aj' and (lbid = '' or lbid is null) and (mark = '' or mark is null) and (jytype like 'No' &
						or jytype like 'Xo' &
						or jytype LIKE 'Yo' &
						or jytype LIKE '@d' ) ;   
OPEN sdaj_bgml;
FETCH sdaj_bgml INTO :id,:jytype;
do while sqlca.sqlcode = 0
	if isnull(jytype) or jytype = '' then
	else
		choose case jytype
			case 'No'
				update a_bgml set lbid = 'sd101' where id like :id and jytype = 'No';
			case 'Xo'
				update a_bgml set lbid = 'sd102' where id like :id and jytype = 'Xo';
			case 'Yo'
				update a_bgml set lbid = 'sd103' where id like :id and jytype = 'Yo';
			case '@d'
				update a_bgml set lbid = 'sd104' where id like :id and jytype = '@d';
		end choose
	end if
FETCH sdaj_bgml INTO :id,:jytype;
LOOP
CLOSE sdaj_bgml;
//////////////////////////////////////////////////////////////////////////////
IF sqlca.sqlcode <>0 THEN
	MessageBox ('','¸üÐÂÊ§°Ü')
	return
else
	li_count = li_count + 1
END IF
end subroutine

