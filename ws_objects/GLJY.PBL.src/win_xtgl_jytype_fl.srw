jymlid = left(orig_jytype,len(orig_jytype)-1)

//update a_bgml set mark = :orig_lbid where typename like :orig_typename;
choose case Ii_UseIndex
	case 1
      choose case jymlid
			case '6','6b','6c'
				select max(lbid) into :max_lbid from a_bgml WHERE jytype LIKE '6%' and jymk = 'dj';
				if max_lbid = '' or isnull(max_lbid) then
					max_lbid = 'rq' + 'A' + '100'
				else
					max_lbid = string(long(right(max_lbid,3)) + 1) 
				end if
				update a_bgml set lbid = :max_lbid where typename like :orig_typename and jytype like :orig_jytype;
				
				tab_1.tabpage_1.dw_dj.DeleteRow(orig_NowRow)
		end choose
