event clicked;string lds_strl,condstr
if orig_NowRow < 1 then
	return
end if
string jymlid,max_lbid
//jytype like '6%' &
//						or jytype like '?%' &
//						or jytype LIKE '+%' &
//						or jytype LIKE 'K%' &
//						or jytype LIKE 'J%' &
//						or jytype LIKE 'O%' &
//						or jytype LIKE 'P%' &
//						or jytype LIKE '1%' &
//						or jytype LIKE '2%' &
//						or jytype LIKE ';%') ;   
