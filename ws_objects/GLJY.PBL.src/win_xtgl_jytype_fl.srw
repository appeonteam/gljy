public subroutine fun_rq ();string id,jytype
DECLARE rqdj_bgml CURSOR FOR
SELECT id,jytype
FROM a_bgml WHERE jymk = 'dj' and (lbid = '' or lbid is null) and (mark = '' or mark is null) and (jytype like '6%' &
						or jytype like '?%' &
						or jytype LIKE '+%' &
						or jytype LIKE 'K%' &
						or jytype LIKE 'J%' &
						or jytype LIKE 'O%' &
						or jytype LIKE 'P%' &
						or jytype LIKE '1%' &
						or jytype LIKE '2%' &
						or jytype LIKE ';%') ;   
OPEN rqdj_bgml;
FETCH rqdj_bgml INTO :id,:jytype;
do while sqlca.sqlcode = 0
	if isnull(jytype) or jytype = '' then
	else
		choose case jytype
			case '6s'
				update a_bgml set lbid = 'rq101' where id like :id and jytype = '6s';
			case '6n'
				update a_bgml set lbid = 'rq102' where id like :id and jytype = '6n';
			case '6]'
				update a_bgml set lbid = 'rq103' where id like :id and jytype = '6]';
			case '61'
				update a_bgml set lbid = 'rq104' where id like :id and jytype = '61';
			case '6bs'
				update a_bgml set lbid = 'rq105' where id like :id and jytype = '6bs';
			case '6cs'
				update a_bgml set lbid = 'rq106' where id like :id and jytype = '6cs';	
			case '?s'
				update a_bgml set lbid = 'rq201' where id like :id and jytype = '?s';
			case '?n'
				update a_bgml set lbid = 'rq202' where id like :id and jytype = '?n';	
			case '+s'
				update a_bgml set lbid = 'rq301' where id like :id and jytype = '+s';	
			case 'Ks'
				update a_bgml set lbid = 'rq401' where id like :id and jytype = 'Ks';
			case 'Js'
				update a_bgml set lbid = 'rq501' where id like :id and jytype = 'Js';
			case 'Os'
				update a_bgml set lbid = 'rq601' where id like :id and jytype = 'Os';
			case 'On'
				update a_bgml set lbid = 'rq602' where id like :id and jytype = 'On';
			case 'Oc'
				update a_bgml set lbid = 'rq603' where id like :id and jytype = 'Oc';
			case 'Pc'
				update a_bgml set lbid = 'rq701' where id like :id and jytype = 'Pc';
			case '1c'
				update a_bgml set lbid = 'rq801' where id like :id and jytype = '1c';
			case '2c'
				update a_bgml set lbid = 'rq901' where id like :id and jytype = '2c';
			case ';c'
				update a_bgml set lbid = 'rqa01' where id like :id and jytype = ';c';
		end choose
	end if
FETCH rqdj_bgml INTO :id,:jytype;
LOOP
CLOSE rqdj_bgml;
/////////////////////////////////////////////////////////////////
DECLARE rqaj_bgml CURSOR FOR
SELECT id,jytype
FROM a_bgml WHERE jymk = 'aj' and (lbid = '' or lbid is null) and (mark = '' or mark is null) and (jytype like '6%' &
						or jytype LIKE 'O%') ;   
OPEN rqaj_bgml;
FETCH rqaj_bgml INTO :id,:jytype;
do while sqlca.sqlcode = 0
	if isnull(jytype) or jytype = '' then
	else
		choose case jytype
			case '6d'
				update a_bgml set lbid = 'rq107' where id like :id and jytype = '6d';
			case 'Od'
				update a_bgml set lbid = 'rq604' where id like :id and jytype = 'Od';
		end choose
	end if
FETCH rqaj_bgml INTO :id,:jytype;
LOOP
CLOSE rqaj_bgml;
/////////////////////////////////////////////////////////////////
DECLARE rqjj_bgml CURSOR FOR
SELECT id,jytype
FROM a_bgml WHERE jymk = 'jj' and (lbid = '' or lbid is null) and (mark = '' or mark is null) and (jytype like '6%' &
						or jytype like 'O%' &
						or jytype LIKE ']a%' &
						or jytype LIKE '|a%' &
						or jytype LIKE '(a%' &
						or jytype LIKE '^a%' &
						or jytype LIKE '7w'  &
						or jytype LIKE ':w') ;   
OPEN rqjj_bgml;
FETCH rqjj_bgml INTO :id,:jytype;
do while sqlca.sqlcode = 0
	if isnull(jytype) or jytype = '' then
	else
		choose case jytype
			case '6p'
				update a_bgml set lbid = 'rq108' where id like :id and jytype = '6p';
			case '6w'
				update a_bgml set lbid = 'rq109' where id like :id and jytype = '6w';
			case '6u'
				update a_bgml set lbid = 'rq110' where id like :id and jytype = '6u';
			case '6v'
				update a_bgml set lbid = 'rq111' where id like :id and jytype = '6v';
         case 'Op'
				update a_bgml set lbid = 'rq605' where id like :id and jytype = 'Op';
			case 'Ow'
				update a_bgml set lbid = 'rq606' where id like :id and jytype = 'Ow';
			case 'Ou'
				update a_bgml set lbid = 'rq607' where id like :id and jytype = 'Ou';
			case 'Ov'
				update a_bgml set lbid = 'rq608' where id like :id and jytype = 'Ov';
         case ']ap'
				update a_bgml set lbid = 'rqb01' where id like :id and jytype = ']ap';
			case ']aw'
				update a_bgml set lbid = 'rqb02' where id like :id and jytype = ']aw';
         case '|ap'
				update a_bgml set lbid = 'rqc01' where id like :id and jytype = '|ap';
			case '|aw'
				update a_bgml set lbid = 'rqc02' where id like :id and jytype = '|aw';
         case '(ap'
				update a_bgml set lbid = 'rqd01' where id like :id and jytype = '(ap';
			case '(aw'
				update a_bgml set lbid = 'rqd02' where id like :id and jytype = '(aw';
			case '^ap'
				update a_bgml set lbid = 'rqe01' where id like :id and jytype = '^ap';
			case '^aw'
				update a_bgml set lbid = 'rqe02' where id like :id and jytype = '^aw';
			case '6ap'
				update a_bgml set lbid = 'rqf01' where id like :id and jytype = '6ap';
			case '6dp'
				update a_bgml set lbid = 'rqg01' where id like :id and jytype = '6dp';
			case '7w'
				update a_bgml set lbid = 'rqh01' where id like :id and jytype = '7w';
			case ':w'
				update a_bgml set lbid = 'rqi01' where id like :id and jytype = ':w';
		end choose
	end if
FETCH rqjj_bgml INTO :id,:jytype;
LOOP
CLOSE rqjj_bgml;
/////////////////////////////////////////////////////////////////
DECLARE rqjk_bgml CURSOR FOR
SELECT id,jytype
FROM a_bgml WHERE jymk = 'jk' and (lbid = '' or lbid is null) and (mark = '' or mark is null) and (jytype like 'Le' or jytype like '4%') ;   
OPEN rqjk_bgml;
FETCH rqjk_bgml INTO :id,:jytype;
do while sqlca.sqlcode = 0
	if isnull(jytype) or jytype = '' then
	else
		choose case jytype
			case 'Le'
				update a_bgml set lbid = 'rqj01' where id like :id and jytype = 'Le';
			case '4p'
				update a_bgml set lbid = 'rqk01' where id like :id and jytype = '4p';
			case '4w'
				update a_bgml set lbid = 'rqk02' where id like :id and jytype = '4w';
		end choose
	end if
FETCH rqjk_bgml INTO :id,:jytype;
LOOP
CLOSE rqjk_bgml;
//////////////////////////////////////////////////////////////////////////////
IF sqlca.sqlcode <>0 THEN
	MessageBox ('','¸üÐÂÊ§°Ü')
	return
else
	li_count = li_count + 1
END IF

end subroutine

public subroutine fun_gl ();string id,jytype
DECLARE gldj_bgml CURSOR FOR
SELECT id,jytype
FROM a_bgml WHERE jymk = 'dj' and (lbid = '' or lbid is null) and (mark = '' or mark is null) and (jytype like 'A%' &
						or jytype like 'D%' &
						or jytype like 'F%' &
						or jytype LIKE '(%' &
						or jytype LIKE ',%' &
						or jytype LIKE '|%') ;   
OPEN gldj_bgml;
FETCH gldj_bgml INTO :id,:jytype;
do while sqlca.sqlcode = 0
	if isnull(jytype) or jytype = '' then
	else
		choose case jytype
			case 'Aa'
				update a_bgml set lbid = 'gl101' where id like :id and jytype = 'Aa';
			case 'Ab'
				update a_bgml set lbid = 'gl102' where id like :id and jytype = 'Ab';
			case 'Ai'
				update a_bgml set lbid = 'gl103' where id like :id and jytype = 'Ai';
			case 'Da'
				update a_bgml set lbid = 'gl201' where id like :id and jytype = 'Da';
			case 'Db'
				update a_bgml set lbid = 'gl202' where id like :id and jytype = 'Db';
			case 'Di'
				update a_bgml set lbid = 'gl203' where id like :id and jytype = 'Di';
			case 'Dc'
				update a_bgml set lbid = 'gl204' where id like :id and jytype = 'Dc';
			case 'Fa'
				update a_bgml set lbid = 'gl301' where id like :id and jytype = 'Fa';
			case 'Fb'
				update a_bgml set lbid = 'gl302' where id like :id and jytype = 'Fb';
			case '(c'
				update a_bgml set lbid = 'gl401' where id like :id and jytype = '(c';
			case ',s'
				update a_bgml set lbid = 'gl501' where id like :id and jytype = ',s';
			case ',@'
				update a_bgml set lbid = 'gl502' where id like :id and jytype = ',@';
			case '|;'
				update a_bgml set lbid = 'gl602' where id like :id and jytype = '|;';	
			case '|@'
				update a_bgml set lbid = 'gl602' where id like :id and jytype = '|@';	
		end choose
	end if
FETCH gldj_bgml INTO :id,:jytype;
LOOP
CLOSE gldj_bgml;
/////////////////////////////////////////////////////////////////
DECLARE glaj_bgml CURSOR FOR
SELECT id,jytype
FROM a_bgml WHERE jymk = 'aj' and (lbid = '' or lbid is null) and (mark = '' or mark is null) and (jytype like 'D%' &
						or jytype LIKE 'F%') ;   
OPEN glaj_bgml;
FETCH glaj_bgml INTO :id,:jytype;
do while sqlca.sqlcode = 0
	if isnull(jytype) or jytype = '' then
	else
		choose case jytype
			case 'Dk'
				update a_bgml set lbid = 'gl205' where id like :id and jytype = 'Dk';
			case 'Dj'
				update a_bgml set lbid = 'gl206' where id like :id and jytype = 'Dj';
			case 'Dr'
				update a_bgml set lbid = 'gl207' where id like :id and jytype = 'Dr';
			case 'D3'
				update a_bgml set lbid = 'gl208' where id like :id and jytype = 'D3';
			case 'Dm'
				update a_bgml set lbid = 'gl209' where id like :id and jytype = 'Dm';
			case 'Fd'
				update a_bgml set lbid = 'gl303' where id like :id and jytype = 'Fd';
		end choose
	end if
FETCH glaj_bgml INTO :id,:jytype;
LOOP
CLOSE glaj_bgml;
/////////////////////////////////////////////////////////////////
DECLARE gljj_bgml CURSOR FOR
SELECT id,jytype
FROM a_bgml WHERE jymk = 'jj' and (lbid = '' or lbid is null) and (mark = '' or mark is null) and (jytype like 'A%' &
						or jytype like 'D%' &
						or jytype LIKE 'F%' &
						or jytype LIKE ')%' &
						or jytype LIKE ',%' &
						or jytype LIKE '|%') ;   
OPEN gljj_bgml;
FETCH gljj_bgml INTO :id,:jytype;
do while sqlca.sqlcode = 0
	if isnull(jytype) or jytype = '' then
	else
		choose case jytype
			case 'Ap'
				update a_bgml set lbid = 'gl104' where id like :id and jytype = 'Ap';
			case 'Aw'
				update a_bgml set lbid = 'gl105' where id like :id and jytype = 'Aw';
			case 'Au'
				update a_bgml set lbid = 'gl106' where id like :id and jytype = 'Au';
			case 'Av'
				update a_bgml set lbid = 'gl107' where id like :id and jytype = 'Av';
			case 'D#'
				update a_bgml set lbid = 'gl210' where id like :id and jytype = 'D#';
         case 'Dp'
				update a_bgml set lbid = 'gl211' where id like :id and jytype = 'Dp';
			case 'Dw'
				update a_bgml set lbid = 'gl212' where id like :id and jytype = 'Dw';
			case 'Du'
				update a_bgml set lbid = 'gl213' where id like :id and jytype = 'Du';
			case 'Dv'
				update a_bgml set lbid = 'gl214' where id like :id and jytype = 'Dv';
			case 'D5'
				update a_bgml set lbid = 'gl215' where id like :id and jytype = 'D5';
			case 'Fp'
				update a_bgml set lbid = 'gl304' where id like :id and jytype = 'Fp';
         case 'Fe'
				update a_bgml set lbid = 'gl305' where id like :id and jytype = 'Fe';
			case ')ap'
				update a_bgml set lbid = 'gl401' where id like :id and jytype = ')ap';
         case ')aw'
				update a_bgml set lbid = 'gl402' where id like :id and jytype = ')aw';
			case ')bw'
				update a_bgml set lbid = 'gl501' where id like :id and jytype = ')bw';
         case 'Dbw'
				update a_bgml set lbid = 'gl601' where id like :id and jytype = 'Dbw';	
			case ',w'
				update a_bgml set lbid = 'gl701' where id like :id and jytype = ',w';
         case ',3'
				update a_bgml set lbid = 'gl702' where id like :id and jytype = ',3';
			case ',5'
				update a_bgml set lbid = 'gl703' where id like :id and jytype = ',5';
			case '|w'
				update a_bgml set lbid = 'gl801' where id like :id and jytype = '|w';
         case '|3'
				update a_bgml set lbid = 'gl802' where id like :id and jytype = '|3';
			case '|5'
				update a_bgml set lbid = 'gl803' where id like :id and jytype = '|5';
		end choose
	end if
FETCH gljj_bgml INTO :id,:jytype;
LOOP
CLOSE gljj_bgml;
/////////////////////////////////////////////////////////////////
DECLARE gljk_bgml CURSOR FOR
SELECT id,jytype
FROM a_bgml WHERE jymk = 'jk' and (lbid = '' or lbid is null) and (mark = '' or mark is null) and jytype like 'Ge' ;   
OPEN gljk_bgml;
FETCH gljk_bgml INTO :id,:jytype;
do while sqlca.sqlcode = 0
	if isnull(jytype) or jytype = '' then
	else
		choose case jytype
			case 'Ge'
				update a_bgml set lbid = 'gl901' where id like :id and jytype = 'Ge';
		end choose
	end if
FETCH gljk_bgml INTO :id,:jytype;
LOOP
CLOSE gljk_bgml;
/////////////////////////////////////////////////////////////////
DECLARE glqj_bgml CURSOR FOR
SELECT id,jytype
FROM a_bgml WHERE jymk = 'qj' and (lbid = '' or lbid is null) and (mark = '' or mark is null) and jytype like 'Zh' ;   
OPEN glqj_bgml;
FETCH glqj_bgml INTO :id,:jytype;
do while sqlca.sqlcode = 0
	if isnull(jytype) or jytype = '' then
	else
		choose case jytype
			case 'Zh'
				update a_bgml set lbid = 'gla01' where id like :id and jytype = 'Zh';
