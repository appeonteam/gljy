DECLARE a_bgml CURSOR FOR
SELECT id,jytype
FROM a_bgml;
OPEN a_bgml;
FETCH a_bgml INTO :id,:jytype;
do while sqlca.sqlcode = 0
	if isnull(jytype) or jytype = '' then
	else
		update a_bgml set lbid = '',mark = '' where id like :id and jytype like :jytype;
	end if
FETCH a_bgml INTO :id,:jytype;
LOOP
