on tab_1.create
this.tabpage_1=create tabpage_1
this.tabpage_2=create tabpage_2
this.tabpage_3=create tabpage_3
this.tabpage_4=create tabpage_4
this.tabpage_5=create tabpage_5
this.Control[]={this.tabpage_1,&
this.tabpage_2,&
this.tabpage_3,&
this.tabpage_4,&
this.tabpage_5}
end on

on tab_1.destroy
destroy(this.tabpage_1)
destroy(this.tabpage_2)
destroy(this.tabpage_3)
destroy(this.tabpage_4)
destroy(this.tabpage_5)
end on

event selectionchanged;string lds_strl,condstr	
Ii_UseIndex = newindex
choose case newindex
	case 2
		if ib_dw_aj = false then
			tab_1.tabpage_2.dw_aj.settransobject(SQLCA)
			lds_strl = tab_1.tabpage_2.dw_aj.getsqlselect()
			condstr = " and (lbid = '' or lbid is null) and (mark = '' or mark is null) order by id"
			tab_1.tabpage_2.dw_aj.setsqlselect(lds_strl + condstr)
			tab_1.tabpage_2.dw_aj.retrieve()
			tab_1.tabpage_2.dw_aj.Object.typename.TabSequence = 0
			tab_1.tabpage_2.dw_aj.Object.jymk.visible = false
			tab_1.tabpage_2.dw_aj.Object.typename.Font.Height = 60		
			ib_dw_aj = true
		end if 
	case 3
		if ib_dw_jj = false then
			tab_1.tabpage_3.dw_jj.settransobject(SQLCA)
			lds_strl = tab_1.tabpage_3.dw_jj.getsqlselect()
			condstr = " and (lbid = '' or lbid is null) and (mark = '' or mark is null) order by id"
			tab_1.tabpage_3.dw_jj.setsqlselect(lds_strl + condstr)
			tab_1.tabpage_3.dw_jj.retrieve()
			tab_1.tabpage_3.dw_jj.Object.typename.TabSequence = 0
			tab_1.tabpage_3.dw_jj.Object.jymk.visible = false
			tab_1.tabpage_3.dw_jj.Object.typename.Font.Height = 60	
			ib_dw_jj = true
		end if 
	case 4
		if ib_dw_jk = false then
			tab_1.tabpage_4.dw_jk.settransobject(SQLCA)
			lds_strl = tab_1.tabpage_4.dw_jk.getsqlselect()
			condstr = " and (lbid = '' or lbid is null) and (mark = '' or mark is null) order by id"
			tab_1.tabpage_4.dw_jk.setsqlselect(lds_strl + condstr)
			tab_1.tabpage_4.dw_jk.retrieve()
			tab_1.tabpage_4.dw_jk.Object.typename.TabSequence = 0
			tab_1.tabpage_4.dw_jk.Object.jymk.visible = false
			tab_1.tabpage_4.dw_jk.Object.typename.Font.Height = 60	
			ib_dw_jk = true
		end if 
	case 5
		if ib_dw_qj = false then
			tab_1.tabpage_5.dw_qj.settransobject(SQLCA)
			lds_strl = tab_1.tabpage_5.dw_qj.getsqlselect()
			condstr = " and (lbid = '' or lbid is null) and (mark = '' or mark is null) order by id"
			tab_1.tabpage_5.dw_qj.setsqlselect(lds_strl + condstr)
			tab_1.tabpage_5.dw_qj.retrieve()
			tab_1.tabpage_5.dw_qj.Object.typename.TabSequence = 0
			tab_1.tabpage_5.dw_qj.Object.jymk.visible = false
			tab_1.tabpage_5.dw_qj.Object.typename.Font.Height = 60	
			ib_dw_qj = true
		end if 
end choose

end event

