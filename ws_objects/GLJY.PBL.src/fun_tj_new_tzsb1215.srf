IF mark = 'sqlserver' THEN
	mysql="CREATE TABLE djylrq.b_ylrqxczhzl_zs(jyid varchar(20) NOT NULL,bgbh varchar(20) null,cpid varchar(20) NULL,"+&
       "sydw varchar(60) null,sgdw varchar(60) null,zzdw varchar(60) null,zzbh varchar(30) null,"+&
       "rqmc varchar(30) null,rqpz varchar(30) null,th varchar(30) null,zhqk varchar(80) null,"+&
		 "yy varchar(4) null,mm varchar(2) null,dd varchar(2) null,jjjg varchar(60) null,"+& 
		 "jydate varchar(20) null,shdate varchar(20) null,spdate varchar(20) null,jyz1 varchar(10) null,"+&
		 "jyz2 varchar(10) null,jyz3 varchar(10) null,jyz4 varchar(10) null,jyz5 varchar(10) null,"+&
		 "jyy varchar(10) null,sh varchar(10) null,pz varchar(10) null,hzzh varchar(30) null);"
		execute immediate :mysql using sqlca;
		myindex = "CREAT UNIQUE INDEX b_ylrqxczhzl_zs_x ON DJYLRQ.b_ylrqxczhzl_zs (JYID);"
		execute immediate :myindex using sqlca;
else
		mysql="CREATE TABLE b_ylrqxczhzl_zs(jyid varchar(20) NOT NULL,bgbh varchar(20) null,cpid varchar(20) NULL,"+&
       "sydw varchar(60) null,sgdw varchar(60) null,zzdw varchar(60) null,zzbh varchar(30) null,"+&
       "rqmc varchar(30) null,rqpz varchar(30) null,th varchar(30) null,zhqk varchar(80) null,"+&
		 "yy varchar(4) null,mm varchar(2) null,dd varchar(2) null,jjjg varchar(60) null,"+& 
		 "jydate varchar(20) null,shdate varchar(20) null,spdate varchar(20) null,jyz1 varchar(10) null,"+&
