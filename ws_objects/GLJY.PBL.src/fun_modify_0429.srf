delsql = "drop view djylrq.View_dtjd_nrcx"
execute immediate :delsql using sqlca;
mysql = "create View djylrq.View_dtjd_nrcx as select a.jyid as jyid,a.djid as djid,a.sb_zcdm as sb_zcdm,a.nh as nh,a.bgid as bgid," + &
	"a.jyml as jyml,a.jylb as jylb,a.sydw as sydw,a.spmc as spmc,a.ryid as ryid," + &
	"a.rymc as rymc,a.rybm as rybm,a.jydate as jydate,a.nextdate as nextdate,a.qz as qz," + &
	"a.shib as shib,a.shmark as shmark,a.shtui as shtui,a.shzb as shzb,a.shsp as shsp,a.sjid as sjid," + &
	"a.shwang as shwang,a.nextyear as nextyear,a.nextmonth as nextmonth,a.nextday as nextday," + &
	"b.sblb as sblb,b.sbmc as sbmc,b.sglb as sglb,b.jyrqks as jyrqks,b.jyrqjs as jyrqjs,b.ggxh as ggxh,b.wbdh as wbdh," + &
	"b.zzdw as zzdw,b.cpbh as cpbh,b.zzrq as zzrq,b.sgdw as sgdw,b.sgdwxkzbh as sgdwxkzbh,b.yhbh as yhbh," + &
	"b.sydjbh as sydjbh,b.azdz as azdz,b.wxbydw as wbdw,b.edzzl as edzzl,b.edsd as edsd,b.kzfs as kzfs,b.cs as cs,b.zs as zs," + &
	"b.sh as sh,b.shrq as shrq,b.pz as pz,b.pzrq as pzrq,b.jyjl as jyjl,b.jyrq as jyrq," + &
	"a.cqdw as cqdw,a.yqmc as yqmc,a.sydd as sydd,a.tsgd as tsgd " + &
	"from djylrq.b_aj_total as a,djylrq.tzsb_dtjd1 as b where a.jyid = b.jyid"
execute immediate :mysql using sqlca;
