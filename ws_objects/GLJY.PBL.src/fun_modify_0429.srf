if mark = 'sqlserver' then
	delsql = "drop view djylrq.view_yjrztdj_nrcx"
	execute immediate :delsql using sqlca;
	mysql = "create view djylrq.view_yjrztdj_nrcx as select a.jyid, a.djid, a.sb_zcdm, a.nh, a.bgid, a.jyml, a.jylb, "+&
				"a.cpmc, a.spmc, a.ryid,a.rymc, a.rybm, a.jydate, a.jyjl, a.nextdate, a.shib, a.shmark, a.shtui, a.shzb,"+&
				"a.shsp,a.sjid, a.jyyear, a.jymonth, a.jyday, a.nextyear, a.nextmonth, a.nextday, a.shwang,"+& 
      		"b.glsydw, b.glxh, b.dh, b.yb, b.cz, b.dz, b.txdz, b.sjdw, b.jyxm, b.jcrq, b.zzrq, b.ccrq,"+& 
      		"b.lxr, b.ztfl, b.qyy + '-' + b.qym + '-' + b.qyd AS qyrq, "+&
      		"b.hysjy + '-' + b.hysjm + '-' + b.hysjd AS hysj, a.sydw, b.fd, b.ngd, b.sywd, b.shname,"+& 
      		"b.shy, b.shm, b.shd, b.jyz1, b.jyz2, b.jyz3, b.jyz4, b.jyz5"+&
      		" FROM djylrq.b_jy_total a INNER JOIN djylrq.b_qj_yjrztgljc b ON a.jyid = b.jyid"
	execute immediate :mysql using sqlca;
else
	delsql = "drop view view_yjrztdj_nrcx"
	execute immediate :delsql using sqlca;
	mysql = "create view djylrq.view_yjrztdj_nrcx as select a.jyid, a.djid, a.sb_zcdm, a.nh, a.bgid, a.jyml, a.jylb, "+&
				"a.cpmc, a.spmc, a.ryid,a.rymc, a.rybm, a.jydate, a.jyjl, a.nextdate, a.shib, a.shmark, a.shtui, a.shzb,"+&
				"a.shsp,a.sjid, a.jyyear, a.jymonth, a.jyday, a.nextyear, a.nextmonth, a.nextday, a.shwang,"+& 
		      "b.glsydw, b.glxh, b.dh, b.yb, b.cz, b.dz, b.txdz, b.sjdw, b.jyxm, b.jcrq, b.zzrq, b.ccrq,"+& 
		      "b.lxr, b.ztfl, b.qyy + '-' + b.qym + '-' + b.qyd AS qyrq, "+&
		      "b.hysjy + '-' + b.hysjm + '-' + b.hysjd AS hysj, a.sydw, b.fd, b.ngd, b.sywd, b.shname,"+& 
		      "b.shy, b.shm, b.shd, b.jyz1, b.jyz2, b.jyz3, b.jyz4, b.jyz5"+&
		      " FROM djylrq.b_jy_total a INNER JOIN djylrq.b_qj_yjrztgljc b ON a.jyid = b.jyid"
