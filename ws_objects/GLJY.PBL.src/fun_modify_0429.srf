if gs_jydw='ÉòÑôÊÐÌØÖÖÉè±¸¼ì²âÑÐ¾¿Ôº' then
	delsql = "drop view djylrq.a_aj_dqm_swts_sy"
	execute immediate :delsql using sqlca;
	modsql = "create view djylrq.a_aj_dqm_swts_sy as select a.jyid as jyid,a.cpid as cpid,a.djid,a.nh,a.bgid,a.jyml,a.jylb,a.jytype,"+&
	"a.sydw,a.spmc,a.ryid,a.rymc,a.rybm,a.jydate,a.jyyear,a.jymonth,a.jyday,a.jyjl,a.shmark,a.shtui,a.newmark,a.shzb,"+&
	"a.shsp,a.shwang,a.dangan,a.qz,a.sb_zcdm,a.tory,a.sbmc,a.tuitime,a.rysh,a.rysp,b.bg_qc_addrid as bg_qc_addrid,"+&
	"b.fl as fl,c.id as id,c.typename as typename,c.jyid as sh_jyid,c.addrid as addrid,c.addrname as addrname,"+&
	"c.mark as mark  from djylrq.b_aj_total as a,djylrq.u_addr_bg as b,djylrq.a_ry_dqm as c "+&
	"where a.jyid=b.bg_id and a.jytype=c.jytype and substring(b.bg_qc_addrid,1,2) = substring(c.addrid,1,2) and "+&
	"(a.jytype<>'#3' and a.jytype<>'U?' and a.jytype<>'T?' and a.jytype<>'V?' and a.jytype<>'<?' and a.jytype<>'&?' and "+&
	 "a.jytype<>'`?' and a.jytype<>'Va?' and a.jytype<>'`q?' and a.jytype<>'R?' and a.jytype<>'W?')" 
	 execute immediate :modsql using sqlca;
end if

