//////////////////////////////////////////////////////µ¥»ú°æ
string lbid_bgml,jymlid_bgml,jylbid_bgml,sx_bgml
if mark = 'sqlserver' then 
else
	DECLARE a_bgml_DJ CURSOR FOR
	SELECT id,jytype,lbid
	FROM a_bgml WHERE (jytype is not null and jytype not like '');   
	OPEN a_bgml_DJ;
	FETCH a_bgml_DJ INTO :id_bgml,:jytype_bgml,:lbid_bgml;
	do while sqlca.sqlcode = 0
		if len(jytype_bgml) = 3 then
			jymlid_bgml = left(jytype_bgml,2)
		elseif len(jytype_bgml) = 2 then
			jymlid_bgml = left(jytype_bgml,1)
		end if
		jylbid_bgml = right(jytype_bgml,1)
		if lbid_bgml = '' or isnull(lbid_bgml) then
		else
			choose case left(lbid_bgml,2)
				case 'rq'
					sx_bgml = '10'
				case 'gl'
					sx_bgml = '11'
				case 'gd'
					sx_bgml = '12'
				case 'qp'
					sx_bgml = '13'
				case 'sz'
					sx_bgml = '14'
				case 'aq'
					sx_bgml = '15'
				case 'ws'
					sx_bgml = '16'
				case 'dt'
					sx_bgml = '17'
				case 'qz'
					sx_bgml = '18'
				case 'cc'
					sx_bgml = '19'
				case 'sd'
					sx_bgml = '20'
				case 'yl'
					sx_bgml = '21'
				case 'qt'
					sx_bgml = '22'
			end choose		
		end if
		update a_bgml set jymlid = :jymlid_bgml,jylbid = :jylbid_bgml,sx = :sx_bgml where id like :id_bgml;
		FETCH a_bgml_DJ INTO :id_bgml,:jytype_bgml,:lbid_bgml;
	LOOP
	CLOSE a_bgml_DJ;
end if
end subroutine

