				"bz16 varchar(80) null,bz17 varchar(80) null,bz18 varchar(80) null,bz19 varchar(80) null,bz20 varchar(80) null,PRIMARY KEY (jyid));"
      execute immediate :mysql using sqlca ;	
END IF

end subroutine

