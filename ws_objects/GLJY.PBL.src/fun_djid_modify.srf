	modsql = "alter table glc_tzsb add primary key (cpid,djid)"
	execute immediate :modsql using sqlca;
end if
if mark = 'sqlserver' then
	modsql = "alter table djylrq.glc_qcgc add primary key (cpid)"
	execute immediate :modsql using sqlca;
end if
if mark = 'sqlserver' then
	modsql = "alter table djylrq.glc_dzgl add primary key (cpid)"
	execute immediate :modsql using sqlca;
end if
end subroutine

