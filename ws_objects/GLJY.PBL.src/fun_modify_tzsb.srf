				"yhsbbh varchar(30) null,wtn varchar(4) null,wtm varchar(2) null,wtd varchar(2) null,jyyj1 varchar(80) null,jyyj2 varchar(80) null,jyyj3 varchar(80) null,"+&
				"zyjyyqsb varchar(80) null,z1 varchar(80) null,z2 varchar(80) null,bz varchar(80) null,"+&
				"jyjl varchar(30) null,xcjyy varchar(4) null,xcjym varchar(2) null,xcjyd varchar(2) null,"+&
				"qfri varchar(4) null,moon varchar(2) null,day varchar(2) null,"+&
				"jy varchar(10) null,sh varchar(10) null,pz varchar(10) null,"+&
				");"
