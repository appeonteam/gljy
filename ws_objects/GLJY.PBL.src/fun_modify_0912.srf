	delsql = "drop view djylrq.View_ypgsb_sblbmc_nrcx"
	execute immediate :delsql using sqlca;
	mysql = "create View djylrq.View_ypgsb_sblbmc_nrcx as select b.zgbmmc as zgbmmc,a.sblb as sblb," + &
      "a.sbmc as sbmc,COUNT(a.sblb) AS [sum] " + &
		"from djylrq.glc_tzsb as a,djylrq.a_zgbm as b where a.zgbmid = b.zgbmid " + &
		"GROUP BY a.sblb, a.sbmc, b.zgbmmc"
	execute immediate :mysql using sqlca;
else
	delsql = "drop view View_ypgsb_sblbmc_nrcx"
	execute immediate :delsql using sqlca;
	mysql = "create View djylrq.View_ypgsb_sblbmc_nrcx as select b.zgbmmc as zgbmmc,a.sblb as sblb," + &
