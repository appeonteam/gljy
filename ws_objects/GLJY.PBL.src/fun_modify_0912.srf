      "COUNT(a.sydwmc) AS [sum],b.sblb as sblb,a.sbmc as sbmc,a.zzdw as zzdw,b.wxbydw as wxbydw," + &
		"b.dh as dh,b.lxr as lxr,a.yqmc as yqmc,a.rymc as rymc,a.second_rymc as second_rymc,a.yjrq as yjrq," + &
		"a.jyjzrq as jyjzrq,b.bcjyrq as bcjyrq,b.scjyrq as scjyrq " + &
		"from djylrq.z_rw_sb as a,djylrq.glc_tzsb as b where a.sydwmc = b.sydw " + &
		"GROUP BY a.sydwmc, b.sblb, a.sbmc, a.zzdw, b.wxbydw, b.dh, b.lxr, a.yqmc, a.rymc," + & 
      "a.second_rymc, a.yjrq, a.jyjzrq, b.bcjyrq,b.scjyrq"
