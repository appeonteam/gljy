if mark = 'sqlserver' then
	delsql = "drop view djylrq.View_ypgsb_nrcx"
	execute immediate :delsql using sqlca;
	mysql = "create View djylrq.View_ypgsb_nrcx as select a.jyid as jyid,a.djid as djid,a.cqdw as cqdw," + &
      "a.sydwmc as sydwmc,a.sbsydd as sbsydd,a.zzdw as zzdw,a.typename as typename,a.sglb as sglb,a.sbmc as sbmc,a.bm as bm," + &
		"a.yqmc as yqmc,a.rymc as rymc,a.second_rymc as second_rymc," + &
		"a.yjrq as yjrq,a.jyjzrq as jyjzrq," + &
		"b.bcjyrq as bcjyrq,b.scjyrq as scjyrq,b.wxbydw as wxbydw,b.dh as dh,b.lxr as lxr,b.ccbh as ccbh,b.dtyxsd as dtyxsd," + &
		"b.dtcz as dtcz,b.zhan as zhan,b.dtedzh as dtedzh,b.sblb as sblb,b.zgbmid as zgbmid,b.sb_zcdm as sb_zcdm," + &
      "b.nextyear + b.nextmonth + b.nextday AS nextdate " + &
		"from djylrq.z_rw_sb as a,djylrq.glc_tzsb as b where a.djid = b.djid AND a.sb_zcdm = b.sb_zcdm "
	execute immediate :mysql using sqlca;
else
	delsql = "drop view View_ypgsb_nrcx"
	execute immediate :delsql using sqlca;
	mysql = "create View djylrq.View_ypgsb_nrcx as select a.jyid as jyid,a.djid as djid,a.cqdw as cqdw," + &
      "a.sydwmc as sydwmc,a.sbsydd as sbsydd,a.zzdw as zzdw,a.typename as typename,a.sglb as sglb,a.sbmc as sbmc,a.bm as bm," + &
		"a.yqmc as yqmc,a.rymc as rymc,a.second_rymc as second_rymc," + &
		"a.yjrq as yjrq,a.jyjzrq as jyjzrq," + &
		"b.bcjyrq as bcjyrq,b.scjyrq as scjyrq,b.wxbydw as wxbydw,b.dh as dh,b.lxr as lxr,b.ccbh as ccbh,b.dtyxsd as dtyxsd," + &
		"b.dtcz as dtcz,b.zhan as zhan,b.dtedzh as dtedzh,b.sblb as sblb,b.zgbmid as zgbmid,b.sb_zcdm as sb_zcdm," + &
      "b.nextyear + b.nextmonth + b.nextday AS nextdate " + &
		"from z_rw_sb as a,glc_tzsb as b where a.djid = b.djid AND a.sb_zcdm = b.sb_zcdm "
	execute immediate :mysql using sqlca;
end if
