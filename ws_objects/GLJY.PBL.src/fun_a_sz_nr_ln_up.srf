///////////////////////////////Éý¼¶Ö®Ç°ÇåÀía_bgbhÖÐ²»·ûºÏ±ê×¼µÄ////////////////////////////
DECLARE ltemp_bgbh CURSOR FOR
SELECT jymlid,jylbid
FROM a_bgbh order by jymlid; 
OPEN ltemp_bgbh;
FETCH ltemp_bgbh INTO :ll_jymlid,:ll_jylbid;
do while sqlca.sqlcode = 0
	if isnull(ll_jymlid) or ll_jymlid = '' then
	else
		jytype_temp = ll_jymlid + ll_jylbid
		select count(*) into :ll_num from a_bgml where jytype like :jytype_temp;
		if ll_num = 0 then
			if jytype_bgbh = '' or isnull(jytype_bgbh) then
				jytype_bgbh = jytype_temp + ','
			else
				jytype_bgbh = jytype_bgbh + jytype_temp + ','
			end if
			delete a_bgbh where jymlid like :ll_jymlid and jylbid like :ll_jylbid;
		end if
	end if
FETCH ltemp_bgbh INTO :ll_jymlid,:ll_jylbid;
LOOP
CLOSE ltemp_bgbh;
