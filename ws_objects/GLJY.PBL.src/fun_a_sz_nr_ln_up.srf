string jytype,ll_jytype,condstr,cs1
string temp
temp = '1c,2c,4w,5s,5t,61,6c,6n,6u,7w,8d,8w,9v,Aa,Ap,Au,Av,Aw,D3,Da,Db,Dc,Di,Dj,Dk,Dm,Dp,Dr,Du,Dv,Dw,Ec,Eo,Fa,Fb,Ge,H,eIc,Id,Ip,Iu,Iw,Jc,Kc,Le,Oc,Od,On,Op,Os,Ou,Ov,Ow,Z9,Zf,Zg,Zh,Zl'
DECLARE temp6 CURSOR FOR
SELECT jytype
FROM a_sz_nr where xh = '' or xh is null ORDER BY jytype ; 
OPEN temp6;
FETCH temp6 INTO :jytype;
do while sqlca.sqlcode = 0
	if jytype = '' or isnull(jytype) then
	else
		if pos(temp,jytype) > 0 then
			if ll_jytype = '' or isnull(ll_jytype) then
				condstr = " where (jytype like '" + jytype + "'" + "' or"
				ll_jytype = jytype + ','
			else
				condstr = condstr +  " jytype like '" + jytype + "'" + "' or"
				ll_jytype = ll_jytype + jytype + ','
			end if
		end if
	end if
FETCH temp6 INTO :jytype;
LOOP
CLOSE temp6;
if right(condstr,2) = 'or' then 
	 condstr = replace(condstr,len(condstr) - 1,2,") and xh = '01' ORDER BY jytype")
end if
if condstr <> '' then
	cs1 =  "select jytype from a_bgml " + condstr
	declare shjb1_qc dynamic cursor for sqlsa;
	prepare sqlsa from :cs1;
	open dynamic shjb1_qc;
	fetch shjb1_qc into :jytype;
	do while sqlca.sqlcode = 0
	if isnull(jytype) then jytype = ''
	if pos(temp,jytype) > 0 then
	else
		DELETE FROM a_sz_nr WHERE jytype = :jytype;
	end if
	fetch shjb1_qc into :jytype;
	loop
	close shjb1_qc;
else
	DECLARE temp7 CURSOR FOR
	SELECT jytype
	FROM a_sz_nr where xh = '01' ORDER BY jytype ; 
	OPEN temp7;
	FETCH temp7 INTO :jytype;
	do while sqlca.sqlcode = 0
	if pos(temp,jytype) > 0 then
	else
		DELETE FROM a_sz_nr WHERE jytype = :jytype;
	end if
	FETCH temp7 INTO :jytype;
	LOOP
	CLOSE temp7;
end if
end subroutine

