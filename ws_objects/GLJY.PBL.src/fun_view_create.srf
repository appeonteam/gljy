if mark = 'sqlserver' then 
   delsql = "drop view djylrq.view_px_slg_xygl_cxfff"
	execute immediate :delsql using sqlca;
	mysql = "create view djylrq.view_px_slg_xygl_cxfff as select a.xh as xh,a.xm as xm,a.xb,a.nl,a.whcd,a.sfzh,a.gzdw,a.bm,a.zc,a.zw,"+&
       "a.lxdh,a.ch,a.dwdz,a.yb,a.xx,a.zy,a.bz as bz1,b.jfqk as jfqk,b.pxxm_jb as xmjb,"+&
       "b.pxxm_zgxm as zgxm,b.pxxm_gllb as czzldm,b.qc as qc,b.bmrq as bmrq,b.nian as nian,b.kh as kh,b.llcj "+&
       "as llcj,b.sjcj as sjcj,b.zh as zh,b.bz as bz2,c.kbsj as kbsj,c.khsj as khsj,"+&
       "c.fzsj as fzsj,c.yxq as yxq from djylrq.px_slg_xygl_bmb as a,djylrq.px_slg_xygl_fzb as b,djylrq.px_slg_xygl_ban as c "+&
		 "where a.bh=b.bh and b.nian=c.nian and b.qc=c.qc "+&
       " and b.pxxm_gllb=c.czzldm"
	execute immediate :mysql using sqlca;
else 
	delsql = "drop view view_px_slg_xygl_cxfff"
	execute immediate :delsql using sqlca;
	mysql = "create view view_px_slg_xygl_cxfff as select a.xh as xh,a.xm as xm,a.xb,a.nl,a.whcd,a.sfzh,a.gzdw,a.bm,a.zc,a.zw,"+&
       "a.lxdh,a.ch,a.dwdz,a.yb,a.xx,a.zy,a.bz as bz1,b.jfqk as jfqk,b.pxxm_jb as xmjb,"+&
       "b.pxxm_zgxm as zgxm,b.pxxm_gllb as czzldm,b.qc as qc,b.bmrq as bmrq,b.nian as nian,b.kh as kh,b.llcj "+&
       "as llcj,b.sjcj as sjcj,b.zh as zh,b.bz as bz2,c.kbsj as kbsj,c.khsj as khsj,"+&
       "c.fzsj as fzsj,c.yxq as yxq from px_slg_xygl_bmb as a,px_slg_xygl_fzb as b,px_slg_xygl_ban as c "+&
		 "where a.bh=b.bh and b.nian=c.nian and b.qc=c.qc "+&
