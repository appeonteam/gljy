event clicked;string is_select_mc,jytype
string is_select_mark
string temp_bb
long i
select qzjmark into :is_select_mark from a_jydw;
for i = 1 to 10
	is_select_mc = trim(cbx[i].text)
	select jytype into :jytype from view_bgml_total where typename like :is_select_mc;
	if i = 1 then
		if pos(is_select_mark,'Dk') <> 0 then
			is_select_mark = Replace(is_select_mark, pos(is_select_mark,'Dk'), 6, '')
		end if
		temp_bb = ''
		if cbx[i].checked = true then
			if rb_1.checked = false and rb_2.checked = false then
				MessageBox ('','ÄãÑ¡Ôñ°æ±¾£¡')
				return
			elseif rb_1.checked = true then
				temp_bb = '(A)'
			elseif rb_2.checked = true then	
				temp_bb = '(B)'
			end if
			if is_select_mark = '' or isnull(is_select_mark) then
				is_select_mark = jytype + temp_bb + ','
			else
				is_select_mark = is_select_mark + jytype + temp_bb + ','
			end if
		end if
	end if
	if i = 2 then
		if pos(is_select_mark,'Dj') <> 0 then
			is_select_mark = Replace(is_select_mark, pos(is_select_mark,'Dj'), 6, '')
		end if
		temp_bb = ''
		if cbx[i].checked = true then
			if rb_3.checked = false and rb_4.checked = false then
				MessageBox ('','ÄãÑ¡Ôñ°æ±¾£¡')
				return
			elseif rb_3.checked = true then
				temp_bb = '(A)'
			elseif rb_4.checked = true then	
				temp_bb = '(B)'
			end if
			if is_select_mark = '' or isnull(is_select_mark) then
				is_select_mark = jytype + temp_bb + ','
			else
				is_select_mark = is_select_mark + jytype + temp_bb + ','
			end if
		end if
	end if
	if i = 5 then
		if pos(is_select_mark,':w') <> 0 then
			is_select_mark = Replace(is_select_mark, pos(is_select_mark,':w'), 6, '')
		end if
		temp_bb = ''
		if cbx[i].checked = true then
			if rb_7.checked = false and rb_8.checked = false then
				MessageBox ('','ÄãÑ¡Ôñ°æ±¾£¡')
				return
			elseif rb_7.checked = true then
				temp_bb = '(A)'
			elseif rb_8.checked = true then	
				temp_bb = '(B)'
			end if
			if is_select_mark = '' or isnull(is_select_mark) then
				is_select_mark = jytype + temp_bb + ','
			else
				is_select_mark = is_select_mark + jytype + temp_bb + ','
			end if
		end if
	end if
	if i = 3 or i = 4 or i = 6 or i = 7 or i = 8 or i = 9 or i=10 then
		if pos(is_select_mark,jytype) <> 0 then
			is_select_mark = Replace(is_select_mark, pos(is_select_mark,jytype), len(jytype) + 1, '')
		end if
		if cbx[i].checked = true then
			if is_select_mark = '' or isnull(is_select_mark) then
				is_select_mark = jytype + ','
			else
				is_select_mark = is_select_mark + jytype + ','
			end if
		end if
	end if
next
//////////////////////////////////////////////////////////////////////////////
delete from a_sz_nr where jytype = ':w';
if pos(is_select_mark,':w') <> 0 then
	choose case mid(is_select_mark,pos(is_select_mark,':w') + 3,1)
		case 'A' //¹óÖÝÊ¡¹øÂ¯Ñ¹Á¦ÈÝÆ÷¼ìÑéÖÐÐÄ
			insert into a_sz_nr (jytype,xh,nr,fy,dw) values (':w','01','¼ì¶¨Ö¤Êé','¸½Ò³','jj_ylbzs_gz');
			insert into a_sz_nr (jytype,xh,nr,fy,dw) values (':w','02','¼ì¶¨½á¹û','¸½Ò³','jj_ylbjg_gz');
		case 'B' //°²Ë³ÊÐ¹øÂ¯Ñ¹Á¦ÈÝÆ÷¼ìÑéËù
			insert into a_sz_nr (jytype,xh,nr,fy,dw) values (':w','01','¼ì¶¨Ö¤Êé','¸½Ò³','jj_ylbzs_as');
			insert into a_sz_nr (jytype,xh,nr,fy,dw) values (':w','02','¼ì¶¨½á¹û','¸½Ò³','jj_ylbjg_as');
	end choose
else
	insert into a_sz_nr (jytype,xh,nr,fy,dw) values (':w','01','¼ì¶¨Ö¤Êé','¸½Ò³','jj_ylbzs');
end if
//////////////////////////////////////////////////////////////////////////////
delete from a_sz_nr where jytype like '`aw';
if pos(is_select_mark,'`aw')<>0 then //¹óÖÝÊ¡¹øÂ¯Ñ¹Á¦ÈÝÆ÷¼ìÑéÖÐÐÄ
	insert into a_sz_nr (jytype,xh,nr,fy,dw) values ('`aw','01','¼ì¶¨Ö¤Êé','¸½Ò³','dat_ylgdyjzs');//¹óÖÝ
else
	insert into a_sz_nr (jytype,xh,nr,fy,dw) values ('`aw','01','¼ì¶¨Ö¤Êé','¸½Ò³','dat_jdjyzs');//±ê×¼
end if 
//////////////////////////////////////////////////////////////////////////////
delete from a_sz_nr where jytype like '\aw';
if pos(is_select_mark,'\aw')<>0 then //¹óÖÝÊ¡¹øÂ¯Ñ¹Á¦ÈÝÆ÷¼ìÑéÖÐÐÄ
	insert into a_sz_nr (jytype,xh,nr,fy,dw) values ('\aw','01','¼ì¶¨Ö¤Êé','¸½Ò³','dat_ylgdyjzs');//¹óÖÝ
else
	insert into a_sz_nr (jytype,xh,nr,fy,dw) values ('\aw','01','¼ì¶¨Ö¤Êé','¸½Ò³','dat_jdjyzs');//±ê×¼
end if 
//////////////////////////////////////////////////////////////////////////////
delete from a_sz_nr where jytype like '=aw';
if pos(is_select_mark,'=aw')<>0 then //¹óÖÝÊ¡¹øÂ¯Ñ¹Á¦ÈÝÆ÷¼ìÑéÖÐÐÄ
	insert into a_sz_nr (jytype,xh,nr,fy,dw) values ('=aw','01','¼ì¶¨Ö¤Êé','¸½Ò³','dat_ylgdyjzs');//¹óÖÝ
else
	insert into a_sz_nr (jytype,xh,nr,fy,dw) values ('=aw','01','¼ì¶¨Ö¤Êé','¸½Ò³','dat_jdjyzs');//±ê×¼
end if 
//////////////////////////////////////////////////////////////////////////////
delete from a_sz_nr where jytype like 'D=';
if pos(is_select_mark,'D=')<>0 then //¹óÖÝÊ¡¹øÂ¯Ñ¹Á¦ÈÝÆ÷¼ìÑéÖÐÐÄ
	insert into a_sz_nr (jytype,xh,nr,fy,dw) values ('D=','01','Ë®ÖÊ¼à²â','¸½Ò³','dat_qj_sz_bg_gy');//¹óÖÝ
else
	insert into a_sz_nr (jytype,xh,nr,fy,dw) values ('D=','01','Ë®ÖÊ¼à²â','¸½Ò³','dat_qj_sz_bg');//±ê×¼
end if 
//////////////////////////////////////////////////////////////////////////////
delete from a_sz_nr where jytype like 'Qbp' or jytype like 'Qbw';
if pos(is_select_mark,'Qbp')<>0 then //¹óÖÝÊ¡¹øÂ¯Ñ¹Á¦ÈÝÆ÷¼ìÑéÖÐÐÄ
	insert into a_sz_nr (jytype,xh,nr,fy,dw) values ('Qbp','01','ÏîÄ¿±í','','dat_cyqpxmb');//¹óÖÝ
	insert into a_sz_nr (jytype,xh,nr,fy,dw) values ('Qbw','01','Ö¤Êé','','dat_cyqp_zs');
else
	insert into a_sz_nr (jytype,xh,nr,fy,dw) values ('Qbp','01','ÏîÄ¿±í1','','dat_czyhsyqgp_xmb1');
	insert into a_sz_nr (jytype,xh,nr,fy,dw) values ('Qbp','02','ÏîÄ¿±í2','','dat_czyhsyqgp_xmb2');
	insert into a_sz_nr (jytype,xh,nr,fy,dw) values ('Qbp','03','ÏîÄ¿±í3','','dat_czyhsyqgp_xmb3');
	insert into a_sz_nr (jytype,xh,nr,fy,dw) values ('Qbw','01','Ö¤Êé','','dat_clqp_zs');
end if 
//////////////////////////////////////////////////////////////////////////////
IF sqlca.sqlcode <>0 THEN
	MessageBox ('','¸üÐÂÊ§°Ü')
	return
else
	update a_jydw set qzjmark = :is_select_mark;
	commit;
	messagebox('ÏµÍ³ÌáÊ¾','ÉèÖÃÍê±Ï!')
END IF

end event

