		"b.sbmc as sbmc,b.ggxh as ggxh," + &
		"b.zzdw as zzdw,b.cpccbh as cpccbh,b.yhsbbh as yhsbbh,b.jyjl as jyjl,b.shname as shname,b.pzname as pzname " + &
