global subroutine fun_view_create2 ();//**fun_reCreatePX_DB**//
string delsql,mysql,myindex,modsql
int    li_temp
boolean lb_insert
string ls_temp
string mark = 'sybase'
if sqlca.dbms = "MSS (Msoft) SQL Server 6.0" then 
   mark = 'sqlserver'
end if
long ll_Count 
ll_Count = 0

if mark = 'sqlserver' then
	delsql = "drop view djylrq.view_gygljj_nrcx"
	execute immediate :delsql using sqlca;
	mysql = "create view djylrq.view_gygljj_nrcx as select a.jyid as jyid,a.djid as djid,a.sb_zcdm as sb_zcdm,a.nh as nh,a.bgid as bgid,a.jyml as jyml,"+&
                             "a.jylb as jylb,a.sydw as sydw,a.spmc as spmc,a.ryid as ryid,"+&
									  "a.rymc as rymc,a.rybm as rybm,a.jydate as jydate,"+&
									  "a.shib as shib,a.shmark as shmark,a.shtui as shtui,a.shzb as shzb,a.shsp as shsp,a.sjid as sjid,"+&
									  "a.shwang as shwang,"+&
                             "b.dz as dz,b.yzbm as yzbm,b.sydwlxr as sydwlxr,b.sydwdh as sydwdh,b.glxh as glxh,b.zzcm as zzcm,"+&
									  "b.sybh as sybh,b.cpbh as cpbh,b.edcl as edcl,b.edckyl as edckyl,b.syyl as syyl,b.edckwd as edckwd,"+&
									  "b.zzrq as zzrq,b.rszl as rszl,"+&
									  "c.shname as shname,c.shyear as shyear,c.jzd1 as jzd1,c.shday as shday, "+&
									  "c.jyy1 as jyy1,c.jyy2 as jyy2,c.jyy3 as jyy3,c.jyy4 as jyy4,c.jyy5 as jyy5"+&
      " from djylrq.b_jj_total as a,djylrq.b_jj_gygl_bg as b,djylrq.b_jj_gygl_xmb as c"+&
		" where a.jyid = b.jyid and a.jyid = c.jyid"
	execute immediate :mysql using sqlca;
else
	delsql = "drop view view_gygljj_nrcx"
	execute immediate :delsql using sqlca;
mysql ="create view view_gygljj_nrcx as select a.jyid as jyid,a.djid as djid,a.sb_zcdm as sb_zcdm,a.nh as nh,a.bgid as bgid,a.jyml as jyml,"+&
                             "a.jylb as jylb,a.sydw as sydw,a.spmc as spmc,a.ryid as ryid,"+&
									  "a.rymc as rymc,a.rybm as rybm,a.jydate as jydate,"+&
									  "a.shib as shib,a.shmark as shmark,a.shtui as shtui,a.shzb as shzb,a.shsp as shsp,a.sjid as sjid,"+&
									  "a.shwang as shwang,"+&
                             "b.dz as dz,b.yzbm as yzbm,b.sydwlxr as sydwlxr,b.sydwdh as sydwdh,b.glxh as glxh,b.zzcm as zzcm,"+&
									  "b.sybh as sybh,b.cpbh as cpbh,b.edcl as edcl,b.edckyl as edckyl,b.syyl as syyl,b.edckwd as edckwd,"+&
									  "b.zzrq as zzrq,b.rszl as rszl,"+&
									  "c.shname as shname,c.shyear as shyear,c.jzd1 as jzd1,c.shday as shday, "+&
									  "c.jyy1 as jyy1,c.jyy2 as jyy2,c.jyy3 as jyy3,c.jyy4 as jyy4,c.jyy5 as jyy5"+&
      " from b_jj_total as a,b_jj_gygl_bg as b,b_jj_gygl_xmb as c"+&
		" where a.jyid = b.jyid and a.jyid = c.jyid"
	execute immediate :mysql using sqlca;
end if

