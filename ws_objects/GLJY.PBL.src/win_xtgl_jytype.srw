			ls_show = ls_show + '0'
		else
			ls_show = ls_show + '1'
		end if
		select count(*) into :li_Str from a_bgml where jymk = 'aj' and lbid like 'qt%' and (mark = '' or mark is null);
		if li_Str = 0 then
			ls_show = ls_show + '0'
		else
			ls_show = ls_show + '1'
		end if
		select count(*) into :li_Str from a_bgml where jymk = 'jj' and lbid like 'qt%' and (mark = '' or mark is null);
		if li_Str = 0 then
			ls_show = ls_show + '0'
		else
			ls_show = ls_show + '1'
		end if
		ls_show = ls_show + '0'
		select count(*) into :li_Str from a_bgml where jymk = 'qj' and lbid like 'qt%' and (mark = '' or mark is null);
		if li_Str = 0 then
			ls_show = ls_show + '0'
		else
			ls_show = ls_show + '1'
		end if
end choose
ls_ReturnStr = ls_show
return ls_ReturnStr
end function

public function string fun_count1 (string jymk, string lbid, string mark);string ls_Str
string ls_ReturnStr
string ls_show = '' 
if lbid = '' or isnull(lbid) then 
	mark = mark + '%'
	select mark into :ls_Str from a_bgml where jymk = :jymk and mark like :mark and (lbid = '' or lbid is null);
	if ls_Str = '' or isnull(ls_Str) then
	else
		ls_Str = left(ls_Str,len(ls_Str) - 3)
	   ls_show = '0' +ls_Str
	end if
else
	lbid = lbid + '%'
	select lbid into :ls_Str from a_bgml where jymk = :jymk and lbid like :lbid and (mark = '' or mark is null);
	if ls_Str = '' or isnull(ls_Str) then
	else
		ls_Str = left(ls_Str,len(ls_Str) - 3)
	   ls_show = '1' +ls_Str
	end if
end if
ls_ReturnStr = ls_show
return ls_ReturnStr
end function

