event clicked;long ll_NowRow,ll_RowCount
string typename,ls_total,jytype
boolean lb_Succ
/////////////////////////////////////////////////////////////////////////////
ll_RowCount = tab_1.tabpage_1.dw_rqdj.RowCount()
if ll_RowCount > 0 then
	for ll_NowRow = 1 to ll_RowCount
		typename = tab_1.tabpage_1.dw_rqdj.getitemstring(ll_NowRow,'typename')
		select jytype into :jytype from a_bgml where typename like :typename;
		if isnull(typename) or typename = '' then
			MessageBox("ÌáÊ¾","È¨ÏÞ·ÖÅäÖÐÓÐÎ´·ÖÅäµÄÏîÄ¿£¡")
			return
		else
			if pos(ls_total,jytype) > 0 then
				MessageBox("ÌáÊ¾","µÚ" + string(ll_NowRow) + "ÐÐÈ¨ÏÞ·ÖÅäÖÐÓÐÖØ¸´·ÖÅäµÄÏîÄ¿£¡")
				return
			else
				if isnull(ls_total) or ls_total = '' then
					ls_total = jytype
				else
					ls_total = ls_total + ','
				end if
			   update a_bgml set mark = '' where typename like :typename;
			end if
		end if
	next
end if
/////////////////////////////////////////////////////////////////////////////
ll_RowCount = tab_1.tabpage_1.dw_rqaj.RowCount()
if ll_RowCount > 0 then
